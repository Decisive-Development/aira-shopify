{%- comment -%}
	Affiliate — Final CTA (scaffold).
	Slim variant of the shared final-cta — keeps affiliate page copy
	overrides isolated from the homepage's final CTA.
{%- endcomment -%}

<section class="bg-main text-secondary py-16 md:py-24 relative overflow-hidden">

	<div
		class="absolute inset-0 pointer-events-none"
		style="background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(155,183,212,0.12), transparent 70%);"
	></div>

	<div class="relative z-10 container mx-auto px-4 max-w-3xl text-center">
		{%- if section.settings.eyebrow != blank -%}
			<p class="text-xs font-bold uppercase tracking-widest text-tertiary-light mb-4">{{ section.settings.eyebrow }}</p>
		{%- endif -%}
		{%- if section.settings.heading != blank -%}
			<h2 class="font-heading heading-weight text-3xl md:text-4xl text-secondary m-0 mb-4 text-balance">{{ section.settings.heading }}</h2>
		{%- endif -%}
		{%- if section.settings.body != blank -%}
			<p class="text-base md:text-lg text-secondary/80 max-w-xl mx-auto mb-8">{{ section.settings.body }}</p>
		{%- endif -%}
		{%- if section.settings.cta_label != blank -%}
			{%- render 'cta-button',
				label: section.settings.cta_label,
				url:   section.settings.cta_url | default: '#affiliate-form',
				variant: 'accent',
				size: 'lg'
			-%}
		{%- endif -%}
	</div>
</section>

{% schema %}
{
	"name": "Affiliate - Final CTA",
	"settings": [
		{ "type": "text",     "id": "eyebrow",   "label": "Eyebrow",   "default": "Ready to partner?" },
		{ "type": "text",     "id": "heading",   "label": "Heading",   "default": "Apply to partner with AIRA" },
		{ "type": "textarea", "id": "body",      "label": "Body",      "default": "Two minutes to apply. We review every application within five business days." },
		{ "type": "text",     "id": "cta_label", "label": "CTA label", "default": "Apply now" },
		{ "type": "url",      "id": "cta_url",   "label": "CTA URL" }
	],
	"presets": [{ "name": "Affiliate - Final CTA" }]
}
{% endschema %}
