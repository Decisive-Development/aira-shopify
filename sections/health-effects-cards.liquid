{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'py-24 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

<style>
/* ─────────────────────────────────────────
   Scroll-in helpers
───────────────────────────────────────── */
.hecx-fade {
	opacity: 0;
	transform: translateY(28px);
	transition: opacity 0.7s ease, transform 0.7s ease;
}
.hecx-fade.is-visible {
	opacity: 1;
	transform: none;
}

/* ─────────────────────────────────────────
   Layout
───────────────────────────────────────── */
.hecx-layout {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1.25rem;
	align-items: stretch;
}
@media (min-width: 1024px) {
	.hecx-layout {
		grid-template-columns: 3fr 2fr;
		gap: 2rem;
	}
}

/* ─────────────────────────────────────────
   Display panel
───────────────────────────────────────── */
.hecx-display {
	position: relative;
	border-radius: 28px;
	overflow: hidden;
	min-height: 360px;
	display: flex;
	flex-direction: column;
	justify-content: flex-end;
	isolation: isolate;
}
@media (min-width: 1024px) {
	.hecx-display { min-height: 500px; }
}

/* Gradient layers — one per block, faded in/out */
.hecx-grad {
	position: absolute;
	inset: 0;
	opacity: 0;
	transition: opacity 0.85s ease;
	pointer-events: none;
	z-index: 0;
}
.hecx-grad.is-active { opacity: 1; }

/* Subtle vignette at the bottom so text is readable */
.hecx-vignette {
	position: absolute;
	inset: 0;
	background: linear-gradient(
		to top,
		rgba(0,0,0,0.55) 0%,
		rgba(0,0,0,0.15) 50%,
		rgba(0,0,0,0) 100%
	);
	z-index: 1;
	pointer-events: none;
}

/* Large decorative emoji floating in the top-right */
.hecx-deco {
	position: absolute;
	top: 50%;
	right: -0.5rem;
	transform: translateY(-54%) scale(0.7) rotate(-10deg);
	font-size: 13rem;
	line-height: 1;
	opacity: 0;
	filter: blur(3px);
	z-index: 2;
	pointer-events: none;
	user-select: none;
	transition:
		transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1),
		opacity   0.45s ease;
}
.hecx-deco.is-in {
	opacity: 0.15;
	transform: translateY(-54%) scale(1) rotate(-8deg);
}

/* Watermark number top-left */
.hecx-watermark {
	position: absolute;
	top: 1.75rem;
	left: 2.25rem;
	font-family: var(--font-heading-family, inherit);
	font-size: 7rem;
	font-weight: 900;
	line-height: 1;
	color: white;
	opacity: 0.08;
	z-index: 2;
	pointer-events: none;
	user-select: none;
	transition: opacity 0.3s ease;
}

/* Content area */
.hecx-display-content {
	position: relative;
	z-index: 3;
	padding: 2.25rem;
}
@media (min-width: 1024px) {
	.hecx-display-content { padding: 2.75rem 3rem; }
}

/* Animated inner — transitions on switch */
.hecx-inner {
	display: flex;
	flex-direction: column;
	gap: 0.65rem;
	transition: opacity 0.22s ease, transform 0.22s ease;
}
.hecx-inner.is-exit {
	opacity: 0;
	transform: translateY(-10px);
}
.hecx-inner.is-enter {
	opacity: 0;
	transform: translateY(12px);
	transition: none;
}

/* Icon pill */
.hecx-disp-icon {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 3.25rem;
	height: 3.25rem;
	border-radius: 13px;
	font-size: 1.6rem;
	background: rgba(255,255,255,0.18);
	backdrop-filter: blur(10px);
	-webkit-backdrop-filter: blur(10px);
	border: 1px solid rgba(255,255,255,0.28);
}

.hecx-disp-title {
	font-family: var(--font-heading-family, inherit);
	font-weight: 700;
	font-size: 1.65rem;
	line-height: 1.2;
	color: #fff;
	margin: 0;
}
@media (min-width: 768px) { .hecx-disp-title { font-size: 2.1rem; } }

.hecx-disp-desc {
	font-size: 0.875rem;
	line-height: 1.75;
	color: rgba(255,255,255,0.8);
	max-width: 42ch;
}
.hecx-disp-desc p { margin: 0; }

.hecx-disp-link {
	display: inline-flex;
	align-items: center;
	gap: 5px;
	margin-top: 0.25rem;
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.05em;
	color: rgba(255,255,255,0.88);
	text-decoration: none;
	border-bottom: 1px solid rgba(255,255,255,0.38);
	padding-bottom: 1px;
	width: fit-content;
	transition: gap 0.2s ease, border-color 0.2s ease;
}
.hecx-disp-link:hover { gap: 8px; border-color: rgba(255,255,255,0.88); }
.hecx-disp-link[hidden] { display: none !important; }

/* ─────────────────────────────────────────
   Nav list
───────────────────────────────────────── */
.hecx-nav {
	display: flex;
	flex-direction: row;
	gap: 0.5rem;
	overflow-x: auto;
	-webkit-overflow-scrolling: touch;
	scrollbar-width: none;
	padding-bottom: 2px; /* prevent box-shadow clip */
}
.hecx-nav::-webkit-scrollbar { display: none; }

@media (min-width: 1024px) {
	.hecx-nav {
		flex-direction: column;
		overflow-x: visible;
		gap: 0;
		padding-bottom: 0;
	}
}

.hecx-nav-btn {
	position: relative;
	display: flex;
	align-items: center;
	gap: 0.875rem;
	padding: 0.9rem 1.1rem;
	border-radius: 14px;
	background: transparent;
	border: none;
	cursor: pointer;
	text-align: left;
	overflow: hidden;
	flex-shrink: 0;
	width: 100%;
	transition: background 0.22s ease;
}
@media (max-width: 1023px) {
	.hecx-nav-btn { width: auto; min-width: 175px; }
}
.hecx-nav-btn:hover { background: rgba(0,0,0,0.04); }
.hecx-nav-btn.is-active {
	background: white;
	box-shadow: 0 3px 18px rgba(0,0,0,0.09);
}

.hecx-nav-emoji {
	font-size: 1.35rem;
	flex-shrink: 0;
	transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.hecx-nav-btn.is-active .hecx-nav-emoji { transform: scale(1.18); }

.hecx-nav-text { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; }

.hecx-nav-num {
	font-size: 0.62rem;
	font-weight: 700;
	letter-spacing: 0.1em;
	color: #bbb;
	line-height: 1;
}
.hecx-nav-label {
	font-size: 0.86rem;
	font-weight: 600;
	color: var(--color-copy, #666);
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
	line-height: 1.3;
	transition: color 0.22s ease;
}
.hecx-nav-btn.is-active .hecx-nav-label { color: var(--color-title, #111); }

/* Animated left accent bar on active */
.hecx-nav-bar {
	position: absolute;
	left: 0; top: 20%; bottom: 20%;
	width: 3px;
	border-radius: 2px;
	background: linear-gradient(to bottom, #a8edea, #c9b8ff);
	transform: scaleY(0);
	transform-origin: center;
	transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.hecx-nav-btn.is-active .hecx-nav-bar { transform: scaleY(1); }

/* Progress bar — fills over AUTO_DELAY ms */
.hecx-nav-prog {
	position: absolute;
	bottom: 0; left: 0;
	height: 2px;
	width: 0;
	border-radius: 2px;
	background: linear-gradient(90deg, #a8edea, #c9b8ff);
	pointer-events: none;
}
</style>

{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<section
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}
	<div class="{{ container_class }} {{ py }}">

		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div
				class="hecx-fade mb-10 lg:mb-12"
				data-hecx-fade
			>
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      section.settings.heading_align | default: 'left',
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- if section.blocks.size > 0 -%}
			<div class="hecx-fade hecx-layout" data-hecx-fade style="transition-delay: 120ms;">

				{%- comment -%} ── Display panel ── {%- endcomment -%}
				<div class="hecx-display" data-hecx-display>

					{%- comment -%} One gradient layer per block {%- endcomment -%}
					{%- for block in section.blocks -%}
						<div
							class="hecx-grad{% if forloop.first %} is-active{% endif %}"
							data-hecx-grad="{{ forloop.index0 }}"
						></div>
					{%- endfor -%}

					<div class="hecx-vignette" aria-hidden="true"></div>

					<div class="hecx-watermark" data-hecx-watermark aria-hidden="true">01</div>
					<div class="hecx-deco" data-hecx-deco aria-hidden="true">{{ section.blocks[0].settings.icon }}</div>

					<div class="hecx-display-content">
						<div class="hecx-inner" data-hecx-inner>
							<div class="hecx-disp-icon" data-hecx-disp-icon>{{ section.blocks[0].settings.icon }}</div>
							<h3 class="hecx-disp-title" data-hecx-disp-title>{{ section.blocks[0].settings.title }}</h3>
							<div class="hecx-disp-desc" data-hecx-disp-desc>{{ section.blocks[0].settings.description }}</div>
							{%- if section.blocks[0].settings.link_label != blank and section.blocks[0].settings.link_url != blank -%}
								<a
									href="{{ section.blocks[0].settings.link_url }}"
									class="hecx-disp-link"
									data-hecx-disp-link
								>
									{{ section.blocks[0].settings.link_label }}
									<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
								</a>
							{%- else -%}
								<a class="hecx-disp-link" data-hecx-disp-link hidden></a>
							{%- endif -%}
						</div>
					</div>

				</div>

				{%- comment -%} ── Nav list ── {%- endcomment -%}
				<nav class="hecx-nav" aria-label="{{ section.settings.heading | escape }}">
					{%- for block in section.blocks -%}
						{%- assign num = forloop.index | prepend: '0' | slice: -2, 2 -%}
						<button
							class="hecx-nav-btn{% if forloop.first %} is-active{% endif %}"
							data-hecx-nav="{{ forloop.index0 }}"
							aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
							{{ block.shopify_attributes }}
						>
							<span class="hecx-nav-bar" aria-hidden="true"></span>
							<span class="hecx-nav-emoji">{{ block.settings.icon }}</span>
							<span class="hecx-nav-text">
								<span class="hecx-nav-num">{{ num }}</span>
								<span class="hecx-nav-label">{{ block.settings.title }}</span>
							</span>
							<span class="hecx-nav-prog" data-hecx-prog aria-hidden="true"></span>
						</button>
					{%- endfor -%}
				</nav>

			</div>
		{%- endif -%}

	</div>
</section>

<script>
(function () {

	var AUTO_MS = 4200; // must match progress animation duration

	/* ── Block data (serialised from Liquid) ── */
	var BLOCKS = [
		{%- for block in section.blocks -%}
		{
			icon:       {{ block.settings.icon        | json }},
			title:      {{ block.settings.title       | json }},
			desc:       {{ block.settings.description | json }},
			linkLabel:  {{ block.settings.link_label  | json }},
			linkUrl:    {{ block.settings.link_url    | json }}
		}{% unless forloop.last %},{% endunless %}
		{%- endfor -%}
	];

	/* ── Gradient themes (cycles through blocks) ── */
	var GRADIENTS = [
		'linear-gradient(145deg,#ff6b6b 0%,#feca57 100%)',
		'linear-gradient(145deg,#4facfe 0%,#43e97b 100%)',
		'linear-gradient(145deg,#a18cd1 0%,#fbc2eb 100%)',
		'linear-gradient(145deg,#f7971e 0%,#ffd200 100%)',
		'linear-gradient(145deg,#30cfd0 0%,#667eea 100%)'
	];

	/* ── Apply gradients from JS (keeps Liquid clean) ── */
	document.querySelectorAll('[data-hecx-grad]').forEach(function (el) {
		var i = parseInt(el.getAttribute('data-hecx-grad'), 10);
		el.style.background = GRADIENTS[i % GRADIENTS.length];
	});

	/* ── DOM refs ── */
	var grads     = document.querySelectorAll('[data-hecx-grad]');
	var navBtns   = document.querySelectorAll('[data-hecx-nav]');
	var progBars  = document.querySelectorAll('[data-hecx-prog]');
	var inner     = document.querySelector('[data-hecx-inner]');
	var dispIcon  = document.querySelector('[data-hecx-disp-icon]');
	var dispTitle = document.querySelector('[data-hecx-disp-title]');
	var dispDesc  = document.querySelector('[data-hecx-disp-desc]');
	var dispLink  = document.querySelector('[data-hecx-disp-link]');
	var decoEl    = document.querySelector('[data-hecx-deco]');
	var watermark = document.querySelector('[data-hecx-watermark]');

	if (!inner || BLOCKS.length === 0) return;

	var current  = 0;
	var timer    = null;
	var progAnim = null; // rAF handle

	/* ── Initial deco pop-in ── */
	setTimeout(function () { if (decoEl) decoEl.classList.add('is-in'); }, 350);

	/* ── Progress bar (rAF-driven so it can be cancelled cleanly) ── */
	function startProgress() {
		cancelProgress();
		var progEl = progBars[current];
		if (!progEl) return;
		progEl.style.transition = 'none';
		progEl.style.width = '0%';

		var start = null;
		function tick(ts) {
			if (!start) start = ts;
			var pct = Math.min((ts - start) / AUTO_MS * 100, 100);
			progEl.style.transition = 'none';
			progEl.style.width = pct + '%';
			if (pct < 100) {
				progAnim = requestAnimationFrame(tick);
			}
		}
		progAnim = requestAnimationFrame(tick);
	}

	function cancelProgress() {
		if (progAnim) { cancelAnimationFrame(progAnim); progAnim = null; }
		progBars.forEach(function (b) {
			b.style.transition = 'none';
			b.style.width = '0%';
		});
	}

	/* ── Switch to index ── */
	function goTo(idx) {
		if (idx === current) return;
		current = idx;
		var b = BLOCKS[current];

		/* 1 — exit */
		inner.classList.add('is-exit');
		if (decoEl) decoEl.classList.remove('is-in');

		setTimeout(function () {

			/* 2 — swap gradient */
			grads.forEach(function (g, i) {
				g.classList.toggle('is-active', i === current);
			});

			/* 3 — update content */
			var numStr = (current + 1 < 10 ? '0' : '') + (current + 1);
			if (watermark) watermark.textContent = numStr;
			if (decoEl)    decoEl.textContent = b.icon;

			dispIcon.textContent  = b.icon;
			dispTitle.textContent = b.title;
			dispDesc.innerHTML    = b.desc || '';

			if (b.linkLabel && b.linkUrl) {
				dispLink.textContent = b.linkLabel;
				dispLink.setAttribute('href', b.linkUrl);
				dispLink.removeAttribute('hidden');
				var svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
				svg.setAttribute('width','11'); svg.setAttribute('height','11');
				svg.setAttribute('viewBox','0 0 24 24');
				svg.setAttribute('fill','none');
				svg.setAttribute('stroke','currentColor');
				svg.setAttribute('stroke-width','2.5');
				svg.setAttribute('aria-hidden','true');
				var p = document.createElementNS('http://www.w3.org/2000/svg','path');
				p.setAttribute('stroke-linecap','round');
				p.setAttribute('stroke-linejoin','round');
				p.setAttribute('d','M9 5l7 7-7 7');
				svg.appendChild(p); dispLink.appendChild(svg);
			} else {
				dispLink.setAttribute('hidden','');
			}

			/* 4 — enter */
			inner.classList.remove('is-exit');
			inner.classList.add('is-enter');
			requestAnimationFrame(function () {
				requestAnimationFrame(function () {
					inner.classList.remove('is-enter');
					setTimeout(function () {
						if (decoEl) decoEl.classList.add('is-in');
					}, 40);
				});
			});

			/* 5 — update nav */
			navBtns.forEach(function (btn, i) {
				var active = (i === current);
				btn.classList.toggle('is-active', active);
				btn.setAttribute('aria-pressed', active ? 'true' : 'false');
			});

			/* 6 — restart progress */
			startProgress();

		}, 240);
	}

	/* ── Auto-advance ── */
	function scheduleNext() {
		clearTimeout(timer);
		timer = setTimeout(function () {
			goTo((current + 1) % BLOCKS.length);
			scheduleNext();
		}, AUTO_MS);
	}

	/* ── Nav clicks ── */
	navBtns.forEach(function (btn, i) {
		btn.addEventListener('click', function () {
			clearTimeout(timer);
			goTo(i);
			scheduleNext();
		});
	});

	/* ── Scroll-in ── */
	var fadeEls = document.querySelectorAll('[data-hecx-fade]');
	if ('IntersectionObserver' in window) {
		var io = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (!entry.isIntersecting) return;
				entry.target.classList.add('is-visible');
				io.unobserve(entry.target);
			});
		}, { threshold: 0.1 });
		fadeEls.forEach(function (el) { io.observe(el); });
	} else {
		fadeEls.forEach(function (el) { el.classList.add('is-visible'); });
	}

	/* ── Boot ── */
	startProgress();
	scheduleNext();

})();
</script>

{% schema %}
{
	"name": "Health Effects Spotlight",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Why it matters"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Health effects of poor airflow"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Mouth breathing and restricted nasal airflow have been linked to a surprising range of health issues — many of which are reversible."
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FAFAFA"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 0,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"blocks": [
		{
			"type": "effect",
			"name": "Health effect",
			"settings": [
				{
					"type": "text",
					"id": "icon",
					"label": "Icon (emoji)",
					"default": "🫀"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "High blood pressure"
				},
				{
					"type": "richtext",
