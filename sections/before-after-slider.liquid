{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'py-24 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase

	assign has_before_img = false
	if section.settings.before_image != blank
		assign has_before_img = true
	endif

	assign has_after_img = false
	if section.settings.after_image != blank
		assign has_after_img = true
	endif
-%}

<section class="w-full bg-bg">
	<div class="{{ container_class }} {{ py }}">

		{%- comment -%} Section heading {%- endcomment -%}
		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div class="mb-12 md:mb-16">
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      section.settings.heading_align,
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- comment -%} Comparison slider {%- endcomment -%}
		<div
			class="relative max-w-3xl mx-auto rounded-2xl overflow-hidden select-none touch-none"
			data-comparison-slider
		>

			{%- comment -%} After image — base layer, determines container height {%- endcomment -%}
			<div class="w-full">
				{%- if has_after_img -%}
					{{
						section.settings.after_image
						| image_url: width: 1200
						| image_tag:
							loading: 'lazy',
							class: 'w-full h-auto block',
							widths: '400, 600, 800, 1200'
					}}
				{%- else -%}
					{% # theme-check-disable RemoteAsset %}
					<img
						src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&q=80&auto=format&fit=crop"
						alt="{{ section.settings.after_label | default: 'After' }}"
						class="w-full h-auto block"
						width="1200"
						height="800"
						loading="lazy"
					>
					{% # theme-check-enable RemoteAsset %}
				{%- endif -%}
			</div>

			{%- comment -%} After label {%- endcomment -%}
			{%- if section.settings.after_label != blank -%}
				<span class="absolute bottom-4 right-4 px-3 py-1.5 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
					{{ section.settings.after_label }}
				</span>
			{%- endif -%}

			{%- comment -%} Before pane — full size, clip-path drives the reveal {%- endcomment -%}
			<div class="absolute inset-0" style="clip-path: inset(0 50% 0 0);" data-before-pane>

				{%- if has_before_img -%}
					{{
						section.settings.before_image
						| image_url: width: 1200
						| image_tag:
							loading: 'lazy',
							class: 'absolute inset-0 w-full h-full object-cover',
							widths: '400, 600, 800, 1200'
					}}
				{%- else -%}
					{% # theme-check-disable RemoteAsset %}
					<img
						src="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1200&q=80&auto=format&fit=crop"
						alt="{{ section.settings.before_label | default: 'Before' }}"
						class="absolute inset-0 w-full h-full object-cover"
						width="1200"
						height="800"
						loading="lazy"
					>
					{% # theme-check-enable RemoteAsset %}
				{%- endif -%}

				{%- comment -%} Before label {%- endcomment -%}
				{%- if section.settings.before_label != blank -%}
					<span class="absolute bottom-4 left-4 px-3 py-1.5 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
						{{ section.settings.before_label }}
					</span>
				{%- endif -%}

			</div>

			{%- comment -%} Drag handle — 40px wide hit target centred on divider line {%- endcomment -%}
			<div
				class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-10 flex items-center justify-center cursor-col-resize z-10"
				data-divider
			>
				{%- comment -%} Vertical line {%- endcomment -%}
				<div class="absolute inset-y-0 left-1/2 -translate-x-1/2 w-0.5 bg-white pointer-events-none"></div>

				{%- comment -%} Circle handle {%- endcomment -%}
				<div class="w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center relative pointer-events-none">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2.5"
						class="text-main"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-4 3 4 3M16 9l4 3-4 3"/>
					</svg>
				</div>
			</div>

		</div>

	</div>
</section>

<script>
	(function () {
		document.querySelectorAll('[data-comparison-slider]').forEach(function (slider) {
			var beforePane = slider.querySelector('[data-before-pane]');
			var divider    = slider.querySelector('[data-divider]');
			var dragging   = false;

			function setPosition(clientX) {
				var rect = slider.getBoundingClientRect();
				var pct  = ((clientX - rect.left) / rect.width) * 100;
				pct = Math.min(Math.max(pct, 2), 98);
				beforePane.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
				divider.style.left        = pct + '%';
				divider.style.transform = 'translateX(-50%)';
			}

			divider.addEventListener('mousedown', function (e) {
				dragging = true;
				e.preventDefault();
			});

			window.addEventListener('mousemove', function (e) {
				if (dragging) setPosition(e.clientX);
			});

			window.addEventListener('mouseup', function () {
				dragging = false;
			});

			divider.addEventListener('touchstart', function (e) {
				dragging = true;
				e.preventDefault();
			}, { passive: false });

			window.addEventListener('touchmove', function (e) {
				if (!dragging) return;
				e.preventDefault();
				setPosition(e.touches[0].clientX);
			}, { passive: false });

			window.addEventListener('touchend', function () {
				dragging = false;
			});
		});
	})();
</script>

{% schema %}
{
	"name": "Before / After Slider",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "See the difference"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Breathe the way you were meant to."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Drag to compare your airways — without and with the Aira nasal strip."
		},
		{
			"type": "select",
			"id": "heading_align",
			"label": "Heading alignment",
			"options": [
				{ "value": "left",   "label": "Left" },
				{ "value": "center", "label": "Center" },
				{ "value": "right",  "label": "Right" }
			],
			"default": "center"
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Before image"
		},
		{
			"type": "image_picker",
			"id": "before_image",
			"label": "Before image"
		},
		{
			"type": "text",
			"id": "before_label",
			"label": "Before label",
			"default": "Without Aira"
		},
		{
			"type": "header",
			"content": "After image"
		},
		{
			"type": "image_picker",
			"id": "after_image",
			"label": "After image"
		},
		{
			"type": "text",
			"id": "after_label",
			"label": "After label",
			"default": "With Aira"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"presets": [
		{
			"name": "Before / After Slider"
		}
	]
}
{% endschema %}
