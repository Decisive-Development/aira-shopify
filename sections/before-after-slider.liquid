{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-4 md:py-12'
		when 'md'
			assign py = 'py-8 md:py-20'
		when 'lg'
			assign py = 'py-12 md:py-32'
		when 'xl'
			assign py = 'py-16 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase

	assign has_before_img = false
	if section.settings.before_image != blank
		assign has_before_img = true
	endif

	assign has_after_img = false
	if section.settings.after_image != blank
		assign has_after_img = true
	endif

	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<section
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}
	<div class="{{ container_class }} {{ py }}">

		{%- comment -%} Section heading {%- endcomment -%}
		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div class="mb-12 md:mb-16">
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      section.settings.heading_align,
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- comment -%} Comparison slider {%- endcomment -%}
		<div
			class="relative max-w-4xl mx-auto rounded-2xl overflow-hidden select-none touch-none aspect-[16/10]"
			data-comparison-slider
		>

			{%- comment -%} After image — base layer {%- endcomment -%}
			<div class="absolute inset-0">
				{%- if has_after_img -%}
					{{
						section.settings.after_image
						| image_url: width: 1200
						| image_tag:
							loading: 'lazy',
							class: 'w-full h-auto block',
							widths: '400, 600, 800, 1200',
							draggable: 'false'
					}}
				{%- else -%}
					<img
						src="{{ 'images/With_Compressed.webp' | asset_url }}"
						alt="{{ section.settings.after_label | default: 'With Aira' }}"
						class="w-full h-auto block"
						width="600"
						height="654"
						loading="lazy"
						draggable="false"
					>
				{%- endif -%}
			</div>

			{%- comment -%} After label {%- endcomment -%}
			{%- if section.settings.after_label != blank -%}
				<span class="absolute bottom-4 right-4 px-3 py-1.5 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
					{{ section.settings.after_label }}
				</span>
			{%- endif -%}

			{%- comment -%} Before pane — clip-path on the pane drives the reveal (clips image + label together) {%- endcomment -%}
			<div class="absolute inset-0" style="clip-path: inset(0 50% 0 0)" data-before-pane>

				{%- if has_before_img -%}
					{{
						section.settings.before_image
						| image_url: width: 1200
						| image_tag:
							loading: 'lazy',
							class: 'w-full h-auto block',
							widths: '400, 600, 800, 1200',
							draggable: 'false'
					}}
				{%- else -%}
					<img
						src="{{ 'images/Without_Compressed.webp' | asset_url }}"
						alt="{{ section.settings.before_label | default: 'Without Aira' }}"
						class="w-full h-auto block"
						width="600"
						height="654"
						loading="lazy"
						draggable="false"
					>
				{%- endif -%}

				{%- comment -%} Before label {%- endcomment -%}
				{%- if section.settings.before_label != blank -%}
					<span class="absolute bottom-4 left-4 px-3 py-1.5 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
						{{ section.settings.before_label }}
					</span>
				{%- endif -%}

			</div>

			{%- comment -%} Drag handle — centred on divider line via margin-left, no transform {%- endcomment -%}
			<div
				class="absolute inset-y-0 w-10 flex items-center justify-center cursor-grab z-10"
				style="left: 50%; margin-left: -20px"
				data-divider
			>
				{%- comment -%} Vertical line {%- endcomment -%}
				<div class="absolute inset-y-0 left-1/2 w-0.5 -translate-x-px bg-white pointer-events-none"></div>

				{%- comment -%} Circle handle {%- endcomment -%}
				<div class="w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center pointer-events-none">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2.5"
						class="text-main"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M8 9l-4 3 4 3M16 9l4 3-4 3"/>
					</svg>
				</div>
			</div>

		</div>

	</div>
</section>

<script>
	(function () {
		document.querySelectorAll('[data-comparison-slider]').forEach(function (slider) {
			var beforePane = slider.querySelector('[data-before-pane]');
			var divider    = slider.querySelector('[data-divider]');
			var dragging   = false;

			function setPosition(clientX) {
				var rect = slider.getBoundingClientRect();
				var pct  = ((clientX - rect.left) / rect.width) * 100;
				pct = Math.min(Math.max(pct, 2), 98);
				beforePane.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
				divider.style.left       = pct + '%';
				divider.style.marginLeft = '-20px';
			}

			divider.addEventListener('mousedown', function (e) {
				dragging = true;
				divider.style.cursor = 'grabbing';
				e.preventDefault();
			});

			window.addEventListener('mousemove', function (e) {
				if (dragging) setPosition(e.clientX);
			});

			window.addEventListener('mouseup', function () {
				dragging = false;
				divider.style.cursor = '';
			});

			divider.addEventListener('touchstart', function (e) {
				dragging = true;
				e.preventDefault();
			}, { passive: false });

			window.addEventListener('touchmove', function (e) {
				if (!dragging) return;
				e.preventDefault();
				setPosition(e.touches[0].clientX);
			}, { passive: false });

			window.addEventListener('touchend', function () {
				dragging = false;
			});
		});
	})();
</script>

{% schema %}
{
	"name": "Before / After Slider",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "See the difference"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Breathe the way you were meant to."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Drag to compare your airways — without and with the Aira nasal strip."
		},
		{
			"type": "select",
			"id": "heading_align",
			"label": "Heading alignment",
			"options": [
				{ "value": "left",   "label": "Left" },
				{ "value": "center", "label": "Center" },
				{ "value": "right",  "label": "Right" }
			],
			"default": "center"
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Before image"
		},
		{
			"type": "image_picker",
			"id": "before_image",
			"label": "Before image"
		},
		{
			"type": "text",
			"id": "before_label",
			"label": "Before label",
			"default": "Without Aira"
		},
		{
			"type": "header",
			"content": "After image"
		},
		{
			"type": "image_picker",
			"id": "after_image",
			"label": "After image"
		},
		{
			"type": "text",
			"id": "after_label",
			"label": "After label",
			"default": "With Aira"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FFFFFF"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 0,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"presets": [
		{
			"name": "Before / After Slider"
		}
	]
}
{% endschema %}
