{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign pt = ''
			assign pb = ''
		when 'sm'
			assign pt = 'pt-8 md:pt-12'
			assign pb = 'pb-8 md:pb-12'
		when 'md'
			assign pt = 'pt-16 md:pt-20'
			assign pb = 'pb-16 md:pb-20'
		when 'lg'
			assign pt = 'pt-24 md:pt-32'
			assign pb = 'pb-24 md:pb-32'
	endcase
-%}

{%- comment -%} Page header — dark bg so transparent nav is visible {%- endcomment -%}
<div class="bg-main pt-32 pb-16 md:pt-36 md:pb-20">
	<div class="container-contained text-center">
		{%- if section.settings.eyebrow != blank -%}
			<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-4">{{ section.settings.eyebrow }}</p>
		{%- endif -%}
		<h1 class="font-heading font-bold text-4xl md:text-5xl leading-tight tracking-tight text-secondary">
			{{ section.settings.heading | default: 'Shop' }}
		</h1>
		{%- if section.settings.subheading != blank -%}
			<p class="text-base md:text-lg leading-relaxed text-secondary opacity-65 max-w-2xl mx-auto mt-4">{{ section.settings.subheading }}</p>
		{%- endif -%}
	</div>
</div>

<section style="background-color: {{ section.settings.background_color }};">
	<div class="container-contained {{ pt }} {{ pb }}">

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
			{%- for collection in collections -%}
				{%- if collection.products_count == 0 or collection.handle == 'frontpage' -%}
					{%- continue -%}
				{%- endif -%}

				<a href="{{ collection.url }}" class="group block rounded-2xl overflow-hidden bg-bg shadow-sm hover:shadow-lg transition-shadow duration-300">
					<div class="relative aspect-4/5 overflow-hidden bg-bg-muted">
						{%- if collection.featured_image -%}
							{{
								collection.featured_image
								| image_url: width: 800
								| image_tag:
									loading: 'lazy',
									class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
									widths: '400, 600, 800'
							}}
						{%- elsif collection.products.first.featured_image -%}
							{{
								collection.products.first.featured_image
								| image_url: width: 800
								| image_tag:
									loading: 'lazy',
									class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
									widths: '400, 600, 800'
							}}
						{%- else -%}
							<div class="w-full h-full flex items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" class="text-copy opacity-20">
									<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
								</svg>
							</div>
						{%- endif -%}
					</div>

					<div class="p-5 md:p-6">
						<h3 class="font-heading text-title font-semibold text-lg leading-snug group-hover:opacity-75 transition-opacity">
							{{ collection.title }}
						</h3>
						{%- if collection.description != blank -%}
							<p class="text-copy text-sm leading-relaxed mt-1.5 line-clamp-2">
								{{ collection.description | strip_html | truncate: 100 }}
							</p>
						{%- endif -%}
						<p class="text-sm text-copy opacity-50 mt-2">
							{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}
						</p>
					</div>
				</a>
			{%- endfor -%}
		</div>

	</div>
</section>

{% schema %}
{
	"name": "Collections Grid",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Browse"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Shop by category"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FFFFFF"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" }
			],
			"default": "lg"
		}
	]
}
{% endschema %}
