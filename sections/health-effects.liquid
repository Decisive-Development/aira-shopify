{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'py-24 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<section
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}
	<div class="{{ container_class }} {{ py }}">

		<div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

			{%- comment -%} Left: section image {%- endcomment -%}
			<div
				class="transition-all duration-700 ease-out opacity-0 translate-y-8"
				data-animate
			>
				{%- if section.settings.image != blank -%}
					{{
						section.settings.image
						| image_url: width: 800
						| image_tag:
							loading: 'lazy',
							class: 'w-full h-auto rounded-2xl object-cover shadow-lg',
							widths: '400, 600, 800',
							draggable: 'false'
					}}
				{%- else -%}
					<div class="w-full aspect-4/5 rounded-2xl bg-bg-muted flex items-center justify-center">
						<span class="text-copy text-sm">Upload a section image</span>
					</div>
				{%- endif -%}
			</div>

			{%- comment -%} Right: heading + accordion list {%- endcomment -%}
			<div class="flex flex-col gap-10">

				{%- comment -%} Section heading {%- endcomment -%}
				{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
					<div
						class="transition-all duration-700 ease-out opacity-0 translate-y-8"
						style="transition-delay: 100ms"
						data-animate
					>
						{%- render 'section-heading',
							eyebrow:    section.settings.eyebrow,
							heading:    section.settings.heading,
							subheading: section.settings.subheading,
							align:      'left',
							size:       section.settings.heading_size
						-%}
					</div>
				{%- endif -%}

				{%- comment -%} Health effect accordion items {%- endcomment -%}
				{%- if section.blocks.size > 0 -%}
					<div class="flex flex-col divide-y divide-bg-muted" role="list">
						{%- for block in section.blocks -%}
							{%- assign delay = forloop.index | times: 75 | plus: 160 -%}
							<div
								class="py-5 first:pt-0 last:pb-0 transition-all duration-500 ease-out opacity-0 translate-y-6"
								style="transition-delay: {{ delay }}ms"
								data-animate
								data-accordion-item
								{{ block.shopify_attributes }}
							>

								{%- comment -%} Accordion trigger {%- endcomment -%}
								<button
									class="w-full flex items-center gap-4 text-left cursor-pointer"
									aria-expanded="false"
									data-accordion-toggle
								>
									{%- comment -%} Icon pill {%- endcomment -%}
									<div class="shrink-0 w-10 h-10 rounded-xl bg-secondary flex items-center justify-center text-xl leading-none select-none transition-colors duration-200">
										{{ block.settings.icon }}
									</div>

									<span class="flex-1 font-heading font-semibold text-title text-lg leading-snug">
										{{ block.settings.title }}
									</span>

									{%- comment -%} Chevron — rotated when open {%- endcomment -%}
									<svg
										class="shrink-0 w-5 h-5 text-copy transition-transform duration-300"
										data-accordion-chevron
										xmlns="http://www.w3.org/2000/svg"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="2"
										aria-hidden="true"
									>
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
									</svg>
								</button>

								{%- comment -%} Expandable body {%- endcomment -%}
								<div
									class="overflow-hidden"
									style="max-height: 0; transition: max-height 0.35s ease"
									data-accordion-body
								>
									<div class="pt-4 pl-14 flex flex-col gap-3">
										{%- if block.settings.description != blank -%}
											<div class="text-base text-copy leading-relaxed">
												{{ block.settings.description }}
											</div>
										{%- endif -%}
										{%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
											<a
												href="{{ block.settings.link_url }}"
												class="inline-flex items-center gap-1.5 text-sm font-semibold text-highlight hover:underline"
											>
												{{ block.settings.link_label }}
												<svg
													class="w-3.5 h-3.5"
													xmlns="http://www.w3.org/2000/svg"
													fill="none"
													viewBox="0 0 24 24"
													stroke="currentColor"
													stroke-width="2.5"
													aria-hidden="true"
												>
													<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
												</svg>
											</a>
										{%- endif -%}
									</div>
								</div>

							</div>
						{%- endfor -%}
					</div>
				{%- endif -%}

			</div>
		</div>
	</div>
</section>

<script>
	(function () {

		{%- comment -%} Scroll-in animation {%- endcomment -%}
		var animateEls = document.querySelectorAll('[data-animate]');

		if ('IntersectionObserver' in window) {
			var observer = new IntersectionObserver(function (entries) {
				entries.forEach(function (entry) {
					if (!entry.isIntersecting) return;
					var el = entry.target;
					el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
					observer.unobserve(el);
				});
			}, { threshold: 0.15 });

			animateEls.forEach(function (el) {
				observer.observe(el);
			});
		} else {
			// Fallback: show everything immediately
			animateEls.forEach(function (el) {
				el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
			});
		}

		{%- comment -%} Accordion {%- endcomment -%}
		document.querySelectorAll('[data-accordion-item]').forEach(function (item) {
			var toggle  = item.querySelector('[data-accordion-toggle]');
			var body    = item.querySelector('[data-accordion-body]');
			var chevron = item.querySelector('[data-accordion-chevron]');

			if (!toggle || !body) return;

			toggle.addEventListener('click', function () {
				var isOpen = toggle.getAttribute('aria-expanded') === 'true';

				if (isOpen) {
					body.style.maxHeight = '0';
					toggle.setAttribute('aria-expanded', 'false');
					if (chevron) chevron.classList.remove('rotate-180');
				} else {
					body.style.maxHeight = body.scrollHeight + 'px';
					toggle.setAttribute('aria-expanded', 'true');
					if (chevron) chevron.classList.add('rotate-180');
				}
			});
		});

	})();
</script>

{% schema %}
{
	"name": "Health Effects",
	"settings": [
		{
			"type": "header",
			"content": "Image"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Section image"
		},
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Why it matters"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Health effects of poor airflow"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Mouth breathing and restricted nasal airflow have been linked to a surprising range of health issues — many of which are reversible."
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FAFAFA"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 0,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"blocks": [
		{
			"type": "effect",
			"name": "Health effect",
			"settings": [
				{
					"type": "text",
					"id": "icon",
					"label": "Icon (emoji)",
					"default": "🫀"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "High blood pressure"
				},
				{
					"type": "richtext",
					"id": "description",
					"label": "Description",
					"default": "<p>Mouth breathing activates the body's stress response, raising cortisol and constricting blood vessels. Over time this can contribute to chronically elevated blood pressure — a major risk factor for heart disease.</p>"
				},
				{
					"type": "text",
					"id": "link_label",
					"label": "Link label"
				},
				{
					"type": "url",
					"id": "link_url",
					"label": "Link URL"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Health Effects",
			"blocks": [
				{
					"type": "effect",
					"settings": {
						"icon": "🫀",
						"title": "High blood pressure",
						"description": "<p>Mouth breathing activates the body's stress response, raising cortisol and constricting blood vessels. Over time this can contribute to chronically elevated blood pressure — a major risk factor for heart disease.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "😴",
						"title": "Snoring",
						"description": "<p>When the nose is bypassed, the soft tissue at the back of the throat is more likely to vibrate during sleep — producing the sound of snoring. Nasal breathing stabilises this tissue and reduces vibration significantly.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "💧",
						"title": "Dry mouth",
						"description": "<p>Breathing through the mouth dries out saliva, which is your body's first line of defence against bacteria. Chronic dry mouth leads to bad breath, tooth decay, and gum disease.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "🌙",
						"title": "Poor sleep quality",
						"description": "<p>Mouth breathing reduces oxygen uptake and disrupts sleep architecture — resulting in more time in lighter sleep stages. Switching to nasal breathing has been shown to improve deep sleep and morning energy levels.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "🧒",
						"title": "Facial development",
						"description": "<p>In children, long-term mouth breathing can alter the development of facial bones — leading to a narrower palate, elongated face, and crowded teeth. Early nasal breathing habits help guide healthy craniofacial growth.</p>"
					}
				}
			]
		}
	]
}
{% endschema %}
