{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'py-24 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<style>
	@property --border-progress {
		syntax: "<angle>";
		initial-value: 0deg;
		inherits: false;
	}

	.he-card {
		background: rgba(10, 26, 52, 0.12);
		padding: 2px;
	}

	.he-card:hover {
		background: rgba(10, 26, 52, 0.22);
	}

	.he-card.is-next {
		--border-progress: 0deg;
		background: conic-gradient(
			from 0deg,
			#FF4000 var(--border-progress),
			rgba(10, 26, 52, 0.12) var(--border-progress)
		);
		animation: he-sweep 5s linear forwards;
	}

	.he-card.is-next:hover {
		background: conic-gradient(
			from 0deg,
			#FF4000 var(--border-progress),
			rgba(10, 26, 52, 0.22) var(--border-progress)
		);
	}

	.he-card.sweep-paused {
		animation-play-state: paused;
	}

	@keyframes he-sweep {
		to { --border-progress: 360deg; }
	}

	@keyframes he-card-enter {
		from {
			opacity: 0;
			transform: scale(0.92);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	.he-card.card-entering {
		animation: he-card-enter 0.35s ease-out forwards;
	}
</style>

<section
	id="health-effects-{{ section.id }}"
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}

	<div class="{{ container_class }} {{ py }}">

		{%- comment -%} Section heading {%- endcomment -%}
		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div
				class="mb-12 transition-all duration-700 ease-out opacity-0 translate-y-8"
				data-animate
			>
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      'center',
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- if section.blocks.size > 0 -%}
			<div
				class="grid lg:grid-cols-2 gap-6 lg:gap-8 transition-all duration-700 ease-out opacity-0 translate-y-8"
				style="transition-delay: 100ms"
				data-animate
				data-health-effects="{{ section.id }}"
			>

				{%- comment -%} ── Left: Focus panel ── {%- endcomment -%}
				<div class="relative rounded-2xl overflow-hidden bg-main min-h-[420px] lg:min-h-[540px]">
					{%- for block in section.blocks -%}
						<div
							class="absolute inset-0 flex flex-col transition-opacity duration-500 {% if forloop.first %}opacity-100{% else %}opacity-0 pointer-events-none{% endif %}"
							data-focus-panel="{{ forloop.index0 }}"
						>
							{%- comment -%} Image — top portion {%- endcomment -%}
							<div class="relative flex-1">
								{%- if block.settings.image != blank -%}
									{{
										block.settings.image
										| image_url: width: 1200
										| image_tag:
											loading: 'lazy',
											class: 'absolute inset-0 w-full h-full object-cover',
											widths: '400, 600, 800, 1200'
									}}
								{%- else -%}
									<div class="absolute inset-0 bg-main/60"></div>
								{%- endif -%}
							</div>

							{%- comment -%} Text — bottom {%- endcomment -%}
							<div class="relative z-10 p-8 lg:p-10 flex flex-col gap-3 bg-main">
								<h3 class="font-heading font-semibold text-white text-2xl lg:text-3xl leading-snug">
									{{ block.settings.title }}
								</h3>
								{%- if block.settings.description != blank -%}
									<div class="text-base text-white/85 leading-relaxed max-w-lg">
										{{ block.settings.description }}
									</div>
								{%- endif -%}
								{%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
									<a
										href="{{ block.settings.link_url }}"
										class="inline-flex items-center gap-1.5 text-sm font-semibold text-highlight hover:underline"
									>
										{{ block.settings.link_label }}
										<svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
										</svg>
									</a>
								{%- endif -%}
							</div>
						</div>
					{%- endfor -%}
				</div>

				{%- comment -%} ── Right: 2×2 card grid ── {%- endcomment -%}
				<div class="grid grid-cols-2 gap-4 auto-rows-fr" data-card-grid role="list">
					{%- for block in section.blocks -%}
						<button
							class="he-card rounded-2xl cursor-pointer aspect-square {% if forloop.first %}hidden{% endif %}"
							data-effect-card="{{ forloop.index0 }}"
							data-target="{{ section.id }}"
							{{ block.shopify_attributes }}
						>
							<span class="relative flex flex-col rounded-[14px] w-full h-full bg-bg-soft overflow-hidden transition-colors duration-300 hover:bg-secondary">
								{%- if block.settings.image != blank -%}
									{{
										block.settings.image
										| image_url: width: 600
										| image_tag:
											loading: 'lazy',
											class: 'absolute inset-0 w-full h-full object-cover',
											widths: '300, 400, 600'
									}}
								{%- endif -%}
								<span class="relative z-10 mt-auto p-3 lg:p-4 bg-linear-to-t from-black/70 via-black/40 to-transparent">
									<span class="font-heading font-semibold text-white text-sm lg:text-base leading-snug block">
										{{ block.settings.title }}
									</span>
								</span>
							</span>
						</button>
					{%- endfor -%}
				</div>

			</div>
		{%- endif -%}

	</div>
</section>

<script>
(function () {
	{%- comment -%} Scroll-in animation {%- endcomment -%}
	var animateEls = document.querySelectorAll('#health-effects-{{ section.id }} [data-animate]');

	if ('IntersectionObserver' in window) {
		var observer = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (!entry.isIntersecting) return;
				entry.target.classList.remove('opacity-0', 'translate-y-8');
				observer.unobserve(entry.target);
			});
		}, { threshold: 0.15 });

		animateEls.forEach(function (el) { observer.observe(el); });
	} else {
		animateEls.forEach(function (el) { el.classList.remove('opacity-0', 'translate-y-8'); });
	}

	{%- comment -%} Focus panel switching {%- endcomment -%}
	var root = document.querySelector('[data-health-effects="{{ section.id }}"]');
	if (!root) return;

	var panels = root.querySelectorAll('[data-focus-panel]');
	var cards  = root.querySelectorAll('[data-effect-card]');
	var grid   = root.querySelector('[data-card-grid]');
	var total        = cards.length;
	var lockedIndex  = 0;
	var previewIndex = null;
	var ROTATE_MS    = 5000;
	var timer        = null;
	var paused       = false;

	function getNextIndex() {
		return (lockedIndex + 1) % total;
	}

	function showPanel(index) {
		panels.forEach(function (p, i) {
			if (i === index) {
				p.classList.remove('opacity-0', 'pointer-events-none');
				p.classList.add('opacity-100');
			} else {
				p.classList.add('opacity-0', 'pointer-events-none');
				p.classList.remove('opacity-100');
			}
		});
	}

	function syncCards() {
		var nextIdx = getNextIndex();

		cards.forEach(function (c, i) {
			if (i === lockedIndex) {
				c.classList.add('hidden');
				c.classList.remove('is-next');
			} else {
				var wasHidden = c.classList.contains('hidden');
				c.classList.remove('hidden');

				if (wasHidden) {
					c.classList.add('card-entering');
					c.addEventListener('animationend', function handler() {
						c.classList.remove('card-entering');
						c.removeEventListener('animationend', handler);
					});
				}

				if (i === nextIdx) {
					c.classList.remove('is-next');
					void c.offsetHeight;
					c.classList.add('is-next');
					if (paused) c.classList.add('sweep-paused');
				} else {
					c.classList.remove('is-next');
				}
			}
		});
	}

	function lock(index) {
		if (index === lockedIndex) return;
		lockedIndex = index;
		previewIndex = null;
		showPanel(index);
		syncCards();
		resetTimer();
	}

	function preview(index) {
		if (index === lockedIndex) return;
		previewIndex = index;
		showPanel(index);
	}

	function endPreview() {
		if (previewIndex === null) return;
		previewIndex = null;
		showPanel(lockedIndex);
	}

	function rotateNext() {
		lock(getNextIndex());
	}

	function resetTimer() {
		clearTimeout(timer);
		if (!paused) {
			timer = setTimeout(rotateNext, ROTATE_MS);
		}
	}

	cards.forEach(function (card) {
		var idx = parseInt(card.getAttribute('data-effect-card'), 10);
		card.addEventListener('click', function () { lock(idx); });
		card.addEventListener('mouseenter', function () { preview(idx); });
		card.addEventListener('mouseleave', function () { endPreview(); });
	});

	grid.addEventListener('mouseenter', function () {
		paused = true;
		clearTimeout(timer);
		cards.forEach(function (c) {
			if (c.classList.contains('is-next')) c.classList.add('sweep-paused');
		});
	});
	grid.addEventListener('mouseleave', function () {
		paused = false;
		cards.forEach(function (c) { c.classList.remove('sweep-paused'); });
		endPreview();
		resetTimer();
	});

	syncCards();
	resetTimer();
})();
</script>

{% schema %}
{
	"name": "Health Effects",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Why it matters"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Health effects of poor airflow"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Mouth breathing and restricted nasal airflow have been linked to a surprising range of health issues — many of which are reversible."
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FAFAFA"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 0,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"blocks": [
		{
			"type": "effect",
			"name": "Health effect",
			"settings": [
				{
					"type": "text",
					"id": "icon",
					"label": "Icon (emoji)",
					"default": "🫀"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "High blood pressure"
				},
				{
					"type": "text",
					"id": "subtitle",
					"label": "Subtitle (card)",
					"info": "Short text shown on the card beneath the title"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "Focus image",
					"info": "Shown in the focus panel when this card is active"
				},
				{
					"type": "richtext",
					"id": "description",
					"label": "Description",
					"default": "<p>Mouth breathing activates the body's stress response, raising cortisol and constricting blood vessels. Over time this can contribute to chronically elevated blood pressure — a major risk factor for heart disease.</p>"
				},
				{
					"type": "text",
					"id": "link_label",
					"label": "Link label"
				},
				{
					"type": "url",
					"id": "link_url",
					"label": "Link URL"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Health Effects",
			"blocks": [
				{
					"type": "effect",
					"settings": {
						"icon": "🫀",
						"title": "High blood pressure",
						"description": "<p>Mouth breathing activates the body's stress response, raising cortisol and constricting blood vessels. Over time this can contribute to chronically elevated blood pressure — a major risk factor for heart disease.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "😴",
						"title": "Snoring",
						"description": "<p>When the nose is bypassed, the soft tissue at the back of the throat is more likely to vibrate during sleep — producing the sound of snoring. Nasal breathing stabilises this tissue and reduces vibration significantly.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "💧",
						"title": "Dry mouth",
						"description": "<p>Breathing through the mouth dries out saliva, which is your body's first line of defence against bacteria. Chronic dry mouth leads to bad breath, tooth decay, and gum disease.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "🌙",
						"title": "Poor sleep quality",
						"description": "<p>Mouth breathing reduces oxygen uptake and disrupts sleep architecture — resulting in more time in lighter sleep stages. Switching to nasal breathing has been shown to improve deep sleep and morning energy levels.</p>"
					}
				},
				{
					"type": "effect",
					"settings": {
						"icon": "🧒",
						"title": "Facial development",
						"description": "<p>In children, long-term mouth breathing can alter the development of facial bones — leading to a narrower palate, elongated face, and crowded teeth. Early nasal breathing habits help guide healthy craniofacial growth.</p>"
					}
				}
			]
		}
	]
}
{% endschema %}
