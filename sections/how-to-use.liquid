{%- assign step_blocks = section.blocks | where: "type", "step" -%}

<style>
	/* ─── Mobile carousel track ─── */
	#shopify-section-{{ section.id }} .htu-track::-webkit-scrollbar { display: none; }
	#shopify-section-{{ section.id }} .htu-track { -ms-overflow-style: none; scrollbar-width: none; }

	#shopify-section-{{ section.id }} .htu-track {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: 80%;
		gap: 16px;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		padding-left: 1.5rem;
		padding-right: 1.5rem;
	}

	/* ─── Desktop: normal 3-col grid, no scroll ─── */
	@media (min-width: 768px) {
		#shopify-section-{{ section.id }} .htu-track {
			display: grid;
			grid-auto-flow: unset;
			grid-template-columns: repeat(3, 1fr);
			grid-auto-columns: unset;
			gap: 3rem;
			overflow-x: visible;
			padding-left: 0;
			padding-right: 0;
		}
	}
</style>

<section class="relative overflow-hidden py-16 md:py-24 bg-main text-secondary" data-how-to-use>

	{%- comment -%} Atmospheric radial washes (matching How it works / Our Story heroes) {%- endcomment -%}
	<div
		class="absolute inset-0 pointer-events-none"
		style="background:
			radial-gradient(ellipse 60% 50% at 80% 20%, rgba(155,183,212,0.22), transparent 65%),
			radial-gradient(ellipse 60% 50% at 15% 90%, rgba(80,162,167,0.22), transparent 70%);"
	></div>

	<div class="container-contained relative z-10">

		{%- comment -%} Section header {%- endcomment -%}
		<div class="text-center mb-10 md:mb-14">
			{%- if section.settings.eyebrow != blank -%}
				<p class="text-xs font-bold uppercase tracking-widest text-tertiary-light mb-3">{{ section.settings.eyebrow }}</p>
			{%- endif -%}
			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight text-3xl md:text-4xl lg:text-5xl text-secondary tracking-tight">{{ section.settings.heading }}</h2>
			{%- endif -%}
		</div>

	</div>

	{%- if step_blocks.size > 0 -%}
		<div class="container-contained relative z-10">
			<div class="htu-track" data-htu-track>
				{%- for block in step_blocks -%}
					<div class="flex flex-col min-w-0" {{ block.shopify_attributes }}>

						{%- comment -%} Image {%- endcomment -%}
						<div class="aspect-square rounded-2xl overflow-hidden mb-5" style="background: rgba(155, 183, 212, 0.08); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.35);">
							{%- if block.settings.step_image != blank -%}
								{{
									block.settings.step_image
									| image_url: width: 800
									| image_tag:
										loading: 'lazy',
										class: 'w-full h-full object-cover',
										widths: '400, 600, 800',
										draggable: 'false'
								}}
							{%- endif -%}
						</div>

						{%- comment -%} Step number + title inline — same size, title semibold {%- endcomment -%}
						<div class="flex items-baseline gap-3 mb-1">
							<span class="font-heading font-bold text-2xl md:text-3xl text-tertiary-light leading-none tracking-wider">{{ block.settings.step_number | default: forloop.index | prepend: '00' | slice: -2, 2 }}</span>
							<h3 class="font-heading font-semibold text-2xl md:text-3xl text-secondary leading-tight">{{ block.settings.step_heading }}</h3>
						</div>
						{%- if block.settings.step_description != blank -%}
							<p class="text-secondary/70 text-sm leading-relaxed mt-2">{{ block.settings.step_description }}</p>
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		</div>
	{%- endif -%}

	{%- if section.settings.tutorial_url != blank -%}
		<div class="container-contained relative z-10">
			<div class="text-center mt-10">
				{%- render 'cta-button',
					label: 'Watch tutorial',
					url: section.settings.tutorial_url,
					variant: 'outline',
					surface: 'dark',
					size: 'md'
				-%}
			</div>
		</div>
	{%- endif -%}

</section>

<script>
/* Free-scroll carousel — no snap, user stops where they let go. */
</script>

{% schema %}
{
	"name": "How to use",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "How it works"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "3 steps to better breathing."
		},
		{
			"type": "text",
			"id": "tutorial_label",
			"label": "Tutorial link text",
			"default": "For a more detailed guide, watch our short tutorial video."
		},
		{
			"type": "url",
			"id": "tutorial_url",
			"label": "Tutorial link URL"
		}
	],
	"blocks": [
		{
			"type": "step",
			"name": "Step",
			"settings": [
				{
					"type": "text",
					"id": "step_number",
					"label": "Step number",
					"default": "01",
					"info": "E.g. 01, 02, 03"
				},
				{
					"type": "image_picker",
					"id": "step_image",
					"label": "Step image"
				},
				{
					"type": "text",
					"id": "step_heading",
					"label": "Heading",
					"default": "Peel"
				},
				{
					"type": "textarea",
					"id": "step_description",
					"label": "Description",
					"default": "Peel the adhesive tab from its backing. Avoid touching the glue too much."
				}
			]
		}
	],
	"presets": [
		{
			"name": "How to use",
			"blocks": [
				{
					"type": "step",
					"settings": {
						"step_number": "01",
						"step_heading": "Peel",
						"step_description": "Peel the adhesive tab from its backing. Avoid touching the glue too much."
					}
				},
				{
					"type": "step",
					"settings": {
						"step_number": "02",
						"step_heading": "Place",
						"step_description": "Place a tab on each side of your nose, just above the nostril. (Think, where I would pinch my nose)"
					}
				},
				{
					"type": "step",
					"settings": {
						"step_number": "03",
						"step_heading": "Breathe",
						"step_description": "Attach the magnetic strip and experience effortless breathing."
					}
				}
			]
		}
	],
	"disabled_on": {
		"groups": ["header", "footer"]
	}
}
{% endschema %}
