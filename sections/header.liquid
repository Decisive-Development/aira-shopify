<style>
	.nav-transparent {
		transition: opacity 0.3s ease;
	}

	.nav-solid {
		transform: translateY(-100%);
		opacity: 0;
		pointer-events: none;
		transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
	}

	[data-header].scrolled .nav-transparent {
		opacity: 0;
		pointer-events: none;
	}

	[data-header].scrolled .nav-solid {
		transform: translateY(0);
		opacity: 1;
		pointer-events: auto;
	}

	[data-header].no-transition .nav-transparent,
	[data-header].no-transition .nav-solid {
		transition: none !important;
	}

	/* Mobile menu animation */
	[data-mobile-menu] {
		transition: opacity 0.25s ease, transform 0.25s ease;
	}
	[data-mobile-menu].menu-closed {
		opacity: 0;
		transform: translateY(-8px);
		pointer-events: none;
	}
	[data-mobile-menu].menu-open {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}
</style>

<header data-header class="fixed top-0 inset-x-0 z-50">

	{%- comment -%} ── Transparent nav — visible at page top ── {%- endcomment -%}
	<div class="nav-transparent flex justify-center px-4 md:px-8 pt-2">
		<div class="w-full max-w-7xl flex items-center gap-10 px-6 py-2">

			{%- comment -%} White logo — icon on mobile, full on desktop {%- endcomment -%}
			<a href="{{ routes.root_url }}" class="flex items-center shrink-0">
				<img
					src="{{ 'aira-logo-only-white.svg' | asset_url }}"
					alt="{{ shop.name }}"
					class="h-7 w-auto md:hidden"
					width="28"
					height="28"
					loading="eager"
				>
				<img
					src="{{ 'aira-logo-text-white.svg' | asset_url }}"
					alt="{{ shop.name }}"
					class="h-7 w-auto -translate-y-0.5 hidden md:block"
					width="120"
					height="28"
					loading="eager"
				>
			</a>

			{%- comment -%} Nav links — white text {%- endcomment -%}
			{%- if section.settings.menu != blank -%}
				<nav class="hidden md:flex items-center justify-center gap-8 flex-1">
					{%- for link in section.settings.menu.links -%}
						{%- if link.links != empty -%}
							<div class="relative group">
								<a
									href="{{ link.url }}"
									class="flex items-center gap-1 text-base font-bold tracking-wide text-white transition-opacity hover:opacity-60 {% if link.active %}opacity-100{% else %}opacity-75{% endif %}"
								>
									{{ link.title }}
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mt-0.5 transition-transform group-hover:rotate-180">
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
									</svg>
								</a>
								<div class="absolute top-full left-0 right-0 h-3"></div>
								<div
									class="absolute top-full left-1/2 -translate-x-1/2 translate-y-3 hidden group-hover:flex flex-col gap-1 py-3 px-2 rounded-2xl min-w-44 bg-secondary"
									style="box-shadow: 0 12px 32px rgba(10,26,52,0.18), 0 4px 12px rgba(255,255,255,0.4);"
								>
									{%- for child in link.links -%}
										<a
											href="{{ child.url }}"
											class="px-4 py-2 rounded-xl text-sm font-semibold tracking-wide whitespace-nowrap transition-colors hover:bg-main hover:text-secondary {% if child.active %}text-main{% else %}text-main/75{% endif %}"
										>
											{{ child.title }}
										</a>
									{%- endfor -%}
								</div>
							</div>
						{%- else -%}
							<a
								href="{{ link.url }}"
								class="text-base font-bold tracking-wide text-white transition-opacity hover:opacity-60 {% if link.active %}opacity-100{% else %}opacity-75{% endif %}"
							>
								{{ link.title }}
							</a>
						{%- endif -%}
					{%- endfor -%}
				</nav>
			{%- endif -%}

			{%- comment -%} Right — CTA + white icons {%- endcomment -%}
			<div class="flex items-center gap-4 ml-auto">

				{%- if section.settings.cta_label != blank -%}
					{%- render 'cta-button',
						label: section.settings.cta_label,
						url: section.settings.cta_url,
						variant: 'accent',
						extra_classes: 'hidden md:inline-block'
					-%}
				{%- endif -%}

				<a
					href="{{ routes.cart_url }}"
					class="relative flex items-center text-white transition-opacity hover:opacity-60"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
					</svg>
					{%- if cart.item_count > 0 -%}
						<span class="absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full bg-highlight text-white flex items-center justify-center text-[10px] font-bold leading-none">
							{{ cart.item_count }}
						</span>
					{%- endif -%}
				</a>

				{%- if shop.customer_accounts_enabled -%}
					<a
						href="{{ routes.account_url }}"
						class="hidden md:flex items-center text-white transition-opacity hover:opacity-60"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
						</svg>
					</a>
				{%- endif -%}

				<button
					class="md:hidden flex items-center text-white transition-opacity hover:opacity-60"
					aria-label="Open menu"
					data-mobile-toggle
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
					</svg>
				</button>

			</div>
		</div>
	</div>

	{%- comment -%} ── Solid nav — slides in on scroll ── {%- endcomment -%}
	<div class="nav-solid absolute top-0 inset-x-0 flex justify-center px-4 md:px-8 pt-2">
		<div
			class="w-full max-w-7xl bg-secondary rounded-2xl flex items-center gap-10 px-6 py-2"
			style="box-shadow: 0 12px 40px rgba(10,26,52,0.25), 0 8px 16px rgba(255,255,255,0.4);"
		>

			{%- comment -%} Blue logo — icon on mobile, full on desktop {%- endcomment -%}
			<a href="{{ routes.root_url }}" class="flex items-center shrink-0">
				<img
					src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
					alt="{{ shop.name }}"
					class="h-7 w-auto md:hidden"
					width="28"
					height="28"
					loading="eager"
				>
				<img
					src="{{ 'aira-logo-text-blue.svg' | asset_url }}"
					alt="{{ shop.name }}"
					class="h-7 w-auto -translate-y-0.5 hidden md:block"
					width="120"
					height="28"
					loading="eager"
				>
			</a>

			{%- comment -%} Nav links {%- endcomment -%}
			{%- if section.settings.menu != blank -%}
				<nav class="hidden md:flex items-center justify-center gap-8 flex-1">
					{%- for link in section.settings.menu.links -%}
						{%- if link.links != empty -%}
							<div class="relative group">
								<a
									href="{{ link.url }}"
									class="flex items-center gap-1 text-base font-bold tracking-wide text-main transition-opacity hover:opacity-60 {% if link.active %}opacity-100{% else %}opacity-75{% endif %}"
								>
									{{ link.title }}
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" class="mt-0.5 transition-transform group-hover:rotate-180">
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
									</svg>
								</a>
								<div class="absolute top-full left-0 right-0 h-3"></div>
								<div
									class="absolute top-full left-1/2 -translate-x-1/2 translate-y-3 hidden group-hover:flex flex-col gap-1 py-3 px-2 rounded-2xl min-w-44 bg-secondary"
									style="box-shadow: 0 12px 32px rgba(10,26,52,0.18), 0 4px 12px rgba(255,255,255,0.4);"
								>
									{%- for child in link.links -%}
										<a
											href="{{ child.url }}"
											class="px-4 py-2 rounded-xl text-sm font-semibold tracking-wide whitespace-nowrap transition-colors hover:bg-main hover:text-secondary {% if child.active %}text-main{% else %}text-main/75{% endif %}"
										>
											{{ child.title }}
										</a>
									{%- endfor -%}
								</div>
							</div>
						{%- else -%}
							<a
								href="{{ link.url }}"
								class="text-base font-bold tracking-wide text-main transition-opacity hover:opacity-60 {% if link.active %}opacity-100{% else %}opacity-75{% endif %}"
							>
								{{ link.title }}
							</a>
						{%- endif -%}
					{%- endfor -%}
				</nav>
			{%- endif -%}

			{%- comment -%} Right — CTA + icons {%- endcomment -%}
			<div class="flex items-center gap-4 ml-auto">

				{%- if section.settings.cta_label != blank -%}
					{%- render 'cta-button',
						label: section.settings.cta_label,
						url: section.settings.cta_url,
						variant: 'accent',
						extra_classes: 'hidden md:inline-block'
					-%}
				{%- endif -%}

				<a
					href="{{ routes.cart_url }}"
					class="relative flex items-center text-main transition-opacity hover:opacity-60"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
					</svg>
					{%- if cart.item_count > 0 -%}
						<span class="absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full bg-highlight text-white flex items-center justify-center text-[10px] font-bold leading-none">
							{{ cart.item_count }}
						</span>
					{%- endif -%}
				</a>

				{%- if shop.customer_accounts_enabled -%}
					<a
						href="{{ routes.account_url }}"
						class="hidden md:flex items-center text-main transition-opacity hover:opacity-60"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
						</svg>
					</a>
				{%- endif -%}

				<button
					class="md:hidden flex items-center text-main transition-opacity hover:opacity-60"
					aria-label="Open menu"
					data-mobile-toggle
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
					</svg>
				</button>

			</div>
		</div>
	</div>

	{%- comment -%} Mobile menu dropdown {%- endcomment -%}
	{%- if section.settings.menu != blank -%}
		<div
			data-mobile-menu
			class="menu-closed absolute top-full left-4 right-4 mt-2 max-w-7xl rounded-2xl px-6 py-5 flex flex-col gap-1 shadow-lg bg-secondary md:hidden"
		>
			{%- for link in section.settings.menu.links -%}
				<a
					href="{{ link.url }}"
					class="block text-lg font-bold py-2.5 text-main transition-opacity hover:opacity-60"
				>
					{{ link.title }}
				</a>
				{%- if link.links != empty -%}
					{%- for child in link.links -%}
						<a
							href="{{ child.url }}"
							class="block text-base font-medium py-2 pl-4 text-main opacity-65 transition-opacity hover:opacity-60"
						>
							{{ child.title }}
						</a>
					{%- endfor -%}
				{%- endif -%}
			{%- endfor -%}
			{%- if section.settings.cta_label != blank -%}
				{%- render 'cta-button',
					label: section.settings.cta_label,
					url: section.settings.cta_url,
					variant: 'accent',
					size: 'sm',
					extra_classes: 'mt-3 w-full text-center'
				-%}
			{%- endif -%}
		</div>
	{%- endif -%}
</header>

<script>
(function() {
	var header = document.querySelector('[data-header]');
	if (!header) return;

	var menu = header.querySelector('[data-mobile-menu]');
	var scrolled = false;

	function closeMenu() {
		if (menu) {
			menu.classList.remove('menu-open');
			menu.classList.add('menu-closed');
		}
	}

	function toggleMenu() {
		if (!menu) return;
		var isOpen = menu.classList.contains('menu-open');
		if (isOpen) {
			closeMenu();
		} else {
			menu.classList.remove('menu-closed');
			menu.classList.add('menu-open');
		}
	}

	header.querySelectorAll('[data-mobile-toggle]').forEach(function(btn) {
		btn.addEventListener('click', toggleMenu);
	});

	function update() {
		var isScrolled = window.scrollY > 50;
		if (isScrolled === scrolled) return;
		scrolled = isScrolled;
		header.classList.toggle('scrolled', scrolled);
		closeMenu();
	}

	if (window.scrollY > 50) {
		header.classList.add('scrolled', 'no-transition');
		scrolled = true;
		requestAnimationFrame(function() {
			requestAnimationFrame(function() {
				header.classList.remove('no-transition');
			});
		});
	}

	window.addEventListener('scroll', update, { passive: true });
})();
</script>

{% schema %}
{
	"name": "Header",
	"settings": [
		{
			"type": "image_picker",
			"id": "logo",
			"label": "Logo",
			"info": "Displays shop name as text if left blank."
		},
		{
			"type": "link_list",
			"id": "menu",
			"label": "Navigation menu",
			"default": "main-menu"
		},
		{
			"type": "header",
			"content": "CTA button"
		},
		{
			"type": "text",
			"id": "cta_label",
			"label": "Button label",
			"default": "Shop now"
		},
		{
			"type": "url",
			"id": "cta_url",
			"label": "Button URL"
		},
		{
			"type": "paragraph",
			"content": "Colours are controlled in Theme settings → Brand colours."
		}
	]
}
{% endschema %}
