{%- comment -%}
	How it works — Hero
	Dark navy hero. Left: pill-free headline + lead. Right: portrait tutorial video
	(filmed on a phone) that opens in a popup/lightbox on click. Chapter strip seeks
	into the popup. Trust strip spans full width beneath.
{%- endcomment -%}

{%- liquid
	assign chapter_blocks = section.blocks | where: 'type', 'chapter'
	assign trust_blocks   = section.blocks | where: 'type', 'trust'
-%}

{%- liquid
	assign hl_text = section.settings.headline
	assign hl_accent = section.settings.headline_accent
	if hl_text != blank and hl_accent != blank and hl_text contains hl_accent
		assign hl_accent_wrapped = '<span class="text-tertiary-light/85">' | append: hl_accent | append: '</span>'
		assign hl_html = hl_text | replace: hl_accent, hl_accent_wrapped
	else
		assign hl_html = hl_text
	endif

	assign has_video = false
	if section.settings.video_url != blank
		assign has_video = true
	endif
-%}

<section class="relative overflow-hidden bg-main text-secondary pt-32 md:pt-40 pb-16 md:pb-25">

	{%- comment -%} Atmospheric radial washes (matching Our Story hero) {%- endcomment -%}
	<div
		class="absolute inset-0 pointer-events-none"
		style="background:
			radial-gradient(ellipse 60% 50% at 80% 20%, rgba(155,183,212,0.22), transparent 65%),
			radial-gradient(ellipse 60% 50% at 15% 90%, rgba(80,162,167,0.22), transparent 70%);"
	></div>

	<div class="container-contained relative z-10">

		<div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

			{%- comment -%} Left — headline + lead {%- endcomment -%}
			<div class="text-center lg:text-left max-w-xl mx-auto lg:mx-0 reveal">
				{%- if hl_text != blank -%}
					<h1 class="font-heading heading-weight text-secondary text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight">
						{{ hl_html }}
					</h1>
				{%- endif -%}

				{%- if section.settings.lead != blank -%}
					<p class="text-secondary/70 text-base md:text-lg leading-relaxed mt-5">
						{{ section.settings.lead }}
					</p>
				{%- endif -%}

				{%- comment -%} Chapter strip — 3 buttons under the hero copy {%- endcomment -%}
				{%- if chapter_blocks.size > 0 -%}
					<div class="mt-8 grid grid-cols-3 gap-2 md:gap-3">
						{%- for block in chapter_blocks -%}
							<button
								type="button"
								class="flex flex-col gap-1 text-left rounded-xl px-3 py-3 md:px-4 md:py-3.5 transition min-w-0"
								style="background: rgba(241, 235, 225, 0.06);"
								data-chapter-btn
								data-time="{{ block.settings.time_seconds }}"
								{{ block.shopify_attributes }}
							>
								<span class="font-heading font-bold text-secondary/70 text-[11px] md:text-xs leading-none tracking-wider">{{ block.settings.timestamp }}</span>
								<span class="text-secondary text-xs md:text-sm font-semibold leading-snug">{{ block.settings.title }}</span>
								{%- if block.settings.subtitle != blank -%}
									<span class="text-secondary/55 text-[10px] md:text-xs leading-snug hidden md:block">{{ block.settings.subtitle }}</span>
								{%- endif -%}
							</button>
						{%- endfor -%}
					</div>
				{%- endif -%}
			</div>

			{%- comment -%} Right — portrait video + chapter strip {%- endcomment -%}
			<div class="reveal">
				<div class="max-w-[320px] mx-auto">
					<div class="video-frame video-frame--portrait" id="tutorialVideo" data-tutorial-video>
						{%- if section.settings.video_poster != blank -%}
							<img
								class="video-cover"
								src="{{ section.settings.video_poster | image_url: width: 800 }}"
								alt=""
								width="320"
								height="569"
								loading="lazy"
							>
						{%- elsif has_video -%}
							<video class="video-cover" preload="metadata" muted playsinline>
								<source src="{{ section.settings.video_url }}#t=0.1" type="video/mp4">
							</video>
						{%- else -%}
							<div class="video-placeholder">Tutorial video. Filmed in portrait.</div>
						{%- endif -%}

						{%- if section.settings.duration_label != blank -%}
							<span class="pill video-cinema-mark">
								<svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
									<circle cx="5" cy="5" r="4" fill="currentColor" style="color: var(--color-highlight, #FF4000);"/>
								</svg>
								{{ section.settings.duration_label }}
							</span>
						{%- endif -%}

						{%- if has_video -%}
							<button class="video-play-big" data-tutorial-play aria-label="Play tutorial video">
								<span class="ring">
									<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
							</button>
							<div class="video-overlay"></div>
						{%- endif -%}
					</div>
				</div>
			</div>

		</div>

		{%- comment -%} Trust strip {%- endcomment -%}
		{%- if trust_blocks.size > 0 -%}
			<div class="mt-12 md:mt-16 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-secondary/60 text-xs uppercase tracking-widest">
				{%- for block in trust_blocks -%}
					<span class="flex items-center gap-2" {{ block.shopify_attributes }}>
						{%- case block.settings.icon -%}
							{%- when 'star' -%}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
							{%- when 'moon' -%}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
							{%- when 'clock' -%}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
							{%- when 'check' -%}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
							{%- else -%}
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
						{%- endcase -%}
						{{ block.settings.label }}
					</span>
					{%- unless forloop.last -%}
						<span class="hidden md:block w-1 h-1 rounded-full bg-secondary/30"></span>
					{%- endunless -%}
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>

	{%- comment -%}
		Popup / lightbox. Kept as a direct child of the section (outside any .reveal
		element) because .reveal uses a transform, which would make position:fixed
		resolve against it instead of the viewport.
	{%- endcomment -%}
	{%- if has_video -%}
		<div class="video-modal" data-video-modal hidden>
			<div class="video-modal__backdrop" data-video-close></div>
			<div class="video-modal__player" role="dialog" aria-modal="true" aria-label="Tutorial video">
				<button type="button" class="video-modal__close" data-video-close aria-label="Close video">&times;</button>
				<video
					controls
					playsinline
					preload="none"
					data-modal-video
					{% if section.settings.video_poster != blank %}poster="{{ section.settings.video_poster | image_url: width: 800 }}"{% endif %}
				>
					<source src="{{ section.settings.video_url }}" type="video/mp4">
				</video>
			</div>
		</div>
	{%- endif -%}

</section>

<script>
(function () {
	var section = document.querySelector('#shopify-section-{{ section.id }}');
	if (!section) return;

	var modal    = section.querySelector('[data-video-modal]');
	var video    = modal ? modal.querySelector('[data-modal-video]') : null;
	var playBtn  = section.querySelector('[data-tutorial-play]');
	var chapters = section.querySelectorAll('[data-chapter-btn]');
	var STORAGE_KEY = 'aira.howItWorks.video.t';
	var lastFocus = null;

	if (!modal || !video) return;

	function seek(to) {
		if (typeof to !== 'number' || !isFinite(to) || to <= 0) return;
		var apply = function () {
			try { video.currentTime = video.duration ? Math.min(to, video.duration - 0.5) : to; } catch (e) {}
		};
		if (video.readyState >= 1) { apply(); }
		else { video.addEventListener('loadedmetadata', apply, { once: true }); }
	}

	function open(seekTo) {
		lastFocus = document.activeElement;
		modal.hidden = false;
		document.body.classList.add('video-modal-open');
		seek(seekTo);
		var p = video.play();
		if (p && p.catch) { p.catch(function () { /* autoplay blocked, controls are shown */ }); }
		var closeBtn = modal.querySelector('.video-modal__close');
		if (closeBtn) { closeBtn.focus(); }
	}

	function close() {
		document.body.classList.remove('video-modal-open');
		try {
			localStorage.setItem(STORAGE_KEY, String(video.currentTime || 0));
			video.pause();
		} catch (e) {}
		modal.hidden = true;
		if (lastFocus && lastFocus.focus) { lastFocus.focus(); }
	}

	/* Play button / poster opens the popup, resuming where you left off */
	if (playBtn) {
		playBtn.addEventListener('click', function () {
			var saved = parseFloat(localStorage.getItem(STORAGE_KEY) || '0');
			open(saved > 1 && isFinite(saved) ? saved : 0);
		});
	}

	/* Chapters open the popup and jump to their timestamp */
	chapters.forEach(function (b) {
		b.addEventListener('click', function () {
			chapters.forEach(function (x) { x.style.background = 'rgba(241, 235, 225, 0.06)'; });
			b.style.background = 'rgba(241, 235, 225, 0.18)';
			var t = parseFloat(b.getAttribute('data-time') || '0');
			open(isFinite(t) ? t : 0);
		});
	});

	/* Close: backdrop, close button, Escape */
	modal.querySelectorAll('[data-video-close]').forEach(function (el) {
		el.addEventListener('click', close);
	});
	document.addEventListener('keydown', function (e) {
		if ((e.key === 'Escape' || e.key === 'Esc') && !modal.hidden) { close(); }
	});
})();
</script>

{% schema %}
{
	"name": "How it works — Hero",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{
			"type": "text",
			"id": "headline",
			"label": "Headline",
			"default": "Three steps to life-changing breathing."
		},
		{
			"type": "text",
			"id": "headline_accent",
			"label": "Headline accent phrase",
			"info": "Phrase from the headline to highlight in soft light blue (must match exactly).",
			"default": "life-changing breathing"
		},
		{
			"type": "textarea",
			"id": "lead",
			"label": "Lead paragraph",
			"default": "Watch the 90-second tutorial, then walk through each step at your own pace. The whole routine takes under a minute once you've got it."
		},
		{
			"type": "header",
			"content": "Video"
		},
		{
			"type": "url",
			"id": "video_url",
			"label": "Video MP4 URL",
			"info": "Filmed in portrait (phone). Opens in a popup on click. Leave blank to show the placeholder. Use a Shopify-hosted .mp4 file URL."
		},
		{
			"type": "image_picker",
			"id": "video_poster",
			"label": "Video poster image",
			"info": "Portrait (9:16) thumbnail shown before the popup opens."
		},
		{
			"type": "text",
			"id": "duration_label",
			"label": "Duration label",
			"default": "1:32"
		}
	],
	"blocks": [
		{
			"type": "chapter",
			"name": "Chapter",
			"limit": 3,
			"settings": [
				{ "type": "text",   "id": "timestamp",     "label": "Timestamp",          "default": "00:00" },
				{ "type": "number", "id": "time_seconds",  "label": "Seek time (seconds)","default": 0 },
				{ "type": "text",   "id": "title",         "label": "Title",              "default": "Find your size" },
				{ "type": "text",   "id": "subtitle",      "label": "Subtitle (md+ only)","default": "L1–L4" }
			]
		},
		{
			"type": "trust",
			"name": "Trust item",
			"limit": 6,
			"settings": [
				{
					"type": "select",
					"id": "icon",
					"label": "Icon",
					"options": [
						{ "value": "star",  "label": "Star (hypoallergenic)" },
						{ "value": "moon",  "label": "Moon (drug-free)" },
						{ "value": "clock", "label": "Clock (60 seconds)" },
						{ "value": "check", "label": "Check (reusable)" }
					],
					"default": "star"
				},
				{ "type": "text", "id": "label", "label": "Label", "default": "Hypoallergenic" }
			]
		}
	],
	"presets": [
		{
			"name": "How it works — Hero",
			"blocks": [
				{ "type": "chapter", "settings": { "timestamp": "00:00", "time_seconds": 0,  "title": "Find your size",     "subtitle": "L1–L4" } },
				{ "type": "chapter", "settings": { "timestamp": "00:32", "time_seconds": 32, "title": "Prep your skin",     "subtitle": "Clean, dry, gentle" } },
				{ "type": "chapter", "settings": { "timestamp": "00:58", "time_seconds": 58, "title": "Apply tabs & band",  "subtitle": "Shark fins up" } },
				{ "type": "trust", "settings": { "icon": "star",  "label": "Hypoallergenic" } },
				{ "type": "trust", "settings": { "icon": "moon",  "label": "Drug-free" } },
				{ "type": "trust", "settings": { "icon": "clock", "label": "Sets up in 60 seconds" } },
				{ "type": "trust", "settings": { "icon": "check", "label": "Reusable band" } }
			]
		}
	]
}
{% endschema %}
