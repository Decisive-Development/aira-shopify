{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign pt = ''
			assign pb = ''
		when 'sm'
			assign pt = 'pt-4 md:pt-8'
			assign pb = 'pb-4 md:pb-8'
		when 'md'
			assign pt = 'pt-6 md:pt-12'
			assign pb = 'pb-6 md:pb-12'
		when 'lg'
			assign pt = 'pt-8 md:pt-16'
			assign pb = 'pb-8 md:pb-16'
	endcase

-%}

{%- assign hero_heading = section.settings.hero_heading | default: collection.title -%}
{%- render 'page-hero',
	image: section.settings.hero_image,
	eyebrow: section.settings.eyebrow,
	heading: hero_heading,
	description: collection.description
-%}

<section style="background-color: {{ section.settings.background_color }};">
	<div class="container-contained {{ pt }} {{ pb }}">

		{%- comment -%} Product grid {%- endcomment -%}
		{%- paginate collection.products by section.settings.products_per_page -%}
			{%- if collection.products.size > 0 -%}
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 max-w-3xl mx-auto">
					{%- for product in collection.products -%}
						{%- render 'product-card', product: product -%}
					{%- endfor -%}
				</div>
			{%- else -%}
				<div class="text-center py-20">
					<p class="text-copy text-lg">No products found in this collection.</p>
				</div>
			{%- endif -%}

			{%- comment -%} Pagination {%- endcomment -%}
			{%- if paginate.pages > 1 -%}
				<nav class="flex items-center justify-center gap-2 mt-14" aria-label="Collection pagination">
					{%- if paginate.previous -%}
						<a
							href="{{ paginate.previous.url }}"
							class="w-10 h-10 flex items-center justify-center rounded-xl text-copy transition-colors hover:bg-bg-soft"
							aria-label="Previous page"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
							</svg>
						</a>
					{%- endif -%}

					{%- for part in paginate.parts -%}
						{%- if part.is_link -%}
							<a
								href="{{ part.url }}"
								class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-semibold text-copy transition-colors hover:bg-bg-soft"
							>
								{{ part.title }}
							</a>
						{%- else -%}
							{%- if part.title == paginate.current_page -%}
								<span class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold bg-main text-secondary">
									{{ part.title }}
								</span>
							{%- else -%}
								<span class="w-10 h-10 flex items-center justify-center text-sm text-copy opacity-50">
									{{ part.title }}
								</span>
							{%- endif -%}
						{%- endif -%}
					{%- endfor -%}

					{%- if paginate.next -%}
						<a
							href="{{ paginate.next.url }}"
							class="w-10 h-10 flex items-center justify-center rounded-xl text-copy transition-colors hover:bg-bg-soft"
							aria-label="Next page"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
							</svg>
						</a>
					{%- endif -%}
				</nav>
			{%- endif -%}
		{%- endpaginate -%}

	</div>
</section>

<script>
(function () {
	/* Product card variant JS */
	document.querySelectorAll('[data-product-card]').forEach(function (card) {
		var variantInput = card.querySelector('[data-variant-id]');
		var priceEl      = card.querySelector('[data-price]');
		var addBtn       = card.querySelector('[data-add-to-cart]');
		var imgEl        = card.querySelector('a img');
		var dataEl       = card.querySelector('[data-product-variants]');
		if (!dataEl) return;
		var variants     = JSON.parse(dataEl.textContent);
		var selectedOptions = variants[0].options.slice();

		function findVariant() {
			return variants.find(function (v) {
				return v.options.every(function (opt, i) {
					return opt === selectedOptions[i];
				});
			}) || null;
		}

		function updateCard(variant) {
			if (!variant) return;
			variantInput.value  = variant.id;
			priceEl.textContent = variant.price_formatted;
			addBtn.disabled     = !variant.available;
			addBtn.textContent  = variant.available ? 'Add to Cart' : 'Sold Out';
			if (variant.image && imgEl) {
				imgEl.removeAttribute('srcset');
				imgEl.removeAttribute('sizes');
				imgEl.src = variant.image;
			}
		}

		card.querySelectorAll('[data-option-btn]').forEach(function (btn) {
			btn.addEventListener('click', function () {
				var idx      = parseInt(this.dataset.optionIndex);
				var value    = this.dataset.optionValue;
				selectedOptions[idx] = value;

				var group    = card.querySelector('[data-option-group="' + idx + '"]');
				var isColour = group.dataset.type === 'colour';

				group.querySelectorAll('[data-option-btn]').forEach(function (b) {
					var active = b.dataset.optionValue === value;
					if (isColour) {
						if (active) {
							b.classList.add('border-main', 'ring-2', 'ring-main', 'ring-offset-1');
							b.classList.remove('border-transparent');
						} else {
							b.classList.remove('border-main', 'ring-2', 'ring-main', 'ring-offset-1');
							b.classList.add('border-transparent');
						}
					} else {
						if (active) {
							b.classList.add('bg-main', 'text-secondary', 'border-main');
							b.classList.remove('bg-bg', 'border-bg-muted', 'text-copy');
						} else {
							b.classList.remove('bg-main', 'text-secondary', 'border-main');
							b.classList.add('bg-bg', 'border-bg-muted', 'text-copy');
						}
					}
				});

				updateCard(findVariant());
			updateSellingPlanPrices(findVariant());
			});
		});

		/* Selling plan (subscription) toggle */
		var spInput = card.querySelector('[data-selling-plan-input]');
		var spGroup = card.querySelector('[data-selling-plan-group]');
		if (spInput && spGroup) {
			var planBtns = spGroup.querySelectorAll('[data-plan-btn]');
			var selectedPlan = 'onetime';

			function setActivePlan(plan) {
				selectedPlan = plan;
				planBtns.forEach(function(b) {
					var type = b.dataset.planBtn;
					var radio = b.querySelector('[data-plan-radio]');
					if (type === plan) {
						b.classList.add('border-main', 'bg-bg-soft');
						b.classList.remove('border-bg-muted', 'bg-bg');
						radio.innerHTML = '<span class="w-2.5 h-2.5 rounded-full bg-main"></span>';
					} else {
						b.classList.remove('border-main', 'bg-bg-soft');
						b.classList.add('border-bg-muted', 'bg-bg');
						radio.innerHTML = '';
					}
				});

				var variant = findVariant();
				if (plan === 'subscribe' && variant) {
					var alloc = variant.selling_plan_allocations[0];
					if (alloc) {
						spInput.value = alloc.selling_plan_id;
						priceEl.textContent = alloc.per_delivery_price_formatted;
					}
				} else {
					spInput.value = '';
					if (variant) priceEl.textContent = variant.price_formatted;
				}
			}

			planBtns.forEach(function(b) {
				b.addEventListener('click', function() {
					setActivePlan(this.dataset.planBtn);
				});
			});
		}

		function updateSellingPlanPrices(variant) {
			if (!variant || !spGroup) return;
			var onetimePrice = card.querySelector('[data-onetime-price]');
			var subscribePrice = card.querySelector('[data-subscribe-price]');
			if (onetimePrice) onetimePrice.textContent = variant.price_formatted;
			if (subscribePrice && variant.selling_plan_allocations.length > 0) {
				var alloc = variant.selling_plan_allocations[0];
				subscribePrice.textContent = alloc.per_delivery_price_formatted + ' / ' + alloc.name.toLowerCase();
			}
			if (selectedPlan === 'subscribe' && variant.selling_plan_allocations.length > 0) {
				spInput.value = variant.selling_plan_allocations[0].selling_plan_id;
				priceEl.textContent = variant.selling_plan_allocations[0].per_delivery_price_formatted;
			}
		}
	});
})();
</script>

{% schema %}
{
	"name": "Collection",
	"settings": [
		{
			"type": "header",
			"content": "Hero"
		},
		{
			"type": "image_picker",
			"id": "hero_image",
			"label": "Hero background image"
		},
		{
			"type": "text",
			"id": "hero_heading",
			"label": "Heading override",
			"info": "Leave blank to use the collection title",
			"default": "Shop Aira"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow"
		},
		{
			"type": "header",
			"content": "Grid"
		},
		{
			"type": "select",
			"id": "columns",
			"label": "Columns",
			"options": [
				{ "value": "2", "label": "2 columns" },
				{ "value": "3", "label": "3 columns" },
				{ "value": "4", "label": "4 columns" }
			],
			"default": "3"
		},
		{
			"type": "range",
			"id": "products_per_page",
			"label": "Products per page",
			"min": 4,
			"max": 24,
			"step": 2,
			"default": 12
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FFFFFF"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" }
			],
			"default": "lg"
		}
	]
}
{% endschema %}
