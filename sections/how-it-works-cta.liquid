{%- comment -%}
	How it works — Final CTA
	Dark navy strip with eyebrow / h2 / lead and two CTAs (orange filled + cream outline).
{%- endcomment -%}

{%- render 'cta-banner',
	eyebrow: section.settings.eyebrow,
	heading: section.settings.heading,
	body: section.settings.lead,
	primary_label: section.settings.primary_label,
	primary_url: section.settings.primary_url,
	primary_variant: 'shop',
	secondary_label: section.settings.secondary_label,
	secondary_url: section.settings.secondary_url,
	secondary_variant: 'outline'
-%}

{%- comment -%}
	Page-level JS: reveal-on-scroll only.

	The step-rail active state is intentionally NOT driven by JS. Each step section
	renders its own sticky rail (snippets/step-rail.liquid) with the active step baked
	in server-side, and `.step-rail` is `position: sticky` within its own section. Only
	one rail is visible at a time, so the highlight always matches the section in view,
	switches exactly at the section boundary, and reverts on scroll-up automatically.
	A previous global IntersectionObserver synced all rails to one scroll-computed step,
	which flipped early and got stuck on scroll-up — removed in favour of the markup.
{%- endcomment -%}
<script>
(function () {
	/* ── Reveal-on-scroll ── */
	var revealEls = document.querySelectorAll('.reveal');
	if (revealEls.length) {
		if (!('IntersectionObserver' in window)) {
			revealEls.forEach(function (el) { el.classList.add('in'); });
		} else {
			var io = new IntersectionObserver(function (entries) {
				entries.forEach(function (e) {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						io.unobserve(e.target);
					}
				});
			}, { threshold: 0.12 });
			revealEls.forEach(function (el) { io.observe(el); });
		}
	}
})();
</script>

{% schema %}
{
	"name": "How it works — Final CTA",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{ "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Ready when you are" },
		{ "type": "text",     "id": "heading", "label": "Heading", "default": "Three steps. One better night." },
		{ "type": "textarea", "id": "lead",    "label": "Lead",    "default": "Every aira kit ships with all four strip sizes and 30 pairs of tabs — everything you need for your first month." },
		{ "type": "header", "content": "Primary CTA (orange)" },
		{ "type": "text", "id": "primary_label", "label": "Label", "default": "Get my kit" },
		{ "type": "url",  "id": "primary_url",   "label": "URL" },
		{ "type": "header", "content": "Secondary CTA (ghost light)" },
		{ "type": "text", "id": "secondary_label", "label": "Label", "default": "Re-watch tutorial" },
		{ "type": "url",  "id": "secondary_url",   "label": "URL", "info": "Use #tutorialVideo to anchor back to the hero video." }
	],
	"presets": [
		{ "name": "How it works — Final CTA" }
	]
}
{% endschema %}
