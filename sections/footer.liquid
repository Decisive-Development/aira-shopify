{%- comment -%} Footer {%- endcomment -%}
<footer style="background: #0A1A34;" class="relative overflow-hidden">
<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 140% 50% at 50% 100%, rgba(184,68,0,0.7) 0%, rgba(92,34,0,0.45) 35%, rgba(10,26,52,0) 70%); animation: footerGlow 12s ease-in-out infinite;"></div>
<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 120% 40% at 45% 100%, rgba(184,68,0,0.3) 0%, rgba(10,26,52,0) 50%); animation: footerGlow 8s ease-in-out infinite; animation-delay: -4s;"></div>
<style>
	@keyframes footerGlow {
		0%, 100% { opacity: 0.5; transform: scale(1); }
		50% { opacity: 1; transform: scale(1.12); }
	}
</style>
	<div class="w-full px-4 md:px-8 pt-10 pb-32 md:pb-28">

		{%- comment -%} Floating pill {%- endcomment -%}
		<div
			class="w-full max-w-7xl mx-auto bg-secondary rounded-2xl px-8 py-12 md:py-14"
			style="box-shadow: 0 12px 40px rgba(10,26,52,0.35), 0 4px 16px rgba(255,255,255,0.15);"
		>
			<div class="grid grid-cols-2 md:grid-cols-[1.6fr_1fr_1fr_1fr_1fr] gap-10 md:gap-6">

				{%- comment -%} Col 1: Brand — logo, newsletter, social {%- endcomment -%}
				<div class="flex flex-col gap-6 col-span-2 md:col-span-1">

					<a href="{{ routes.root_url }}" class="inline-block">
						<img
							src="{{ 'aira-logo-text-blue.svg' | asset_url }}"
							alt="{{ shop.name }}"
							class="h-7 w-auto"
							width="120"
							height="28"
							loading="lazy"
						>
					</a>

					{%- comment -%} Newsletter form {%- endcomment -%}
					{%- form 'customer', id: 'footer-newsletter' -%}
						<input type="hidden" name="contact[tags]" value="newsletter">
						<p class="text-sm font-semibold mb-2 text-main">Stay in the loop</p>
						<div class="flex flex-col sm:flex-row gap-2">
							<input
								type="email"
								name="contact[email]"
								placeholder="Your email"
								required
								class="w-full sm:w-70 rounded-xl px-4 py-3 text-sm text-main bg-white border border-main focus:outline-none"
							>
							{%- render 'cta-button',
								label: 'Subscribe',
								element: 'button',
								button_type: 'submit',
								variant: 'primary',
								extra_classes: 'shrink-0 w-full sm:w-auto text-center'
							-%}
						</div>
					{%- endform -%}

					{%- comment -%} Social icons (incl. WhatsApp from theme settings) {%- endcomment -%}
					<div class="flex items-center gap-4">
						{%- if section.settings.social_instagram != blank -%}
							<a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="text-main transition-opacity hover:opacity-60">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
									<rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-linecap="round" stroke-linejoin="round"/>
									<circle cx="12" cy="12" r="4" stroke-linecap="round" stroke-linejoin="round"/>
									<circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
								</svg>
							</a>
						{%- endif -%}
						{%- if section.settings.social_youtube != blank -%}
							<a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube" class="text-main transition-opacity hover:opacity-60">
								<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21.5 7.5s-.24-1.65-.97-2.38c-.93-.97-1.97-.97-2.44-1.03C15.6 3.9 12 3.9 12 3.9s-3.6 0-6.09.2c-.48.06-1.51.06-2.44 1.03C2.74 5.85 2.5 7.5 2.5 7.5S2.25 9.43 2.25 11.35v1.79c0 1.93.25 3.85.25 3.85s.24 1.65.97 2.38c.93.97 2.15.94 2.69 1.04C7.71 20.63 12 20.6 12 20.6s3.6 0 6.09-.2c.48-.06 1.51-.06 2.44-1.03.73-.73.97-2.38.97-2.38s.25-1.93.25-3.85v-1.79C21.75 9.43 21.5 7.5 21.5 7.5z"/>
									<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 15.02V9.02l6.5 3-6.5 3z"/>
								</svg>
							</a>
						{%- endif -%}
						{%- if section.settings.social_tiktok != blank -%}
							<a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="text-main transition-opacity hover:opacity-60">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
									<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.2 8.2 0 0 0 4.81 1.54V6.79a4.85 4.85 0 0 1-1.04-.1z"/>
								</svg>
							</a>
						{%- endif -%}
						{%- if settings.support_whatsapp_number != blank -%}
							{%- assign wa_prefill = settings.support_whatsapp_prefill | default: 'Hi AIRA team,' | url_encode -%}
							<a href="https://wa.me/{{ settings.support_whatsapp_number }}?text={{ wa_prefill }}" target="_blank" rel="noopener" aria-label="WhatsApp" class="text-main transition-opacity hover:opacity-60">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
								</svg>
							</a>
						{%- endif -%}
					</div>

				</div>

				{%- comment -%} Col 2: Shop {%- endcomment -%}
				<div>
					<h4 class="text-xs font-bold tracking-widest uppercase mb-4 text-main">Shop</h4>
					<ul class="flex flex-col gap-2.5">
						<li><a href="/products/aira-starter-kit" class="text-sm text-main transition-opacity hover:opacity-70">Starter Kit</a></li>
						<li><a href="/products/aira-refill-tabs" class="text-sm text-main transition-opacity hover:opacity-70">Refills</a></li>
						<li><a href="/collections/all" class="text-sm text-main transition-opacity hover:opacity-70">All Products</a></li>
					</ul>
				</div>

				{%- comment -%} Col 3: About {%- endcomment -%}
				<div>
					<h4 class="text-xs font-bold tracking-widest uppercase mb-4 text-main">About</h4>
					<ul class="flex flex-col gap-2.5">
						<li><a href="/pages/our-story" class="text-sm text-main transition-opacity hover:opacity-70">Our Story</a></li>
						<li><a href="/pages/how-it-works" class="text-sm text-main transition-opacity hover:opacity-70">How It Works</a></li>
						<li><a href="/pages/backed-by-science" class="text-sm text-main transition-opacity hover:opacity-70">Backed by Science</a></li>
						<li><a href="/pages/reviews" class="text-sm text-main transition-opacity hover:opacity-70">Reviews</a></li>
						<li><a href="/pages/affiliate" class="text-sm text-main transition-opacity hover:opacity-70">Partner with Us</a></li>
					</ul>
				</div>

				{%- comment -%} Col 4: Help {%- endcomment -%}
				<div>
					<h4 class="text-xs font-bold tracking-widest uppercase mb-4 text-main">Help</h4>
					<ul class="flex flex-col gap-2.5">
						<li><a href="/pages/contact" class="text-sm text-main transition-opacity hover:opacity-70">Contact</a></li>
						<li><a href="/pages/faq" class="text-sm text-main transition-opacity hover:opacity-70">FAQ</a></li>
						<li><a href="/pages/returns" class="text-sm text-main transition-opacity hover:opacity-70">Returns</a></li>
						<li><a href="/pages/order-tracking" class="text-sm text-main transition-opacity hover:opacity-70">Order tracking</a></li>
					</ul>
				</div>

				{%- comment -%} Col 5: Legal {%- endcomment -%}
				<div class="col-span-2 md:col-span-1">
					<h4 class="text-xs font-bold tracking-widest uppercase mb-4 text-main">Legal</h4>
					<ul class="flex flex-col gap-2.5">
						<li><a href="/policies/refund-policy" class="text-sm text-main transition-opacity hover:opacity-70">Refund Policy</a></li>
						<li><a href="/policies/shipping-policy" class="text-sm text-main transition-opacity hover:opacity-70">Shipping Policy</a></li>
						<li><a href="/policies/privacy-policy" class="text-sm text-main transition-opacity hover:opacity-70">Privacy Policy</a></li>
						<li><a href="/policies/terms-of-service" class="text-sm text-main transition-opacity hover:opacity-70">Terms of Service</a></li>
					</ul>
				</div>

			</div>
		</div>

		{%- comment -%} Bottom legal + copyright bar {%- endcomment -%}
		<div class="relative z-10 mt-6 pb-2 flex flex-col items-center gap-2">
			{%- if settings.legal_entity_name != blank -%}
				<p class="text-xs text-secondary/60 text-center m-0">
					{{ settings.legal_entity_name }}
					{%- if settings.legal_license_number != blank -%}
						&nbsp;&mdash; License {{ settings.legal_license_number }}
					{%- endif -%}
				</p>
			{%- endif -%}
			<div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-1 text-sm text-white">
				<span>&copy; {{ 'now' | date: '%Y' }} Aira Wellness.</span>
			</div>
		</div>

	</div>
</footer>

{% schema %}
{
	"name": "Footer",
	"settings": [
		{
			"type": "header",
			"content": "Social media"
		},
		{
			"type": "url",
			"id": "social_instagram",
			"label": "Instagram URL"
		},
		{
			"type": "url",
			"id": "social_youtube",
			"label": "YouTube URL"
		},
		{
			"type": "url",
			"id": "social_tiktok",
			"label": "TikTok URL"
		},
		{
			"type": "paragraph",
			"content": "WhatsApp icon is rendered automatically when the WhatsApp number is set in Theme settings → Support & contact."
		},
		{
			"type": "paragraph",
			"content": "Footer column links are hardcoded to match the navbar pattern. Edit them in sections/footer.liquid."
		},
		{
			"type": "paragraph",
			"content": "Brand colours and the legal entity block are controlled in Theme settings."
		}
	]
}
{% endschema %}
