{%- comment -%}
	Policy — Content
	Renders the policy prose with a sticky TOC on desktop and a collapsed
	<details> TOC on mobile. The TOC is built client-side by
	assets/policy-page.js from the H2 headings inside .policy-prose.

	Content source:
	  - If the page body (page.content) has text, render that — lets an
	    editor override from the Shopify page editor.
	  - Otherwise render the verbatim legally-reviewed HTML in the
	    snippet selected by the "Default content snippet" section setting
	    (privacy or terms). Update those snippets when the policy text
	    changes.
{%- endcomment -%}

{{ 'policy-page.css' | asset_url | stylesheet_tag }}

<section class="relative bg-secondary text-main py-12 md:py-20">

	<div class="container mx-auto px-4 max-w-[1080px]">

		{%- comment -%}
			Mobile TOC — collapsed inside <details>. Hidden on ≥ md.
		{%- endcomment -%}
		<details class="md:hidden mb-8 border-b border-main/15 pb-4">
			<summary class="cursor-pointer font-body text-sm font-medium text-main flex items-center justify-between list-none">
				<span>On this page</span>
				<span class="text-main/50">▾</span>
			</summary>
			<nav class="mt-4" aria-label="On this page (mobile)" data-policy-toc></nav>
		</details>

		<div class="md:flex md:gap-12 lg:gap-16 md:items-start">

			{%- comment -%}
				Desktop TOC — sticky sidebar. Hidden on < md.
			{%- endcomment -%}
			<aside class="hidden md:block md:w-1/3 md:max-w-60 md:sticky md:top-24 md:self-start md:shrink-0">
				<nav aria-label="On this page" data-policy-toc class="policy-toc"></nav>
			</aside>

			{%- comment -%} Prose body — see content-source note above {%- endcomment -%}
			<article class="policy-prose flex-1 max-w-[720px] font-body text-base md:text-[17px] leading-[1.7] text-copy">
				{%- if page.content != blank -%}
					{{ page.content }}
				{%- else -%}
					{%- case section.settings.default_content -%}
						{%- when 'terms' -%}
							{%- render 'policy-terms-default' -%}
						{%- when 'returns' -%}
							{%- render 'policy-returns-default' -%}
						{%- else -%}
							{%- render 'policy-privacy-default' -%}
					{%- endcase -%}
				{%- endif -%}
			</article>

		</div>

	</div>

</section>

<script src="{{ 'policy-page.js' | asset_url }}" defer></script>

{% schema %}
{
	"name": "Policy — Content",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{
			"type": "select",
			"id": "default_content",
			"label": "Default content snippet",
			"info": "Used when the page body is empty.",
			"options": [
				{ "value": "privacy", "label": "Privacy policy" },
				{ "value": "terms",   "label": "Terms of service" },
				{ "value": "returns", "label": "Return & refund policy" }
			],
			"default": "privacy"
		}
	],
	"presets": [
		{ "name": "Policy — Content" }
	]
}
{% endschema %}
