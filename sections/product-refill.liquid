{%- liquid
	assign current_variant = product.selected_or_first_available_variant | default: product.variants.first
	assign has_selling_plans = false
	if product.selling_plan_groups.size > 0
		assign has_selling_plans = true
		assign sp_group = product.selling_plan_groups.first
		assign sp_first = sp_group.selling_plans.first
		assign sp_allocation = current_variant.selling_plan_allocations | where: "selling_plan_id", sp_first.id | first
	endif
-%}

<style>
	/* Plan card selection */
	.plan-card {
		cursor: pointer;
		transition: border-color 0.3s ease, background-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
	}
	.plan-card:hover:not(.is-selected) {
		border-color: var(--color-primary);
		background-color: var(--color-secondary);
	}
	.plan-card.is-selected {
		border-color: var(--color-primary);
		background-color: var(--color-secondary);
		box-shadow: 0 0 0 1px var(--color-primary), 0 4px 20px rgba(10,26,52,0.08);
	}
	.plan-card:not(.is-selected) {
		border-color: var(--color-border);
		background-color: #FFFFFF;
		box-shadow: none;
	}
	.plan-perks {
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.3s ease;
		margin-top: 0;
	}
	.plan-card.is-selected .plan-perks {
		max-height: 300px;
		opacity: 1;
		margin-top: 0.25rem;
	}

	/* Accordion content — bullet lists */
	.product-info-content ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}
	.product-info-content li {
		display: flex;
		align-items: flex-start;
		gap: 0.625rem;
	}
	.product-info-content li > img.bullet-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		margin-top: 2px;
	}
	.product-info-content li strong {
		font-weight: 700;
		color: #FF4000;
	}
</style>


<section class="bg-bg pt-20 md:pt-24 pb-16 md:pb-24" data-refill-section>
	<div class="container-contained">

		{%- comment -%} ══════ Two-column layout ══════ {%- endcomment -%}
		<div class="grid lg:grid-cols-2 gap-8 lg:gap-14">

			{%- comment -%} ── Left: Image gallery ── {%- endcomment -%}
			<div class="flex flex-col gap-4 lg:sticky lg:top-24 lg:self-start">

				{%- comment -%} Main image {%- endcomment -%}
				<div class="relative aspect-square rounded-2xl overflow-hidden bg-bg-muted">
					{%- if product.featured_image -%}
						{{
							product.featured_image
							| image_url: width: 1200
							| image_tag:
								loading: 'eager',
								class: 'w-full h-full object-cover',
								widths: '400, 600, 800, 1200',
								id: 'refill-main-image'
						}}
					{%- endif -%}
				</div>

				{%- comment -%} Thumbnail row {%- endcomment -%}
				<div class="grid grid-cols-6 gap-2">
					{%- for image in product.images limit: 6 -%}
						<button
							type="button"
							class="aspect-square rounded-lg overflow-hidden bg-bg-muted border-2 transition-colors cursor-pointer {% if forloop.first %}border-main{% else %}border-transparent hover:border-bg-muted{% endif %}"
							data-thumb-btn
							data-thumb-src="{{ image | image_url: width: 1200 }}"
						>
							{{
								image
								| image_url: width: 200
								| image_tag:
									loading: 'lazy',
									class: 'w-full h-full object-cover',
									widths: '100, 200'
							}}
						</button>
					{%- endfor -%}
					{%- if product.images.size < 6 -%}
						{%- assign placeholders_needed = 6 | minus: product.images.size -%}
						{%- for i in (1..placeholders_needed) -%}
							<div class="aspect-square rounded-lg bg-bg-muted border-2 border-transparent"></div>
						{%- endfor -%}
					{%- endif -%}
				</div>

			</div>

			{%- comment -%} ── Right: Product info + form ── {%- endcomment -%}
			<div class="flex flex-col gap-5">

				{%- comment -%} Rating {%- endcomment -%}
				{%- if section.settings.show_rating -%}
					<a href="#reviews-section" class="flex items-center gap-2 hover:opacity-80 transition-opacity scroll-link">
						<div class="flex items-center gap-0.5 text-highlight">
							{%- for i in (1..5) -%}
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
							{%- endfor -%}
						</div>
						{%- if section.settings.rating_text != blank -%}
							<span class="text-copy text-sm">{{ section.settings.rating_text }}</span>
						{%- endif -%}
					</a>
				{%- endif -%}

				{%- comment -%} Title + description {%- endcomment -%}
				<div>
					<h2 class="font-heading heading-weight text-3xl md:text-4xl text-title leading-tight">{{ product.title }}</h2>
					{%- if section.settings.product_subtitle != blank -%}
						<p class="text-copy text-base leading-relaxed mt-3 max-w-lg">{{ section.settings.product_subtitle }}</p>
					{%- endif -%}
				</div>

				<form action="{{ routes.cart_add_url }}" method="post" class="flex flex-col gap-5" data-refill-form>
					<input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
					<input type="hidden" name="quantity" value="1">
					{%- if has_selling_plans -%}
						<input type="hidden" name="selling_plan" value="" data-selling-plan-input>
					{%- else -%}
						<input type="hidden" name="selling_plan" value="" data-selling-plan-input>
					{%- endif -%}

					<p class="text-xs font-bold uppercase tracking-widest text-copy">Plan</p>

					<div class="flex flex-col gap-3">

						{%- comment -%} ── Monthly Refill Plan card ── {%- endcomment -%}
						<button
							type="button"
							class="plan-card relative flex flex-col gap-3 p-4 rounded-2xl border-2 text-left"
							data-plan-btn="subscribe"
						>
							{%- if section.settings.plan_badge != blank -%}
								<span class="absolute -top-3 left-4 px-3 py-1 rounded-full bg-main text-white text-xs font-bold">
									{{ section.settings.plan_badge }}
								</span>
							{%- endif -%}
							<div class="flex items-center justify-between gap-4">
								<div class="flex items-baseline gap-2 flex-wrap">
									<span class="font-heading font-bold text-title text-base">{{ section.settings.plan_title | default: 'Monthly Refill Plan | 30 tabs' }}</span>
									{%- if section.settings.plan_save_text != blank -%}
										<span class="text-highlight text-sm font-bold">· {{ section.settings.plan_save_text }}</span>
									{%- endif -%}
								</div>
								<span class="font-heading font-bold text-title text-lg shrink-0" data-subscribe-price>
									{%- if has_selling_plans and sp_allocation -%}
										{{ sp_allocation.per_delivery_price | money }}
									{%- else -%}
										{{ section.settings.plan_price | default: current_variant.price | money }}
									{%- endif -%}
								</span>
							</div>
							{%- assign perk_blocks = section.blocks | where: "type", "refill_perk" -%}
							{%- if perk_blocks.size > 0 -%}
								<ul class="plan-perks flex flex-col gap-2">
									{%- for block in perk_blocks -%}
										<li class="flex items-start gap-2.5 text-sm text-copy" {{ block.shopify_attributes }}>
											<img src="{{ 'aira-logo-only-dark.svg' | asset_url }}" alt="" class="w-4 h-4 shrink-0 mt-0.5" width="16" height="16" loading="lazy">
											{{ block.settings.text }}
										</li>
									{%- endfor -%}
								</ul>
							{%- endif -%}
						</button>

						{%- comment -%} ── Variant cards (one-time) ── {%- endcomment -%}
						{%- for variant in product.variants -%}
							<button
								type="button"
								class="plan-card flex items-center justify-between gap-4 p-4 rounded-2xl border-2 text-left {% if forloop.first %}is-selected{% endif %}"
								data-plan-btn="onetime"
								data-variant-btn="{{ variant.id }}"
							>
								<div class="flex items-baseline gap-2 flex-wrap">
									<span class="font-heading font-bold text-title text-base">{{ variant.title }} Adhesive Tab Pairs</span>
									{%- if forloop.last -%}
										<span class="text-highlight text-sm font-bold">· Biggest saving</span>
									{%- elsif variant.metafields.custom.badge != blank -%}
										<span class="text-highlight text-sm font-bold">· {{ variant.metafields.custom.badge }}</span>
									{%- endif -%}
								</div>
								<span class="font-heading font-bold text-title text-lg shrink-0">{{ variant.price | money }}</span>
							</button>
						{%- endfor -%}

					</div>

					{%- comment -%} ── Add to cart ── {%- endcomment -%}
					<button
						type="submit"
						class="inline-block rounded-xl text-sm font-semibold tracking-wide transition-opacity hover:opacity-90 bg-main text-secondary px-10 py-4 w-full text-center cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
						data-add-to-cart
						{% unless current_variant.available %}disabled{% endunless %}
					>
						{%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
					</button>

					{%- comment -%} ── Reassurance micro-copy ── {%- endcomment -%}
					<p class="text-xs text-title text-center">✓ Free shipping on all GCC orders</p>

				</form>

				{%- comment -%} ── Aira Kit link ── {%- endcomment -%}
				{%- if section.settings.starter_link_url != blank -%}
					<a
						href="{{ section.settings.starter_link_url }}"
						class="text-sm text-copy hover:text-highlight transition-colors"
					>
						{{ section.settings.starter_link_label | default: 'Need a Aira Kit? Start here →' }}
					</a>
				{%- endif -%}

				{%- comment -%} ── Trust badges ── {%- endcomment -%}
				{%- assign trust_blocks = section.blocks | where: "type", "trust_badge" -%}
				{%- if trust_blocks.size > 0 -%}
					<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
						{%- for block in trust_blocks -%}
							<div class="flex flex-col items-center justify-center text-center gap-2 bg-bg-soft rounded-xl py-3 px-3 {% if trust_blocks.size == 3 and forloop.last %}col-span-2 md:col-span-1{% endif %}" {{ block.shopify_attributes }}>
								{%- case block.settings.icon_type -%}
									{%- when 'research' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-main"><path d="M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m-2 6h2m14-6h2m-2 6h2"/><rect x="7" y="7" width="10" height="10" rx="1"/><path d="M12 7v10m-3-7h6m-6 4h6"/></svg>
									{%- when 'patented' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-main"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
									{%- when 'doctor' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-main"><path d="M4.8 2.3A.3.3 0 105 2H4a2 2 0 00-2 2v5a6 6 0 006 6 6 6 0 006-6V4a2 2 0 00-2-2h-1a.2.2 0 10.3.3"/><path d="M8 15v1a6 6 0 006 6 6 6 0 006-6v-4"/><circle cx="20" cy="10" r="2"/></svg>
									{%- when 'shield' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-main"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
									{%- else -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-main"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
								{%- endcase -%}
								<span class="font-heading font-semibold text-title text-xs leading-tight">{{ block.settings.text }}</span>
							</div>
						{%- endfor -%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Inline info accordions ── {%- endcomment -%}
				{%- assign faq_blocks = section.blocks | where: "type", "product_faq" -%}
				{%- if faq_blocks.size > 0 -%}
					<div class="flex flex-col gap-0 mt-2 [&>:last-child]:border-b-0">
						{%- for block in faq_blocks -%}
							<div class="border-b border-border" {{ block.shopify_attributes }}>
								<button
									type="button"
									class="group w-full flex items-center justify-between gap-4 py-4 text-left cursor-pointer"
									aria-expanded="false"
									data-faq-toggle
								>
									<span class="font-heading font-semibold text-title text-sm">{{ block.settings.question }}</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="shrink-0 text-copy transition-transform duration-200 group-aria-expanded:rotate-180">
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
									</svg>
								</button>
								<div class="overflow-hidden transition-all duration-300 product-info-content" style="max-height: 0;">
									<div class="pb-4 text-copy text-sm leading-relaxed">{{ block.settings.answer }}</div>
								</div>
							</div>
						{%- endfor -%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Static FAQ pairs ── {%- endcomment -%}
				<div class="flex flex-col gap-4 border-t border-border pt-5 mt-4">
					<div>
						<p class="font-heading font-semibold text-title text-sm">Will it help with my snoring?</p>
						<p class="text-copy text-sm leading-relaxed mt-1">When your airway is open, your body naturally breathes through the nose instead of the mouth — the primary cause of snoring is reduced.</p>
					</div>
					<div>
						<p class="font-heading font-semibold text-title text-sm">Does it fall off during sleep?</p>
						<p class="text-copy text-sm leading-relaxed mt-1">The medical-grade adhesive holds all night, even for restless sleepers. The magnetic band weighs less than 2 grams — most people forget it's there within minutes.</p>
					</div>
				</div>

			</div>
		</div>

	</div>
</section>

{%- comment -%} ══════ Sticky mobile add-to-cart bar ══════ {%- endcomment -%}
<div
	class="fixed bottom-0 inset-x-0 z-40 bg-secondary px-4 py-3 flex items-center justify-between gap-4 lg:hidden translate-y-full transition-transform duration-300"
	data-sticky-bar
	style="box-shadow: 0 -4px 24px rgba(10,26,52,0.1);"
>
	<div class="flex flex-col min-w-0">
		<p class="font-heading font-semibold text-main text-sm truncate">{{ product.title }}</p>
		<span class="font-heading font-bold text-main text-lg" data-sticky-price>{{ current_variant.price | money }}</span>
	</div>
	<button
		type="button"
		class="shrink-0 px-8 py-3 rounded-xl bg-highlight text-white text-sm font-semibold tracking-wide transition-opacity hover:opacity-90 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
		data-sticky-atc
		{% unless current_variant.available %}disabled{% endunless %}
	>
		Add to Cart
	</button>
</div>

<script>
(function () {
	var section = document.querySelector('[data-refill-section]');
	if (!section) return;

	/* ── Smooth scroll for review link ── */
	section.querySelectorAll('.scroll-link').forEach(function (link) {
		link.addEventListener('click', function (e) {
			var target = document.querySelector(link.getAttribute('href'));
			if (target) {
				e.preventDefault();
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});
	});

	var form = section.querySelector('[data-refill-form]');
	var variantInput = form.querySelector('[data-variant-id]');
	var sellingPlanInput = form.querySelector('[data-selling-plan-input]');
	var addBtn = form.querySelector('[data-add-to-cart]');
	var mainImage = document.getElementById('refill-main-image');
	var thumbBtns = section.querySelectorAll('[data-thumb-btn]');
	var planBtns = section.querySelectorAll('[data-plan-btn]');

	/* ── Variant data ── */
	var variantsJson = document.querySelector('[data-product-variants]');
	var variants = variantsJson ? JSON.parse(variantsJson.textContent) : [];

	function findVariant(id) {
		return variants.find(function (v) { return v.id === id; }) || null;
	}

	/* ── Card selection — only one active at a time ── */
	var stickyPriceEl = document.querySelector('[data-sticky-price]');

	function selectCard(activeBtn) {
		planBtns.forEach(function (b) { b.classList.remove('is-selected'); });
		activeBtn.classList.add('is-selected');

		var type = activeBtn.getAttribute('data-plan-btn');
		var variantId = activeBtn.getAttribute('data-variant-btn');

		if (type === 'subscribe') {
			/* Set selling plan for first variant */
			if (sellingPlanInput && variants.length > 0) {
				var v = variants[0];
				variantInput.value = v.id;
				if (v.selling_plan_allocations.length > 0) {
					sellingPlanInput.value = v.selling_plan_allocations[0].selling_plan_id;
					if (stickyPriceEl) stickyPriceEl.textContent = v.selling_plan_allocations[0].per_delivery_price_formatted;
				}
			}
		} else {
			/* One-time: set variant, clear selling plan */
			if (sellingPlanInput) sellingPlanInput.value = '';
			if (variantId) {
				variantInput.value = variantId;
				var v = findVariant(parseInt(variantId, 10));
				if (v && stickyPriceEl) stickyPriceEl.textContent = v.price_formatted;
			}
		}
	}

	planBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			selectCard(btn);
		});
	});

	/* ── Thumbnail gallery ── */
	thumbBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			if (!mainImage) return;
			mainImage.removeAttribute('srcset');
			mainImage.removeAttribute('sizes');
			mainImage.src = btn.getAttribute('data-thumb-src');

			thumbBtns.forEach(function (b) {
				b.classList.remove('border-main');
				b.classList.add('border-transparent');
			});
			btn.classList.remove('border-transparent');
			btn.classList.add('border-main');
		});
	});

	/* ── FAQ accordion ── */
	var faqToggles = section.querySelectorAll('[data-faq-toggle]');
	faqToggles.forEach(function (btn) {
		btn.addEventListener('click', function () {
			var expanded = btn.getAttribute('aria-expanded') === 'true';
			var content = btn.nextElementSibling;
			btn.setAttribute('aria-expanded', !expanded);
			if (!expanded) {
				content.style.maxHeight = content.scrollHeight + 'px';
				content.addEventListener('transitionend', function handler() {
					content.style.maxHeight = 'none';
					content.removeEventListener('transitionend', handler);
				});
			} else {
				content.style.maxHeight = content.scrollHeight + 'px';
				requestAnimationFrame(function () {
					content.style.maxHeight = '0';
				});
			}
		});
	});

	/* ── Inject logo icons into accordion list items ── */
	var logoSrc = '{{ "aira-logo-only-dark.svg" | asset_url }}';
	section.querySelectorAll('.product-info-content li').forEach(function (li) {
		if (li.querySelector('strong')) return;
		var img = document.createElement('img');
		img.src = logoSrc;
		img.alt = '';
		img.className = 'bullet-icon';
		img.width = 16;
		img.height = 16;
		img.loading = 'lazy';
		li.insertBefore(img, li.firstChild);
	});

	/* ── Auto-open first accordion (Benefits) ── */
	if (faqToggles.length > 0) {
		var firstBtn = faqToggles[0];
		firstBtn.setAttribute('aria-expanded', 'true');
		firstBtn.nextElementSibling.style.maxHeight = 'none';
	}

	/* ── Sticky mobile bar ── */
	var stickyBar = document.querySelector('[data-sticky-bar]');
	var stickyAtc = stickyBar ? stickyBar.querySelector('[data-sticky-atc]') : null;

	if (stickyBar && addBtn) {
		var observer = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (entry.isIntersecting) {
					stickyBar.classList.add('translate-y-full');
					stickyBar.classList.remove('translate-y-0');
				} else {
					stickyBar.classList.remove('translate-y-full');
					stickyBar.classList.add('translate-y-0');
				}
			});
		}, { threshold: 0 });

		observer.observe(addBtn);

		stickyAtc.addEventListener('click', function () {
			addBtn.click();
		});
	}
})();
</script>

{%- comment -%} ── Variant data for JS ── {%- endcomment -%}
<script type="application/json" data-product-variants>
	[
		{%- for variant in product.variants -%}
			{
				"id": {{ variant.id }},
				"options": {{ variant.options | json }},
				"price": {{ variant.price }},
				"price_formatted": {{ variant.price | money | json }},
				"compare_at_price": {{ variant.compare_at_price | default: 0 }},
				"compare_at_price_formatted": {% if variant.compare_at_price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
				"available": {{ variant.available | json }},
				"selling_plan_allocations": [
					{%- for alloc in variant.selling_plan_allocations -%}
						{
							"selling_plan_id": {{ alloc.selling_plan.id }},
							"per_delivery_price": {{ alloc.per_delivery_price }},
							"per_delivery_price_formatted": {{ alloc.per_delivery_price | money | json }},
							"name": {{ alloc.selling_plan.name | json }}
						}{%- unless forloop.last -%},{%- endunless -%}
					{%- endfor -%}
				]
			}{%- unless forloop.last -%},{%- endunless -%}
		{%- endfor -%}
	]
</script>

