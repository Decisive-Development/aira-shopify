{%- comment -%} Affiliate — Benefits (scaffold). {%- endcomment -%}

<section class="bg-secondary py-16 md:py-24">
	<div class="container mx-auto px-4 max-w-5xl">

		<header class="text-center mb-12">
			{%- if section.settings.eyebrow != blank -%}
				<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
			{%- endif -%}
			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight text-3xl md:text-4xl text-title m-0">{{ section.settings.heading }}</h2>
			{%- endif -%}
		</header>

		{%- if section.blocks.size > 0 -%}
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
				{%- for block in section.blocks -%}
					<div class="rounded-xl bg-bg p-6 flex flex-col gap-2" {{ block.shopify_attributes }}>
						{%- if block.settings.value != blank -%}
							<p class="font-heading text-2xl md:text-3xl font-medium text-title m-0">{{ block.settings.value }}</p>
						{%- endif -%}
						<p class="font-heading text-sm font-semibold text-title m-0">{{ block.settings.title }}</p>
						{%- if block.settings.body != blank -%}
							<p class="text-sm text-copy/80 m-0">{{ block.settings.body }}</p>
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "Affiliate - Benefits",
	"settings": [
		{ "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What you get" },
		{ "type": "text", "id": "heading", "label": "Heading", "default": "Real product, real reward" }
	],
	"blocks": [
		{
			"type": "benefit",
			"name": "Benefit",
			"settings": [
				{ "type": "text",     "id": "value", "label": "Value (large)", "default": "15%" },
				{ "type": "text",     "id": "title", "label": "Title",         "default": "Commission" },
				{ "type": "textarea", "id": "body",  "label": "Body",          "default": "On every sale through your link." }
			]
		}
	],
	"presets": [
		{
			"name": "Affiliate - Benefits",
			"blocks": [
				{ "type": "benefit", "settings": { "value": "15%",   "title": "Commission",     "body": "On every sale through your link." } },
				{ "type": "benefit", "settings": { "value": "Free",  "title": "Starter Kit",    "body": "Sent to every approved partner." } },
				{ "type": "benefit", "settings": { "value": "20%",   "title": "Audience code",  "body": "A discount code your audience can use." } },
				{ "type": "benefit", "settings": { "value": "Net 30","title": "Payouts",        "body": "Cleared monthly via bank transfer or PayPal." } }
			]
		}
	]
}
{% endschema %}
