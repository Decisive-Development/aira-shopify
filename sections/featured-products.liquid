{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-4 md:py-12'
		when 'md'
			assign py = 'py-8 md:py-20'
		when 'lg'
			assign py = 'py-12 md:py-32'
		when 'xl'
			assign py = 'py-16 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<section
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}
	<div class="{{ container_class }} {{ py }}">

		{%- comment -%} Section heading {%- endcomment -%}
		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div class="mb-12 md:mb-16">
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      section.settings.heading_align,
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- comment -%} Product cards {%- endcomment -%}
		{%- if section.blocks.size > 0 -%}
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
				{%- for block in section.blocks -%}
					{%- assign product = block.settings.product -%}
					{%- if product != blank -%}

						<div class="flex flex-col bg-bg rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300" {{ block.shopify_attributes }}>

							{%- comment -%} Image {%- endcomment -%}
							<a href="{{ product.url }}" class="block relative aspect-4/5 overflow-hidden bg-bg-muted group">
								{%- if product.featured_image -%}
									{{
										product.featured_image
										| image_url: width: 800
										| image_tag:
											loading: 'lazy',
											class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
											widths: '400, 600, 800',
											draggable: 'false'
									}}
								{%- endif -%}

								{%- if block.settings.badge != blank -%}
									<span class="absolute top-3 left-3 px-3 py-1 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
										{{ block.settings.badge }}
									</span>
								{%- endif -%}
							</a>

							{%- comment -%} Content {%- endcomment -%}
							<div class="flex flex-col flex-1 p-6 gap-4">

								<h3 class="font-heading text-title font-semibold text-xl leading-snug">
									{{ product.title }}
								</h3>

								{%- if block.type == 'subscription_product' -%}

									{%- comment -%} ── Refill / subscription card ── {%- endcomment -%}
									{%- if block.settings.description != blank -%}
										<p class="text-copy text-sm leading-relaxed">{{ block.settings.description }}</p>
									{%- endif -%}

									{%- comment -%} Subscribe section {%- endcomment -%}
									<div class="flex flex-col gap-1.5 p-4 rounded-xl bg-bg-soft border border-bg-muted">
										<div class="flex items-center gap-2">
											<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-highlight-green shrink-0">
												<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
											</svg>
											<span class="font-heading text-sm font-bold text-title">{{ block.settings.subscribe_heading | default: 'Subscribe & save' }}</span>
										</div>
										<p class="text-xs text-copy leading-snug">{{ block.settings.subscribe_text | default: 'Never run out — automatic delivery at a discount, cancel any time.' }}</p>
									</div>

									{%- comment -%} One-time / bulk section {%- endcomment -%}
									<div class="flex flex-col gap-1.5 p-4 rounded-xl bg-bg-soft border border-bg-muted">
										<div class="flex items-center gap-2">
											<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-highlight-blue shrink-0">
												<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
											</svg>
											<span class="font-heading text-sm font-bold text-title">{{ block.settings.onetime_heading | default: 'Buy in bulk' }}</span>
										</div>
										<p class="text-xs text-copy leading-snug">{{ block.settings.onetime_text | default: 'Stock up with 30, 60 or 90 packs — the more you buy, the more you save.' }}</p>
									</div>

								{%- else -%}

									{%- comment -%} ── Standard product card ── {%- endcomment -%}
									{%- if block.settings.description != blank -%}
										<p class="text-copy text-sm leading-relaxed">{{ block.settings.description }}</p>
									{%- endif -%}

								{%- endif -%}

								{%- comment -%} CTA link {%- endcomment -%}
								<div class="mt-auto pt-2">
									{%- render 'cta-button',
										label: block.settings.cta_label | default: 'Shop now',
										url: product.url,
										variant: 'primary',
										extra_classes: 'w-full text-center'
									-%}
								</div>

							</div>

						</div>

					{%- endif -%}
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "Featured Products",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Our products"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Simple. Effective. Aira."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Two products. Everything you need to breathe freely and sleep better."
		},
		{
			"type": "select",
			"id": "heading_align",
			"label": "Heading alignment",
			"options": [
				{ "value": "left",   "label": "Left" },
				{ "value": "center", "label": "Center" },
				{ "value": "right",  "label": "Right" }
			],
			"default": "center"
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FAFAFA"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 0,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"blocks": [
		{
			"type": "product",
			"name": "Product",
			"settings": [
				{
					"type": "product",
					"id": "product",
					"label": "Product"
				},
				{
					"type": "text",
					"id": "badge",
					"label": "Badge",
					"info": "Optional label on the image, e.g. 'Best Seller'"
				},
				{
					"type": "textarea",
					"id": "description",
					"label": "Description",
					"default": "Everything you need to start breathing better tonight. Includes 4 sized nasal strips and 15 adhesive tabs."
				},
				{
					"type": "text",
					"id": "cta_label",
					"label": "Button label",
					"default": "Shop now"
				}
			]
		},
		{
			"type": "subscription_product",
			"name": "Product (subscribe)",
			"settings": [
				{
					"type": "product",
					"id": "product",
					"label": "Product"
				},
				{
					"type": "text",
					"id": "badge",
					"label": "Badge",
					"info": "Optional label on the image, e.g. 'Best Seller'"
				},
				{
					"type": "textarea",
					"id": "description",
					"label": "Description",
					"default": "Fresh adhesive tabs for your Aira strip. Replace nightly for the best hold and hygiene."
				},
				{
					"type": "text",
					"id": "subscribe_heading",
					"label": "Subscribe heading",
					"default": "Subscribe & save"
				},
				{
					"type": "textarea",
					"id": "subscribe_text",
					"label": "Subscribe description",
					"default": "Never run out — automatic delivery at a discount, cancel any time."
				},
				{
					"type": "text",
					"id": "onetime_heading",
					"label": "Bulk heading",
					"default": "Buy in bulk"
				},
				{
					"type": "textarea",
					"id": "onetime_text",
					"label": "Bulk description",
					"default": "Stock up with 30, 60 or 90 packs — the more you buy, the more you save."
				},
				{
					"type": "text",
					"id": "cta_label",
					"label": "Button label",
					"default": "Shop now"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Featured Products",
			"blocks": [
				{ "type": "product" },
				{ "type": "subscription_product" }
			]
		}
	]
}
{% endschema %}
