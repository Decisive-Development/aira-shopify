{%- comment -%}
	The aira difference — problems fixed → results, not mechanism.
	Light/cream editorial interlude between the Before/After slider and the
	SLEEP trust bar. Single centered text column (~65ch), no JS.
	Optional image renders only when set (hidden when blank).
{%- endcomment -%}

<section
	id="aira-difference-{{ section.id }}"
	class="bg-cream-light"
>
	<div class="container-contained py-12 md:py-32">
		<div class="mx-auto text-center" style="max-width: 65ch;">

			{%- comment -%} Eyebrow {%- endcomment -%}
			{%- if section.settings.eyebrow != blank -%}
				<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-5 md:mb-6">
					{{ section.settings.eyebrow }}
				</p>
			{%- endif -%}

			{%- comment -%} Heading {%- endcomment -%}
			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight text-4xl md:text-5xl leading-none tracking-tight text-title text-balance">
					{{ section.settings.heading }}
				</h2>
			{%- endif -%}

			{%- comment -%} Body (richtext) {%- endcomment -%}
			{%- if section.settings.body != blank -%}
				<div class="text-base md:text-lg leading-relaxed text-copy mt-7 md:mt-8 [&>p]:mb-5 [&>p:last-child]:mb-0">
					{{ section.settings.body }}
				</div>
			{%- endif -%}

			{%- comment -%} Kicker line {%- endcomment -%}
			{%- if section.settings.kicker_line != blank -%}
				<p class="font-heading font-semibold text-main text-lg md:text-xl tracking-tight mt-8 md:mt-10">
					{{ section.settings.kicker_line }}
				</p>
			{%- endif -%}

			{%- comment -%} Conviction CTA (ghost link + arrow, as on the trust bars) {%- endcomment -%}
			{%- if section.settings.cta_label != blank -%}
				<div class="mt-6 md:mt-7">
					{%- render 'cta-button',
						label: section.settings.cta_label,
						url: section.settings.cta_url,
						variant: 'link'
					-%}
				</div>
			{%- endif -%}

			{%- comment -%} Optional image — hidden entirely when blank {%- endcomment -%}
			{%- if section.settings.image != blank -%}
				<div class="mt-12 md:mt-16">
					{{
						section.settings.image
						| image_url: width: 1600
						| image_tag:
							loading: 'lazy',
							class: 'w-full h-auto rounded-2xl',
							widths: '600, 900, 1280, 1600',
							alt: section.settings.image.alt
					}}
				</div>
			{%- endif -%}

		</div>
	</div>
</section>

{% schema %}
{
	"name": "aira Difference",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{ "type": "header", "content": "Content" },
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "THE AIRA DIFFERENCE"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Most sleep problems are breathing problems."
		},
		{
			"type": "richtext",
			"id": "body",
			"label": "Body",
			"default": "<p>The snoring that sends your partner to the sofa. The dry mouth at 6am. The eight hours that somehow weren't enough. They look like different problems — but they usually share one root: your nose closes, and your mouth takes over.</p><p>Keep your airway open through the night, and the dominoes fall the other way. Quieter rooms. Deeper sleep. Easier mornings, faster recovery. Nothing to learn, nothing to remember — it works while you sleep.</p>"
		},
		{
			"type": "text",
			"id": "kicker_line",
			"label": "Kicker line",
			"default": "Fix the breathing. The rest follows."
		},
		{ "type": "header", "content": "CTA" },
		{
			"type": "text",
			"id": "cta_label",
			"label": "Conviction link label",
			"default": "How it works"
		},
		{
			"type": "url",
			"id": "cta_url",
			"label": "Conviction link URL"
		},
		{ "type": "header", "content": "Image" },
		{
			"type": "image_picker",
			"id": "image",
			"label": "Image (optional)",
			"info": "Hidden entirely when blank — reserved for later photography."
		}
	],
	"presets": [
		{
			"name": "aira Difference"
		}
	]
}
{% endschema %}
