{%- liquid
	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase

	assign has_image_desktop = false
	if section.settings.image_desktop != blank
		assign has_image_desktop = true
	endif

	assign has_image_mobile = false
	if section.settings.image_mobile != blank
		assign has_image_mobile = true
	endif

	assign has_any_image = false
	if has_image_desktop or has_image_mobile
		assign has_any_image = true
	endif

	assign alt_text = section.settings.heading | default: 'AIRA — Performance' | escape
	if has_image_desktop and section.settings.image_desktop.alt != blank
		assign alt_text = section.settings.image_desktop.alt | escape
	elsif has_image_mobile and section.settings.image_mobile.alt != blank
		assign alt_text = section.settings.image_mobile.alt | escape
	endif
-%}

<section
	id="performance-{{ section.id }}"
	class="relative overflow-hidden w-full bg-main text-secondary md:min-h-[85vh] md:max-h-[900px]"
	data-performance="{{ section.id }}"
>

	{%- comment -%} ── Image layer ── {%- endcomment -%}
	<div class="relative w-full aspect-[4/5] md:aspect-auto md:absolute md:inset-0">

		{%- if has_any_image -%}
			<picture>
				{%- if has_image_desktop -%}
					<source
						media="(min-width: 768px)"
						srcset="{{ section.settings.image_desktop | image_url: width: 1280 }} 1280w,
						        {{ section.settings.image_desktop | image_url: width: 1920 }} 1920w,
						        {{ section.settings.image_desktop | image_url: width: 2400 }} 2400w"
						sizes="100vw"
					>
				{%- endif -%}

				{%- if has_image_mobile -%}
					<img
						src="{{ section.settings.image_mobile | image_url: width: 1125 }}"
						srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w,
						        {{ section.settings.image_mobile | image_url: width: 1125 }} 1125w,
						        {{ section.settings.image_mobile | image_url: width: 1500 }} 1500w"
						sizes="100vw"
						alt="{{ alt_text }}"
						class="absolute inset-0 w-full h-full object-cover"
						loading="lazy"
						decoding="async"
						width="{{ section.settings.image_mobile.width }}"
						height="{{ section.settings.image_mobile.height }}"
					>
				{%- elsif has_image_desktop -%}
					<img
						src="{{ section.settings.image_desktop | image_url: width: 1920 }}"
						alt="{{ alt_text }}"
						class="absolute inset-0 w-full h-full object-cover"
						loading="lazy"
						decoding="async"
						width="{{ section.settings.image_desktop.width }}"
						height="{{ section.settings.image_desktop.height }}"
					>
				{%- endif -%}
			</picture>
		{%- endif -%}

		{%- comment -%} Desktop legibility gradient — dark on left, fades right {%- endcomment -%}
		<div
			class="hidden md:block absolute inset-0 pointer-events-none"
			style="background: linear-gradient(90deg, rgba(10,26,52,0.92) 0%, rgba(10,26,52,0.78) 22%, rgba(10,26,52,0.45) 42%, rgba(10,26,52,0.12) 62%, transparent 80%);"
		></div>

		{%- comment -%} Mobile fade — image bleeds into the content block below {%- endcomment -%}
		<div
			class="md:hidden absolute inset-x-0 bottom-0 h-24 pointer-events-none"
			style="background: linear-gradient(180deg, transparent, var(--color-main));"
		></div>
	</div>

	{%- comment -%} ── Content layer ── {%- endcomment -%}
	<div class="relative md:absolute md:inset-0 md:flex md:items-end md:pb-16 lg:pb-20">
		<div class="{{ container_class }} w-full py-10 md:py-0">
			<div
				class="max-w-md md:max-w-lg lg:max-w-xl flex flex-col gap-5 md:gap-6 transition-all duration-700 ease-out opacity-0 translate-y-6"
				data-animate
			>

				{%- if section.settings.eyebrow != blank -%}
					<p class="text-xs font-bold uppercase tracking-widest text-highlight">
						{{ section.settings.eyebrow }}
					</p>
				{%- endif -%}

				{%- if section.settings.heading != blank -%}
					<h2 class="font-heading heading-weight text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-secondary">
						{{ section.settings.heading }}
					</h2>
				{%- endif -%}

				{%- if section.settings.subheading != blank -%}
					<p class="text-base md:text-lg leading-relaxed text-secondary/80 max-w-md">
						{{ section.settings.subheading }}
					</p>
				{%- endif -%}

				{%- if section.settings.cta_label != blank -%}
					<div class="pt-1">
						{%- render 'cta-button',
							label:   section.settings.cta_label,
							url:     section.settings.cta_url,
							variant: 'accent'
						-%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Stat (qualifier stays attached — see brief §5) ── {%- endcomment -%}
				{%- if section.settings.stat_value != blank or section.settings.stat_label != blank or section.settings.stat_supporting != blank -%}
					<div class="pt-4 md:pt-5 mt-1 md:mt-2 border-t border-secondary/20">

						<div class="flex items-baseline gap-3 flex-wrap">
							{%- if section.settings.stat_value != blank -%}
								<span class="font-heading font-bold text-secondary leading-none tracking-tight" style="font-size: clamp(2.75rem, 5.5vw, 4rem);">
									{{ section.settings.stat_value }}
								</span>
							{%- endif -%}
							{%- if section.settings.stat_label != blank -%}
								<span class="font-heading font-semibold uppercase tracking-wide text-secondary leading-tight text-sm md:text-base">
									{{ section.settings.stat_label }}
								</span>
							{%- endif -%}
						</div>

						{%- if section.settings.stat_supporting != blank -%}
							<p class="mt-3 text-sm md:text-[0.95rem] text-secondary/75 leading-relaxed max-w-md">
								{{ section.settings.stat_supporting }}
							</p>
						{%- endif -%}

						{%- if section.settings.stat_footnote != blank -%}
							{%- if section.settings.stat_footnote_url != blank -%}
								<a
									href="{{ section.settings.stat_footnote_url }}"
									target="_blank"
									rel="noopener"
									class="inline-block mt-2 text-xs italic hover:underline"
									style="color: var(--color-tertiary-light);"
								>
									{{ section.settings.stat_footnote }}
								</a>
							{%- else -%}
								<p class="mt-2 text-xs italic" style="color: var(--color-tertiary-light);">
									{{ section.settings.stat_footnote }}
								</p>
							{%- endif -%}
						{%- endif -%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Benefits ── {%- endcomment -%}
				{%- if section.blocks.size > 0 -%}
					<ul class="flex flex-col gap-3 pt-1">
						{%- for block in section.blocks -%}
							{%- if block.type == 'benefit' -%}
								<li
									class="flex items-start gap-3 text-sm md:text-[0.95rem] text-secondary/85 leading-relaxed"
									{{ block.shopify_attributes }}
								>
									<span class="shrink-0 mt-0.5 text-highlight" aria-hidden="true">
										{%- if block.settings.icon != blank -%}
											<span class="text-base leading-none">{{ block.settings.icon }}</span>
										{%- else -%}
											<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
										{%- endif -%}
									</span>
									<span>{{ block.settings.text }}</span>
								</li>
							{%- endif -%}
						{%- endfor -%}
					</ul>
				{%- endif -%}

			</div>
		</div>
	</div>
</section>

<script>
(function () {
	var els = document.querySelectorAll('#performance-{{ section.id }} [data-animate]');
	if (!('IntersectionObserver' in window)) {
		els.forEach(function (el) { el.classList.remove('opacity-0', 'translate-y-6'); });
		return;
	}
	var observer = new IntersectionObserver(function (entries) {
		entries.forEach(function (entry) {
			if (!entry.isIntersecting) return;
			entry.target.classList.remove('opacity-0', 'translate-y-6');
			observer.unobserve(entry.target);
		});
	}, { threshold: 0.2 });
	els.forEach(function (el) { observer.observe(el); });
})();
</script>

{% schema %}
{
	"name": "Performance",
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "TRAIN"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Headline",
			"default": "More air. Less effort."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subhead",
			"default": "AIRA holds your nasal passages open so you breathe deeper through your nose — the way your body is built to work under load. More efficient airflow, less wasted energy, every session."
		},
		{
			"type": "header",
			"content": "CTA (optional)",
			"info": "Leave blank to rely on the page-level CTA."
		},
		{
			"type": "text",
			"id": "cta_label",
			"label": "CTA label"
		},
		{
			"type": "url",
			"id": "cta_url",
			"label": "CTA URL"
		},
		{
			"type": "header",
			"content": "Proof stat",
			"info": "Keep the qualifier attached — do not crop the number out of context."
		},
		{
			"type": "text",
			"id": "stat_value",
			"label": "Stat value",
			"default": "22%"
		},
		{
			"type": "text",
			"id": "stat_label",
			"label": "Stat label",
			"default": "More efficient breathing"
		},
		{
			"type": "textarea",
			"id": "stat_supporting",
			"label": "Supporting line",
			"default": "Recreational runners moved the same air with up to 22% less effort after switching to nasal breathing — with no drop in VO2max."
		},
		{
			"type": "text",
			"id": "stat_footnote",
			"label": "Footnote",
			"default": "Dallam et al., 2018"
		},
		{
			"type": "url",
			"id": "stat_footnote_url",
			"label": "Footnote URL"
		},
		{
			"type": "header",
			"content": "Images",
			"info": "Hero photography is gated — see brief §4 & §8. Do not ship a placeholder."
		},
		{
			"type": "image_picker",
			"id": "image_desktop",
			"label": "Image (desktop)",
			"info": "Shown on tablet & desktop (≥768px). Subject offset camera-right; dark third camera-left for copy."
		},
		{
			"type": "image_picker",
			"id": "image_mobile",
			"label": "Image (mobile)",
			"info": "Required separate crop for mobile (<768px). Keep face and AIRA strip visible."
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		}
	],
	"blocks": [
		{
			"type": "benefit",
			"name": "Benefit",
			"settings": [
				{
					"type": "text",
					"id": "icon",
					"label": "Icon",
					"info": "Emoji or symbol. Leave blank for a checkmark."
				},
				{
					"type": "text",
					"id": "text",
					"label": "Benefit line",
					"default": "Easier endurance — an open airway means less breathing effort on long, steady efforts."
				}
			]
		}
	],
	"max_blocks": 5,
	"presets": [
		{
			"name": "Performance",
			"blocks": [
				{
					"type": "benefit",
					"settings": {
						"icon": "",
						"text": "Easier endurance — an open airway means less breathing effort on long, steady efforts."
					}
				},
				{
					"type": "benefit",
					"settings": {
						"icon": "",
						"text": "Cleaner air in — your nose filters, warms and humidifies every breath. Your mouth doesn't."
					}
				},
				{
					"type": "benefit",
					"settings": {
						"icon": "",
						"text": "Calmer recovery — nasal breathing helps bring heart rate and breathing back down between efforts."
					}
				}
			]
		}
	]
}
{% endschema %}
