{%- comment -%}
	Contact — Fallback form (scaffold).
	Uses Shopify's built-in {% form 'contact' %} which routes to the
	store's order/contact email (Settings → Notifications). Replace with
	a Klaviyo embed later if/when Klaviyo flows are configured.
{%- endcomment -%}

<section class="bg-secondary py-16 md:py-24">
	<div class="container mx-auto px-4 max-w-[640px]">

		{%- if section.settings.heading != blank or section.settings.subheading != blank -%}
			<header class="text-center mb-10">
				{%- if section.settings.eyebrow != blank -%}
					<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
				{%- endif -%}
				{%- if section.settings.heading != blank -%}
					<h2 class="font-heading heading-weight text-3xl md:text-4xl text-title m-0">{{ section.settings.heading }}</h2>
				{%- endif -%}
				{%- if section.settings.subheading != blank -%}
					<p class="text-copy/80 text-base mt-3">{{ section.settings.subheading }}</p>
				{%- endif -%}
			</header>
		{%- endif -%}

		<div id="contact-form-mount">
			{%- form 'contact', id: 'contact-fallback-form', class: 'flex flex-col gap-5' -%}
				{%- if form.posted_successfully? -%}
					<div class="rounded-xl bg-bg p-5 text-sm text-copy">{{ section.settings.success_message | default: "Thanks for reaching out — we'll respond within one business day." }}</div>
				{%- endif -%}

				{%- if form.errors -%}
					<div class="rounded-xl bg-highlight/10 p-5 text-sm text-highlight">
						{{ form.errors | default_errors }}
					</div>
				{%- endif -%}

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-copy/70">Name</span>
					<input type="text" name="contact[name]" required autocomplete="name" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-copy/70">Email</span>
					<input type="email" name="contact[email]" required autocomplete="email" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-copy/70">Order number <span class="text-copy/50 normal-case font-normal">(optional)</span></span>
					<input type="text" name="contact[order_number]" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-copy/70">Subject</span>
					<input type="text" name="contact[subject]" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-copy/70">Message</span>
					<textarea name="contact[body]" rows="6" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main resize-y"></textarea>
				</label>

				{%- comment -%} Routes the email to the customer support address. {%- endcomment -%}
				{%- if settings.support_email != blank -%}
					<input type="hidden" name="contact[route_to]" value="{{ settings.support_email }}">
				{%- endif -%}

				<div class="pt-2">
					{%- render 'cta-button',
						label: 'Send message',
						element: 'button',
						button_type: 'submit',
						variant: 'primary',
						extra_classes: 'w-full md:w-auto text-center'
					-%}
				</div>
			{%- endform -%}
		</div>
	</div>
</section>

{% schema %}
{
	"name": "Contact - Form",
	"settings": [
		{ "type": "text",     "id": "eyebrow",         "label": "Eyebrow",        "default": "Or send us a message" },
		{ "type": "text",     "id": "heading",         "label": "Heading",        "default": "Prefer email?" },
		{ "type": "textarea", "id": "subheading",      "label": "Subheading",     "default": "Drop us a note and we'll get back within one business day." },
		{ "type": "textarea", "id": "success_message", "label": "Success message","default": "Thanks for reaching out — we'll respond within one business day." }
	],
	"presets": [{ "name": "Contact - Form" }]
}
{% endschema %}
