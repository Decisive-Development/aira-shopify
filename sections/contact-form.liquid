{%- comment -%}
	Contact — Message form.
	Uses Shopify's built-in {% form 'contact' %}, which emails submissions to
	the store's contact email (Settings → Notifications). No app required.
	Header uses the shared 'section-heading' snippet; submit uses 'cta-button'.
{%- endcomment -%}

<section class="bg-secondary py-16 md:py-24">
	<div class="container mx-auto px-4 max-w-[640px]">

		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div class="mb-10">
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      'center',
					size:       'sm',
					surface:    'light'
				-%}
			</div>
		{%- endif -%}

		<div id="contact-form-mount">
			{%- form 'contact', id: 'contact-fallback-form', class: 'flex flex-col gap-5' -%}
				{%- if form.posted_successfully? -%}
					<div class="rounded-xl bg-bg p-5 text-sm text-copy">{{ section.settings.success_message | default: "Thanks for reaching out. We'll respond within one business day." }}</div>
				{%- endif -%}

				{%- if form.errors -%}
					<div class="rounded-xl bg-highlight/10 p-5 text-sm text-highlight">
						{{ form.errors | default_errors }}
					</div>
				{%- endif -%}

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-title">Name</span>
					<input type="text" name="contact[name]" required autocomplete="name" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-title">Email</span>
					<input type="email" name="contact[email]" required autocomplete="email" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-title">Order number <span class="text-copy/50 normal-case font-normal">(optional)</span></span>
					<input type="text" name="contact[order_number]" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-title">Subject</span>
					<input type="text" name="contact[subject]" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
				</label>

				<label class="flex flex-col gap-1.5">
					<span class="text-xs font-semibold uppercase tracking-widest text-title">Message</span>
					<textarea name="contact[body]" rows="6" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main resize-y"></textarea>
				</label>

				<div class="pt-2 flex justify-center">
					{%- render 'cta-button',
						label: 'Send message',
						element: 'button',
						button_type: 'submit',
						variant: 'solid',
						extra_classes: 'w-full md:w-auto text-center'
					-%}
				</div>
			{%- endform -%}
		</div>

	</div>
</section>

{% schema %}
{
	"name": "Contact - Form",
	"settings": [
		{ "type": "text",     "id": "eyebrow",         "label": "Eyebrow",        "default": "Send a message" },
		{ "type": "text",     "id": "heading",         "label": "Heading",        "default": "How can we help?" },
		{ "type": "textarea", "id": "subheading",      "label": "Subheading",     "default": "Fill in the form and we'll reply within one business day." },
		{ "type": "textarea", "id": "success_message", "label": "Success message","default": "Thanks for reaching out. We'll respond within one business day." }
	],
	"presets": [{ "name": "Contact - Form" }]
}
{% endschema %}
