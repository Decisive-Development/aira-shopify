{%- liquid
	assign current_variant = product.selected_or_first_available_variant | default: product.variants.first
	assign has_selling_plans = false
	if product.selling_plan_groups.size > 0
		assign has_selling_plans = true
		assign sp_group = product.selling_plan_groups.first
		assign sp_first = sp_group.selling_plans.first
		assign sp_allocation = nil
		for alloc in current_variant.selling_plan_allocations
			if alloc.selling_plan.id == sp_first.id
				assign sp_allocation = alloc
				break
			endif
		endfor
	endif
-%}

<style>
	.plan-card {
		cursor: pointer;
		transition: border-color 0.3s ease, background-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
	}
	.plan-card:hover:not(.is-selected) {
		border-color: var(--color-main);
		background-color: var(--color-cream-light);
	}
	.plan-card.is-selected {
		border-color: var(--color-main);
		background-color: var(--color-cream-light);
		box-shadow: 0 0 0 1px var(--color-main), 0 4px 20px rgba(10,26,52,0.08);
	}
	.plan-card:not(.is-selected) {
		border-color: var(--color-border);
		background-color: #FFFFFF;
		box-shadow: none;
	}
	.plan-perks {
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		transition: max-height 0.35s ease, opacity 0.25s ease, margin-top 0.3s ease;
		margin-top: 0;
	}
	.plan-card.is-selected .plan-perks {
		max-height: 300px;
		opacity: 1;
		margin-top: 0;
		border-top: 1px solid var(--color-border);
		padding-top: 0.75rem;
	}

	/* Accordion content — bullet lists */
	.product-info-content ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}
	.product-info-content li {
		display: flex;
		align-items: flex-start;
		gap: 0.625rem;
	}
	.product-info-content li > img.bullet-icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		margin-top: 2px;
	}

	/* Step numbers in How to use — bold orange */
	.product-info-content li strong {
		font-weight: 700;
		color: var(--color-highlight, #FF4000);
	}

	/* Tutorial link below the How to use steps */
	.product-info-content ul + p {
		margin-top: 0.875rem;
	}
	.product-info-content a {
		font-weight: 600;
		color: var(--color-main);
		text-decoration: underline;
		text-underline-offset: 3px;
		transition: color 0.2s ease;
	}
	.product-info-content a:hover {
		color: var(--color-highlight);
	}
</style>


<section class="bg-bg pt-20 md:pt-24 pb-8 md:pb-12" data-product-section>
	<div class="container-contained">

		{%- comment -%} ══════ Buy box ══════ {%- endcomment -%}
		<div class="grid lg:grid-cols-2 gap-8 lg:gap-14">

			{%- comment -%} ── Left: Media gallery (sticky on desktop) ── {%- endcomment -%}
			{%- liquid
				assign media_items = product.media | slice: 0, 6
				assign media_count = media_items.size
			-%}
			<div class="flex flex-col gap-4 lg:sticky lg:top-24 lg:self-start">

				{%- comment -%} Main display — all items rendered, only one visible {%- endcomment -%}
				<div class="relative aspect-square rounded-2xl overflow-hidden bg-bg-muted" data-gallery>
					{%- if media_count > 0 -%}
						{%- for media in media_items -%}
							<div
								class="absolute inset-0 {% unless forloop.first %}hidden{% endunless %}"
								data-gallery-item="{{ forloop.index0 }}"
							>
								{%- case media.media_type -%}
									{%- when 'video' -%}
										<video
											class="w-full h-full object-cover"
											playsinline
											muted
											loop
											preload="metadata"
											{% if forloop.first %}autoplay{% endif %}
											{% if media.preview_image %}poster="{{ media.preview_image | image_url: width: 1200 }}"{% endif %}
										>
											{%- for source in media.sources -%}
												<source src="{{ source.url }}" type="{{ source.mime_type }}">
											{%- endfor -%}
										</video>
									{%- else -%}
										{{
											media
											| image_url: width: 1200
											| image_tag:
												loading: forloop.first | default: false,
												class: 'w-full h-full object-cover',
												widths: '400, 600, 800, 1200',
												sizes: '(min-width: 1024px) 50vw, 100vw',
												alt: media.alt
										}}
								{%- endcase -%}
							</div>
						{%- endfor -%}
					{%- elsif product.featured_image -%}
						{%- comment -%} Fallback for products with no media but a featured image {%- endcomment -%}
						<div class="absolute inset-0" data-gallery-item="0">
							{{
								product.featured_image
								| image_url: width: 1200
								| image_tag:
									loading: 'eager',
									class: 'w-full h-full object-cover',
									widths: '400, 600, 800, 1200',
									sizes: '(min-width: 1024px) 50vw, 100vw'
							}}
						</div>
					{%- endif -%}

					{%- if section.settings.image_badge != blank -%}
						<div class="absolute top-4 left-4 right-4 flex justify-center z-10">
							<span class="px-5 py-2 rounded-full bg-highlight text-white text-xs font-bold tracking-wide uppercase">
								{{ section.settings.image_badge }}
							</span>
						</div>
					{%- endif -%}
				</div>

				{%- comment -%} Thumbnail row {%- endcomment -%}
				<div class="grid grid-cols-6 gap-2">
					{%- for media in media_items -%}
						<button
							type="button"
							class="relative aspect-square rounded-lg overflow-hidden bg-bg-muted border-2 transition-colors cursor-pointer {% if forloop.first %}border-main{% else %}border-transparent hover:border-bg-muted{% endif %}"
							data-thumb-btn
							data-thumb-index="{{ forloop.index0 }}"
							aria-label="Show {{ media.media_type }} {{ forloop.index }}"
						>
							{%- if media.preview_image -%}
								{{
									media.preview_image
									| image_url: width: 200
									| image_tag:
										loading: 'lazy',
										class: 'w-full h-full object-cover',
										widths: '100, 200',
										alt: ''
								}}
							{%- endif -%}
							{%- if media.media_type == 'video' -%}
								<span class="absolute inset-0 flex items-center justify-center pointer-events-none bg-black/15">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white drop-shadow" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M8 5v14l11-7z"/>
									</svg>
								</span>
							{%- endif -%}
						</button>
					{%- endfor -%}
				</div>


			</div>

			{%- comment -%} ── Right: Product info + form ── {%- endcomment -%}
			<div class="flex flex-col gap-5">

				{%- comment -%} Guarantee badge — stars reclaim this slot once a review system goes live {%- endcomment -%}
				{%- if section.settings.pretitle_badge != blank -%}
					<span class="self-start inline-flex items-center gap-1.5 bg-main rounded-full px-3 py-1.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light shrink-0" aria-hidden="true"><path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
						<span class="font-heading font-semibold text-secondary text-xs leading-tight">{{ section.settings.pretitle_badge }}</span>
					</span>
				{%- endif -%}

				{%- comment -%} Title + description {%- endcomment -%}
				<div>
					<h1 class="font-heading heading-weight text-3xl md:text-4xl text-title leading-tight">{{ section.settings.hero_heading | default: product.title }}</h1>
					{%- if section.settings.product_subtitle != blank -%}
						<p class="text-copy text-base leading-relaxed mt-3 max-w-lg">{{ section.settings.product_subtitle }}</p>
					{%- elsif product.description != blank -%}
						<p class="text-copy text-base leading-relaxed mt-3 max-w-lg">{{ product.description }}</p>
					{%- endif -%}
				</div>

				<form action="{{ routes.cart_add_url }}" method="post" class="flex flex-col gap-5" data-product-form>
					<input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
					<input type="hidden" name="quantity" value="1">

					{%- comment -%} ── PLAN selector (real or preview) ── {%- endcomment -%}
					{%- if has_selling_plans -%}
						<input type="hidden" name="selling_plan" value="" data-selling-plan-input>
					{%- endif -%}

						<div class="flex flex-col gap-3" data-selling-plan-group>

						{%- comment -%} ── Subscription card ── {%- endcomment -%}
						<button
							type="button"
							class="plan-card relative flex flex-col gap-3 p-5 rounded-2xl border-2 border-border bg-bg text-left"
							data-plan-btn="subscribe"
						>
							{%- if section.settings.plan_badge != blank -%}
								<span class="absolute -top-3 left-4 px-3 py-1 rounded-full bg-main text-white text-xs font-bold">
									{{ section.settings.plan_badge }}
								</span>
							{%- endif -%}

							<div class="flex items-center justify-between gap-4">
								<div>
									<span class="font-heading font-bold text-title text-lg leading-tight block">{{ section.settings.plan_title | default: 'The aira kit + monthly refills' }}</span>
									{%- if has_selling_plans and sp_allocation -%}
										{%- assign save_amount = current_variant.price | minus: sp_allocation.per_delivery_price -%}
										{%- if save_amount > 0 -%}
											<p class="text-highlight text-sm font-bold mt-0.5" data-plan-save>Save {{ save_amount | money }} on refills</p>
										{%- endif -%}
									{%- elsif section.settings.plan_save_text != blank -%}
										<p class="text-highlight text-sm font-bold mt-0.5">{{ section.settings.plan_save_text }}</p>
									{%- endif -%}
								</div>
								<div class="text-right shrink-0">
									{%- if has_selling_plans and sp_allocation -%}
										<span class="text-copy text-sm line-through" data-plan-compare>{{ current_variant.price | money }}</span>
										<span class="font-heading font-bold text-title text-xl md:text-2xl block" data-subscribe-price>{{ sp_allocation.per_delivery_price | money }}</span>
									{%- else -%}
										{%- if section.settings.plan_compare_price != blank -%}
											<span class="text-copy text-sm line-through">{{ section.settings.plan_compare_price }}</span>
										{%- endif -%}
										<span class="font-heading font-bold text-title text-xl md:text-2xl block" data-subscribe-price>{{ section.settings.plan_price | default: current_variant.price | money }}</span>
									{%- endif -%}
								</div>
							</div>

							{%- comment -%} Plan perks checklist {%- endcomment -%}
							{%- assign perk_blocks = section.blocks | where: "type", "plan_perk" -%}
							{%- if perk_blocks.size > 0 -%}
								<ul class="plan-perks flex flex-col gap-2 mt-1">
									{%- for block in perk_blocks -%}
										<li class="flex items-start gap-2.5 text-sm text-copy" {{ block.shopify_attributes }}>
											<img
												src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
												alt=""
												class="w-4 h-4 shrink-0 mt-0.5"
												width="16"
												height="16"
												loading="lazy"
											>
											{{ block.settings.text }}
										</li>
									{%- endfor -%}
								</ul>
							{%- endif -%}
						</button>

						{%- comment -%} ── One-time purchase card (default selected) ── {%- endcomment -%}
						<button
							type="button"
							class="plan-card flex flex-col gap-3 p-5 rounded-2xl border-2 border-main bg-bg-soft text-left is-selected"
							data-plan-btn="onetime"
						>
							<div class="flex items-center justify-between gap-4">
								<span class="font-heading font-bold text-title text-lg leading-tight">One-time purchase</span>
								<span class="font-heading font-bold text-title text-xl md:text-2xl shrink-0" data-onetime-price>{{ current_variant.price | money }}</span>
							</div>
							<div class="h-px bg-border"></div>
							<ul class="flex flex-col gap-2">
								<li class="flex items-start gap-2.5 text-sm text-copy">
									<img
										src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
										alt=""
										class="w-4 h-4 shrink-0 mt-0.5"
										width="16"
										height="16"
										loading="lazy"
									>
									4 magnetic bands (L1 to L4)
								</li>
								<li class="flex items-start gap-2.5 text-sm text-copy">
									<img
										src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
										alt=""
										class="w-4 h-4 shrink-0 mt-0.5"
										width="16"
										height="16"
										loading="lazy"
									>
									15 adhesive tab pairs
								</li>
								<li class="flex items-start gap-2.5 text-sm text-copy">
									<img
										src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
										alt=""
										class="w-4 h-4 shrink-0 mt-0.5"
										width="16"
										height="16"
										loading="lazy"
									>
									Magnetic placement tool
								</li>
								<li class="flex items-start gap-2.5 text-sm text-copy">
									<img
										src="{{ 'aira-logo-only-dark.svg' | asset_url }}"
										alt=""
										class="w-4 h-4 shrink-0 mt-0.5"
										width="16"
										height="16"
										loading="lazy"
									>
									Instruction manual
								</li>
							</ul>
						</button>

					</div>

					{%- comment -%} ── Add to cart (cta-button solid/lg) ── {%- endcomment -%}
					{%- liquid
						assign atc_label = 'Sold out'
						assign atc_disabled = true
						if current_variant.available
							assign atc_label = 'Add to cart'
							assign atc_disabled = false
						endif
					-%}
					{%- render 'cta-button',
						label: atc_label,
						variant: 'shop',
						size: 'lg',
						element: 'button',
						button_type: 'submit',
						full_width: true,
						disabled: atc_disabled,
						attributes: 'data-add-to-cart',
						extra_classes: 'disabled:opacity-40 disabled:cursor-not-allowed'
					-%}

					{%- comment -%} ── Reassurance micro-copy ── {%- endcomment -%}
					<p class="text-xs text-title text-center">✓ Free shipping across the GCC.</p>

				</form>

				{%- comment -%} ── Refill link ── {%- endcomment -%}
				{%- if section.settings.refill_link_url != blank -%}
					<a
						href="{{ section.settings.refill_link_url }}"
						class="text-sm text-copy hover:text-highlight transition-colors"
					>
						{{ section.settings.refill_link_label | default: 'Already have a band? Get refills' }}
					</a>
				{%- endif -%}

				{%- comment -%} ── Trust badges ── {%- endcomment -%}
				{%- assign trust_blocks = section.blocks | where: "type", "trust_badge" -%}
				{%- if trust_blocks.size > 0 -%}
					<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
						{%- for block in trust_blocks -%}
							{%- capture badge_classes -%}flex flex-col items-center justify-center text-center gap-2 bg-main rounded-xl py-3 px-3 {% if trust_blocks.size == 3 and forloop.last %}col-span-2 md:col-span-1{% endif %}{%- endcapture -%}
							{%- capture badge_inner -%}
								{%- comment -%} Material Icons (filled) — inlined SVGs, no icon-font request {%- endcomment -%}
								{%- case block.settings.icon_type -%}
									{%- when 'research' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light" aria-hidden="true"><path d="M19.8 18.4 14 10.67V6.5l1.35-1.69c.26-.33.03-.81-.39-.81H9.04c-.42 0-.65.48-.39.81L10 6.5v4.17L4.2 18.4c-.49.66-.02 1.6.8 1.6h14c.82 0 1.29-.94.8-1.6z"/></svg>
									{%- when 'patented' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light" aria-hidden="true"><path d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.69 3.1 5.5l.34 3.7L1 12l2.44 2.79-.34 3.7 3.61.82L8.6 22.5l3.4-1.47 3.4 1.46 1.89-3.19 3.61-.82-.34-3.69L23 12zm-12.91 4.72l-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"/></svg>
									{%- when 'doctor' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light" aria-hidden="true"><path d="M17.73 12.02l3.98-3.98c.39-.39.39-1.02 0-1.41l-4.34-4.34c-.39-.39-1.02-.39-1.41 0l-3.98 3.98L8 2.29C7.8 2.1 7.55 2 7.29 2c-.25 0-.51.1-.7.29L2.25 6.63c-.39.39-.39 1.02 0 1.41l3.98 3.98-3.98 3.98c-.39.39-.39 1.02 0 1.41l4.34 4.34c.39.39 1.02.39 1.41 0l3.98-3.98 3.98 3.98c.2.2.45.29.71.29.26 0 .51-.1.71-.29l4.34-4.34c.39-.39.39-1.02 0-1.41l-3.99-3.98zM12 9c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-4.71 1.96L3.66 7.34l3.63-3.63 3.62 3.62-3.62 3.63zM10 13c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm2 2c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm2-4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2.66 9.34l-3.63-3.62 3.63-3.63 3.62 3.62-3.62 3.63z"/></svg>
									{%- when 'shield' -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light" aria-hidden="true"><path d="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
									{%- else -%}
										<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-tertiary-light" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
								{%- endcase -%}
								<span class="font-heading font-semibold text-secondary text-xs leading-tight">{{ block.settings.text }}</span>
							{%- endcapture -%}
							{%- if block.settings.link != blank -%}
								<a href="{{ block.settings.link }}" class="{{ badge_classes }} hover:opacity-80 transition-opacity" {{ block.shopify_attributes }}>{{ badge_inner }}</a>
							{%- else -%}
								<div class="{{ badge_classes }}" {{ block.shopify_attributes }}>{{ badge_inner }}</div>
							{%- endif -%}
						{%- endfor -%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Inline info accordions ── {%- endcomment -%}
				{%- assign faq_blocks = section.blocks | where: "type", "product_faq" -%}
				{%- if faq_blocks.size > 0 -%}
					<div class="flex flex-col gap-0 mt-2 [&>:last-child]:border-b-0">
						{%- for block in faq_blocks -%}
							<div class="border-b border-border" {{ block.shopify_attributes }}>
								<button
									type="button"
									class="group w-full flex items-center justify-between gap-4 py-4 text-left cursor-pointer"
									aria-expanded="false"
									data-faq-toggle
								>
									<span class="font-heading font-semibold text-title text-sm">{{ block.settings.question }}</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="shrink-0 text-copy transition-transform duration-200 group-aria-expanded:rotate-180">
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
									</svg>
								</button>
								<div class="overflow-hidden transition-all duration-300 product-info-content" style="max-height: 0;">
									<div class="pb-4 text-copy text-sm leading-relaxed">{{ block.settings.answer }}</div>
								</div>
							</div>
						{%- endfor -%}
					</div>
				{%- endif -%}

				{%- comment -%} ── Static FAQ pairs ── {%- endcomment -%}
				<div class="flex flex-col gap-4 pt-2">
					<div>
						<p class="font-heading font-semibold text-title text-sm">Will it help with my snoring?</p>
						<p class="text-copy text-sm leading-relaxed mt-1">Most snoring starts when your mouth falls open at night. The band keeps your nose open, your body switches back to nose breathing, and there is a lot less to hear.</p>
					</div>
					<div>
						<p class="font-heading font-semibold text-title text-sm">Does it fall off during sleep?</p>
						<p class="text-copy text-sm leading-relaxed mt-1">No. The tabs use 3M medical-grade adhesive, made to stay on skin for days, not hours. And the magnetic band clips onto the tabs instead of pulling on your skin, so nothing works it loose while you toss and turn. Fresh tabs each night, full strength every night.</p>
					</div>
				</div>

			</div>
		</div>

	</div>
</section>

{%- comment -%} ══════ Sticky mobile add-to-cart bar ══════ {%- endcomment -%}
<div
	class="fixed bottom-0 inset-x-0 z-40 bg-secondary px-4 py-3 flex items-center justify-between gap-4 lg:hidden translate-y-full transition-transform duration-300"
	data-sticky-bar
	style="box-shadow: 0 -4px 24px rgba(10,26,52,0.1);"
>
	<div class="flex flex-col min-w-0">
		<p class="font-heading font-semibold text-main text-sm truncate">{{ section.settings.hero_heading | default: product.title }}</p>
		<span class="font-heading font-bold text-main text-lg" data-sticky-price>{{ current_variant.price | money }}</span>
	</div>
	{%- liquid
		assign sticky_disabled = true
		if current_variant.available
			assign sticky_disabled = false
		endif
	-%}
	{%- render 'cta-button',
		label: 'Add to cart',
		variant: 'shop',
		element: 'button',
		disabled: sticky_disabled,
		attributes: 'data-sticky-atc',
		extra_classes: 'shrink-0 disabled:opacity-40 disabled:cursor-not-allowed'
	-%}
</div>

<script>
(function () {
	var section = document.querySelector('[data-product-section]');
	if (!section) return;

	/* ── Smooth scroll for review link ── */
	section.querySelectorAll('.scroll-link').forEach(function (link) {
		link.addEventListener('click', function (e) {
			var target = document.querySelector(link.getAttribute('href'));
			if (target) {
				e.preventDefault();
				target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		});
	});

	var sellingPlanInput = section.querySelector('[data-selling-plan-input]');
	var addBtn = section.querySelector('[data-add-to-cart]');
	var galleryItems = section.querySelectorAll('[data-gallery-item]');
	var thumbBtns = section.querySelectorAll('[data-thumb-btn]');
	var stickyBar = document.querySelector('[data-sticky-bar]');
	var stickyAtc = stickyBar ? stickyBar.querySelector('[data-sticky-atc]') : null;

	/* ── Variant data ── */
	var variantsJson = document.querySelector('[data-product-variants]');
	var variants = variantsJson ? JSON.parse(variantsJson.textContent) : [];

	/* ── Selling plan toggle ── */
	var planBtns = section.querySelectorAll('[data-plan-btn]');

	function setPlan(type) {
		planBtns.forEach(function (b) {
			var isThis = b.getAttribute('data-plan-btn') === type;
			if (isThis) {
				b.classList.add('is-selected');
			} else {
				b.classList.remove('is-selected');
			}
		});

		if (sellingPlanInput) {
			if (type === 'subscribe' && variants.length > 0) {
				var v = variants[0];
				if (v.selling_plan_allocations.length > 0) {
					sellingPlanInput.value = v.selling_plan_allocations[0].selling_plan_id;
				}
			} else {
				sellingPlanInput.value = '';
			}
		}
	}

	planBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			setPlan(btn.getAttribute('data-plan-btn'));
		});
	});

	/* ── Thumbnail gallery ── */
	thumbBtns.forEach(function (btn) {
		btn.addEventListener('click', function () {
			var idx = btn.getAttribute('data-thumb-index');
			if (idx === null) return;

			galleryItems.forEach(function (item) {
				var match = item.getAttribute('data-gallery-item') === idx;
				item.classList.toggle('hidden', !match);

				var video = item.querySelector('video');
				if (!video) return;
				if (match) {
					try { video.currentTime = 0; } catch (e) {}
					var p = video.play();
					if (p && typeof p.catch === 'function') p.catch(function () {});
				} else {
					video.pause();
				}
			});

			thumbBtns.forEach(function (b) {
				b.classList.remove('border-main');
				b.classList.add('border-transparent');
			});
			btn.classList.remove('border-transparent');
			btn.classList.add('border-main');
		});
	});

	/* ── Product FAQ accordion ── */
	var faqToggles = section.querySelectorAll('[data-faq-toggle]');
	faqToggles.forEach(function (btn) {
		btn.addEventListener('click', function () {
			var expanded = btn.getAttribute('aria-expanded') === 'true';
			var content = btn.nextElementSibling;
			btn.setAttribute('aria-expanded', !expanded);
			if (!expanded) {
				content.style.maxHeight = content.scrollHeight + 'px';
				content.addEventListener('transitionend', function handler() {
					content.style.maxHeight = 'none';
					content.removeEventListener('transitionend', handler);
				});
			} else {
				content.style.maxHeight = content.scrollHeight + 'px';
				requestAnimationFrame(function () {
					content.style.maxHeight = '0';
				});
			}
		});
	});

	/* ── Inject logo icons into accordion list items ── */
	var logoSrc = '{{ "aira-logo-only-dark.svg" | asset_url }}';
	section.querySelectorAll('.product-info-content li').forEach(function (li) {
		if (li.querySelector('strong')) return;
		var img = document.createElement('img');
		img.src = logoSrc;
		img.alt = '';
		img.className = 'bullet-icon';
		img.width = 16;
		img.height = 16;
		img.loading = 'lazy';
		li.insertBefore(img, li.firstChild);
	});

	/* ── Auto-open first accordion (Benefits) ── */
	if (faqToggles.length > 0) {
		var firstBtn = faqToggles[0];
		firstBtn.setAttribute('aria-expanded', 'true');
		firstBtn.nextElementSibling.style.maxHeight = 'none';
	}

	/* ── Sticky mobile bar ── */
	if (stickyBar && addBtn) {
		var observer = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (entry.isIntersecting) {
					stickyBar.classList.add('translate-y-full');
					stickyBar.classList.remove('translate-y-0');
				} else {
					stickyBar.classList.remove('translate-y-full');
					stickyBar.classList.add('translate-y-0');
				}
			});
		}, { threshold: 0 });

		observer.observe(addBtn);

		stickyAtc.addEventListener('click', function () {
			addBtn.click();
		});
	}
})();
</script>

{%- comment -%} ── Variant data for JS ── {%- endcomment -%}
<script type="application/json" data-product-variants>
	[
		{%- for variant in product.variants -%}
			{
				"id": {{ variant.id }},
				"options": {{ variant.options | json }},
				"price": {{ variant.price }},
				"price_formatted": {{ variant.price | money | json }},
				"compare_at_price": {{ variant.compare_at_price | default: 0 }},
				"compare_at_price_formatted": {% if variant.compare_at_price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
				"available": {{ variant.available | json }},
				"image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1200 | json }}{% else %}null{% endif %},
				"selling_plan_allocations": [
					{%- for alloc in variant.selling_plan_allocations -%}
						{
							"selling_plan_id": {{ alloc.selling_plan.id }},
							"per_delivery_price": {{ alloc.per_delivery_price }},
							"per_delivery_price_formatted": {{ alloc.per_delivery_price | money | json }},
							"name": {{ alloc.selling_plan.name | json }}
						}{%- unless forloop.last -%},{%- endunless -%}
					{%- endfor -%}
				]
			}{%- unless forloop.last -%},{%- endunless -%}
		{%- endfor -%}
	]
</script>

