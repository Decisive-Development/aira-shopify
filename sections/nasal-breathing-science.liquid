{%- comment -%}
	Backed by Science — Educational citation (Nestor, Breath, 2020).

	Replaces the placeholder "Reviewed by our medical advisor" slot until
	a real medical advisor is signed. This is educational citation only —
	NOT an endorsement. Section labels, microcopy, and image must not
	imply Nestor reviewed, endorses, or is affiliated with AIRA.

	Verify the quote text and the cite URL against the printed book before
	production deploy.
{%- endcomment -%}

{%- liquid
	assign bg_style = section.settings.background_style | default: 'navy'

	if bg_style == 'off_white'
		assign section_bg_class = 'bg-cream-light text-main'
		assign heading_color    = 'text-main'
		assign quote_color      = 'text-main'
		assign name_color       = 'text-highlight-blue'
		assign source_color     = 'text-copy'
		assign body_color       = 'text-copy'
		assign divider_color    = 'border-main/15'
		assign top_div_color    = 'bg-main/10'
		assign placeholder_bg   = 'bg-main/5 border-main/10'
	else
		assign section_bg_class = 'bg-main text-secondary'
		assign heading_color    = 'text-secondary'
		assign quote_color      = 'text-secondary'
		assign name_color       = 'text-tertiary-light'
		assign source_color     = 'text-secondary/75'
		assign body_color       = 'text-secondary/80'
		assign divider_color    = 'border-tertiary-light/25'
		assign top_div_color    = 'bg-tertiary-light/15'
		assign placeholder_bg   = 'bg-tertiary-light/5 border-tertiary-light/15'
	endif
-%}

<section class="relative overflow-hidden py-24 md:py-32 {{ section_bg_class }}">

	{%- if section.settings.show_top_divider -%}
		<div class="absolute top-0 inset-x-0 h-px {{ top_div_color }}"></div>
	{%- endif -%}

	{%- if bg_style == 'navy' -%}
		{%- comment -%} Light-blue radial halo behind the image (camera-left) {%- endcomment -%}
		<div
			class="absolute inset-0 pointer-events-none"
			style="background: radial-gradient(ellipse 50% 55% at 28% 50%, rgba(155,183,212,0.22), transparent 65%);"
		></div>
	{%- endif -%}

	<div class="container-contained relative z-10">
		<div class="max-w-[1100px] mx-auto">

			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight {{ heading_color }} text-3xl md:text-5xl leading-tight tracking-tight text-center max-w-[22ch] mx-auto mb-12 md:mb-16">
					{{ section.settings.heading }}
				</h2>
			{%- endif -%}

			<div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

				{%- comment -%} ── Image (left on desktop, top on mobile) ── {%- endcomment -%}
				<div>
					<div class="relative aspect-4/5 rounded-2xl overflow-hidden border {{ placeholder_bg }}">
						{%- if section.settings.image != blank -%}
							{{
								section.settings.image
								| image_url: width: 1000
								| image_tag:
									loading: 'lazy',
									class: 'absolute inset-0 w-full h-full object-cover',
									widths: '400, 600, 800, 1000',
									alt: section.settings.image_alt
							}}
						{%- else -%}
							<div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-tertiary-light opacity-80">
								<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" opacity="0.8" aria-hidden="true">
									<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
									<circle cx="8.5" cy="8.5" r="1.5"/>
									<polyline points="21 15 16 10 5 21"/>
								</svg>
								<div class="text-[10px] tracking-[0.22em] uppercase font-bold opacity-80">Image placeholder</div>
							</div>
						{%- endif -%}
					</div>
				</div>

				{%- comment -%} ── Copy (right on desktop, below image on mobile) ── {%- endcomment -%}
				<div>
					<figure class="m-0">

						<svg width="32" height="24" viewBox="0 0 32 24" fill="none" class="mb-4 opacity-50" aria-hidden="true">
							<path d="M0 24V14C0 5 5 0 14 0V6C9 6 7 8 7 14H14V24H0ZM18 24V14C18 5 23 0 32 0V6C27 6 25 8 25 14H32V24H18Z" fill="#9BB7D4"/>
						</svg>

						<blockquote
							{% if section.settings.quote_cite_url != blank %}cite="{{ section.settings.quote_cite_url }}"{% endif %}
							class="font-heading italic {{ quote_color }} text-2xl md:text-3xl lg:text-[2rem] leading-[1.4] m-0"
							style="font-weight: 400;"
						>
							{{ section.settings.quote }}
						</blockquote>

						<figcaption class="mt-6 pt-5 border-t {{ divider_color }}">
							{%- if section.settings.attribution_name != blank -%}
								<div class="font-heading text-base md:text-lg font-semibold {{ name_color }}">
									{{ section.settings.attribution_name }}
								</div>
							{%- endif -%}
							{%- if section.settings.attribution_source != blank -%}
								<cite class="block not-italic text-sm mt-1 {{ source_color }}">
									{{ section.settings.attribution_source }}
								</cite>
							{%- endif -%}
						</figcaption>

					</figure>

					{%- if section.settings.body != blank -%}
						<div class="mt-8 font-body text-base md:text-[17px] leading-[1.65] {{ body_color }}">
							{{ section.settings.body }}
						</div>
					{%- endif -%}
				</div>

			</div>
		</div>
	</div>
</section>

{% schema %}
{
	"name": "Science — Nestor citation",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Why the nose matters"
		},
		{
			"type": "richtext",
			"id": "quote",
			"label": "Quote",
			"info": "Wrapped in <blockquote>. Keep the quotation marks in the copy.",
			"default": "<p>\"Breathing is not just a biochemical or physical act; it's a force that has a profound effect on the way our bodies and minds function.\"</p>"
		},
		{
			"type": "text",
			"id": "attribution_name",
			"label": "Attribution — name",
			"default": "James Nestor"
		},
		{
			"type": "text",
			"id": "attribution_source",
			"label": "Attribution — source",
			"default": "Breath: The New Science of a Lost Art (2020)"
		},
		{
			"type": "url",
			"id": "quote_cite_url",
			"label": "Quote cite URL",
			"info": "Stable URL for the source (publisher product page or ISBN link). Becomes the cite=\"...\" attribute on the <blockquote>. Confirm before publishing."
		},
		{
			"type": "richtext",
			"id": "body",
			"label": "Body paragraph",
			"default": "<p>Nasal breathing increases nitric oxide production, filters and humidifies incoming air, and is consistently linked to deeper sleep, better recovery, and improved focus. The strip is engineered to keep that pathway open — mechanically, magnetically, all night.</p>"
		},
		{
			"type": "header",
			"content": "Image"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Image",
			"info": "Do NOT use a portrait of James Nestor — image rights are not cleared and pairing his face with the product implies endorsement we do not have."
		},
		{
			"type": "text",
			"id": "image_alt",
			"label": "Image alt text"
		},
		{
			"type": "header",
			"content": "Style"
		},
		{
			"type": "select",
			"id": "background_style",
			"label": "Background",
			"options": [
				{ "value": "navy",      "label": "Navy" },
				{ "value": "off_white", "label": "Off-white" }
			],
			"default": "navy"
		},
		{
			"type": "checkbox",
			"id": "show_top_divider",
			"label": "Show top divider",
			"default": false
		}
	],
	"presets": [
		{ "name": "Science — Nestor citation" }
	]
}
{% endschema %}
