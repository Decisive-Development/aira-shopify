{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-4 md:py-12'
		when 'md'
			assign py = 'py-8 md:py-20'
		when 'lg'
			assign py = 'py-12 md:py-32'
		when 'xl'
			assign py = 'py-16 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

<section
	id="faq-{{ section.id }}"
	style="background-color: {{ section.settings.background_color }};"
>
	<div class="{{ container_class }} {{ py }}">

		{%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
			<div
				class="mb-12 transition-all duration-700 ease-out opacity-0 translate-y-8"
				data-faq-animate
			>
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      'center',
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- if section.blocks.size > 0 -%}
			<div
				class="max-w-3xl mx-auto flex flex-col divide-y divide-bg-muted transition-all duration-700 ease-out opacity-0 translate-y-8"
				style="transition-delay: 100ms"
				data-faq-animate
			>
				{%- for block in section.blocks -%}
					<div class="faq-item" {{ block.shopify_attributes }}>
						<button
							class="w-full flex items-center justify-between gap-4 py-6 text-left cursor-pointer group"
							aria-expanded="false"
							data-faq-toggle
						>
							<span class="font-heading font-semibold text-title text-base md:text-lg leading-snug">
								{{ block.settings.question }}
							</span>
							<svg
								class="shrink-0 w-5 h-5 text-copy/50 transition-transform duration-300 group-aria-expanded:rotate-45"
								xmlns="http://www.w3.org/2000/svg"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
								stroke-width="2"
								aria-hidden="true"
							>
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
							</svg>
						</button>
						<div
							class="overflow-hidden transition-all duration-300 ease-out"
							style="max-height: 0;"
							data-faq-answer
						>
							<div class="pb-6 text-sm md:text-base leading-relaxed text-copy/80 max-w-2xl">
								{{ block.settings.answer }}
							</div>
						</div>
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

<script>
(function () {
	var section = document.querySelector('#faq-{{ section.id }}');
	if (!section) return;

	section.querySelectorAll('[data-faq-toggle]').forEach(function (btn) {
		btn.addEventListener('click', function () {
			var expanded = btn.getAttribute('aria-expanded') === 'true';
			var answer = btn.parentElement.querySelector('[data-faq-answer]');

			if (expanded) {
				answer.style.maxHeight = answer.scrollHeight + 'px';
				requestAnimationFrame(function () {
					answer.style.maxHeight = '0';
				});
				btn.setAttribute('aria-expanded', 'false');
			} else {
				answer.style.maxHeight = answer.scrollHeight + 'px';
				btn.setAttribute('aria-expanded', 'true');
				answer.addEventListener('transitionend', function handler() {
					if (btn.getAttribute('aria-expanded') === 'true') {
						answer.style.maxHeight = 'none';
					}
					answer.removeEventListener('transitionend', handler);
				});
			}
		});
	});

	if ('IntersectionObserver' in window) {
		var observer = new IntersectionObserver(function (entries) {
			entries.forEach(function (entry) {
				if (!entry.isIntersecting) return;
				entry.target.classList.remove('opacity-0', 'translate-y-8');
				observer.unobserve(entry.target);
			});
		}, { threshold: 0.15 });

		section.querySelectorAll('[data-faq-animate]').forEach(function (el) {
			observer.observe(el);
		});
	} else {
		section.querySelectorAll('[data-faq-animate]').forEach(function (el) {
			el.classList.remove('opacity-0', 'translate-y-8');
		});
	}
})();
</script>

{% schema %}
{
	"name": "FAQ",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "FAQ"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Frequently asked questions"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading"
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FAFAFA"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"blocks": [
		{
			"type": "question",
			"name": "Question",
			"settings": [
				{
					"type": "text",
					"id": "question",
					"label": "Question",
					"default": "How does it work?"
				},
				{
					"type": "richtext",
					"id": "answer",
					"label": "Answer",
					"default": "<p>Answer goes here.</p>"
				}
			]
		}
	],
	"presets": [
		{
			"name": "FAQ",
			"blocks": [
				{
					"type": "question",
					"settings": {
						"question": "How does it work?",
						"answer": "<p>Answer goes here.</p>"
					}
				},
				{
					"type": "question",
					"settings": {
						"question": "Is it comfortable?",
						"answer": "<p>Answer goes here.</p>"
					}
				},
				{
					"type": "question",
					"settings": {
						"question": "How long does it last?",
						"answer": "<p>Answer goes here.</p>"
					}
				}
			]
		}
	]
}
{% endschema %}
