{%- comment -%}
	FAQ — Client-side search (scaffold, optional per design brief).
	Filters question/answer pairs in the categorized FAQ section beneath
	this one. No backend, no Shopify search call — pure DOM filter so it
	stays instant and indexable.

	Targets: any element with [data-faq-search-target] within the same
	page, matching against [data-faq-search-text].
{%- endcomment -%}

<section class="bg-bg pt-12 pb-4">
	<div class="container mx-auto px-4 max-w-2xl">
		<label class="flex items-center gap-3 rounded-xl bg-secondary px-5 py-4 border border-main/10 focus-within:border-main transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-copy/50 shrink-0">
				<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M16.5 10.5a6 6 0 1 1-12 0 6 6 0 0 1 12 0z"/>
			</svg>
			<input
				type="search"
				placeholder="{{ section.settings.placeholder | default: 'Search the FAQ…' }}"
				class="flex-1 bg-transparent text-sm text-main focus:outline-none placeholder:text-copy/50"
				data-faq-search-input
				aria-label="Search the FAQ"
			>
			<span class="text-xs text-copy/50" data-faq-search-empty hidden>No matches</span>
		</label>
	</div>
</section>

<script>
	(function () {
		var input = document.querySelector('[data-faq-search-input]');
		if (!input) return;

		function normalise(s) {
			return (s || '').toString().toLowerCase();
		}

		input.addEventListener('input', function () {
			var q       = normalise(input.value).trim();
			var targets = document.querySelectorAll('[data-faq-search-target]');
			var anyHit  = false;

			targets.forEach(function (el) {
				var text  = normalise(el.getAttribute('data-faq-search-text') || el.textContent);
				var match = q === '' || text.indexOf(q) !== -1;
				el.hidden = !match;
				if (match) anyHit = true;
			});

			// Hide empty category groups too.
			document.querySelectorAll('[data-faq-search-group]').forEach(function (group) {
				var visible = group.querySelectorAll('[data-faq-search-target]:not([hidden])');
				group.hidden = visible.length === 0;
			});

			var emptyEl = document.querySelector('[data-faq-search-empty]');
			if (emptyEl) emptyEl.hidden = anyHit || q === '';
		});
	})();
</script>

{% schema %}
{
	"name": "FAQ - Search",
	"settings": [
		{ "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Search the FAQ…" }
	],
	"presets": [{ "name": "FAQ - Search" }]
}
{% endschema %}
