{%- liquid
	case section.settings.padding_vertical
		when 'none'
			assign pt = ''
			assign pb = ''
		when 'sm'
			assign pt = 'pt-8 md:pt-12'
			assign pb = 'pb-8 md:pb-12'
		when 'md'
			assign pt = 'pt-16 md:pt-20'
			assign pb = 'pb-16 md:pb-20'
		when 'lg'
			assign pt = 'pt-24 md:pt-32'
			assign pb = 'pb-24 md:pb-32'
	endcase

	assign review_product = section.settings.product
-%}

<section
	style="background-color: {{ section.settings.background_color }};"
>
	<div class="container-contained {{ pt }} {{ pb }}">

		{%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
			<div class="mb-10 md:mb-14">
				{%- render 'section-heading',
					eyebrow:    section.settings.eyebrow,
					heading:    section.settings.heading,
					subheading: section.settings.subheading,
					align:      'center',
					size:       section.settings.heading_size
				-%}
			</div>
		{%- endif -%}

		{%- if review_product != blank -%}
			{%- assign has_legacy = false -%}
			{%- if review_product.metafields.judgeme.widget.size > 20 -%}
				{%- assign has_legacy = true -%}
			{%- endif -%}

			<div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget'
				data-product-title='{{ review_product.title | escape }}'
				data-id='{{ review_product.id }}'
				data-product-id='{{ review_product.id }}'
				data-widget='review'
				data-auto-install='false'
				data-shop-reviews-count='{{ shop.metafields.judgeme.shop_reviews_count | default: 0 | escape }}'
				data-entry-point='review_widget.js'
				data-entry-key='review-widget/main.js'>
				{%- if has_legacy -%}
					<div class='jdgm-legacy-widget-content' style='display: none;'>{{ review_product.metafields.judgeme.widget }}</div>
				{%- endif -%}
			</div>

			{%- if review_product.metafields.judgeme.review_widget_data -%}
				<script>jdgm.data ||= {}; jdgm.data.reviewWidget ||= {}; jdgm.data.reviewWidget[{{ review_product.id }}] = {{ review_product.metafields.judgeme.review_widget_data }}</script>
			{%- endif -%}
		{%- else -%}
			<p style="text-align:center; color: #9ca3af; font-family: var(--font-body, sans-serif);">Select a product in the section settings to display reviews.</p>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "Reviews (Judge.me)",
	"settings": [
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "What our customers say"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Real results. Real people."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading"
		},
		{
			"type": "select",
			"id": "heading_size",
			"label": "Heading size",
			"options": [
				{ "value": "sm", "label": "Small" },
				{ "value": "md", "label": "Medium" },
				{ "value": "lg", "label": "Large" }
			],
			"default": "md"
		},
		{
			"type": "header",
			"content": "Product"
		},
		{
			"type": "product",
			"id": "product",
			"label": "Product to show reviews for"
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#FFFFFF"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" }
			],
			"default": "lg"
		}
	],
	"presets": [
		{
			"name": "Reviews (Judge.me)"
		}
	]
}
{% endschema %}
