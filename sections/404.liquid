{%- comment -%}
	404 — page not found.  ("This page is fast asleep.")

	Used by templates/404.json (section type "404") for any invalid store URL.
	Reference: design_handoff_404/designs/Aira 404.html (hifi, locked).

	On-brand night-sky treatment shared with Hero / Science — Hero: navy
	gradient + tiled starfield. Three fun touches over the base 404:
	  1. The middle "0" of 404 is a sleeping moon-face (closed eyes, smile,
	     rosy cheeks) with snoring Zzz's drifting off it.
	  2. Sleep/breathing copy that turns a dead end into a calm moment.
	  3. An optional interactive breathing orb (tap for a guided In/Hold/Out
	     cycle) — progressive enhancement, works idle without JS.

	The giant numeral (moon-face + Zzz) is decorative (aria-hidden); the <h1>
	carries the message. Copy + button URLs are schema-driven. All motion is
	gated behind prefers-reduced-motion; the breathe/twinkle scale is part of
	the signed-off brief and only runs on user tap.

	https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{%- endcomment -%}

{%- liquid
	assign home_url = section.settings.secondary_button_url | default: routes.root_url
	assign shop_url = section.settings.button_url | default: '/products/aira-kit'
-%}

<section id="fof-{{ section.id }}" class="fof relative overflow-hidden min-h-svh flex items-center justify-center px-6 py-10">

	{%- comment -%} Decorative starfield + twinkles — behind everything. {%- endcomment -%}
	<div class="fof__stars" aria-hidden="true"></div>
	<span class="fof__twinkle t1" aria-hidden="true"></span>
	<span class="fof__twinkle t2" aria-hidden="true"></span>
	<span class="fof__twinkle t3" aria-hidden="true"></span>

	<div class="relative z-5 text-center max-w-[640px] mx-auto">

		{%- if section.settings.eyebrow != blank -%}
			<p class="fof__eyebrow">{{ section.settings.eyebrow }}</p>
		{%- endif -%}

		{%- comment -%} Giant numeral — purely visual; the real heading carries the message. {%- endcomment -%}
		<div class="fof__numeral" aria-hidden="true">
			<span class="fof__drift">4</span>
			<span class="fof__zero">
				<span class="fof__face">
					<span class="fof__eye l"></span>
					<span class="fof__eye r"></span>
					<span class="fof__cheek l"></span>
					<span class="fof__cheek r"></span>
					<span class="fof__mouth"></span>
				</span>
				<span class="fof__zzz"><span class="z1">z</span><span class="z2">z</span><span class="z3">Z</span></span>
			</span>
			<span class="fof__drift" style="animation-delay: 1.2s">4</span>
		</div>

		{%- if section.settings.heading != blank -%}
			<h1 class="fof__heading">{{ section.settings.heading }}</h1>
		{%- endif -%}

		{%- if section.settings.subheading != blank -%}
			<p class="fof__sub">{{ section.settings.subheading }}</p>
		{%- endif -%}

		{%- if section.settings.breather_enabled -%}
			<div class="fof__breather" data-breather>
				<button
					type="button"
					class="fof__orb-btn"
					data-orb
					aria-pressed="false"
					aria-label="{{ section.settings.breather_aria | default: 'Start a breathing exercise' | escape }}"
				>
					<span class="fof__orb">
						<span class="fof__orb-label" data-orb-label>{{ section.settings.breather_label | default: 'Breathe' }}</span>
					</span>
				</button>
				<p class="fof__breath-caption" data-orb-caption aria-live="polite">
					{{- section.settings.breather_caption | default: 'Tap the orb & follow along' -}}
				</p>
			</div>
		{%- endif -%}

		{%- if section.settings.button_label != blank or section.settings.secondary_button_label != blank -%}
			<div class="flex flex-wrap items-center justify-center gap-4 mt-8">
				{%- if section.settings.button_label != blank -%}
					{%- render 'cta-button',
						label: section.settings.button_label,
						url: shop_url,
						variant: 'shop',
						size: 'lg'
					-%}
				{%- endif -%}

				{%- if section.settings.secondary_button_label != blank -%}
					{%- render 'cta-button',
						label: section.settings.secondary_button_label,
						url: home_url,
						variant: 'outline',
						surface: 'dark',
						size: 'lg'
					-%}
				{%- endif -%}
			</div>
		{%- endif -%}

	</div>
</section>

<style>
	/* Night-sky background — identical recipe to Hero / Science — Hero. */
	.fof {
		background:
			radial-gradient(ellipse 75% 55% at 50% 26%, rgba(155, 183, 212, 0.20) 0%, rgba(10, 26, 52, 0) 65%),
			radial-gradient(ellipse 110% 80% at 50% 116%, rgba(184, 68, 0, 0.10) 0%, rgba(10, 26, 52, 0) 60%),
			linear-gradient(180deg, #0A1A34 0%, #0d2247 50%, #0A1A34 100%);
		color: var(--color-secondary);
	}

	.fof__stars {
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0.7;
		background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1440 900' fill='%23F1EBE1'><circle cx='90' cy='120' r='1.4' opacity='0.7'/><circle cx='230' cy='70' r='1' opacity='0.5'/><circle cx='360' cy='180' r='1.8' opacity='0.85'/><circle cx='520' cy='90' r='1' opacity='0.45'/><circle cx='640' cy='220' r='1.3' opacity='0.6'/><circle cx='780' cy='60' r='1.6' opacity='0.8'/><circle cx='910' cy='160' r='1' opacity='0.5'/><circle cx='1050' cy='100' r='1.5' opacity='0.7'/><circle cx='1180' cy='200' r='1.1' opacity='0.55'/><circle cx='1320' cy='80' r='1.7' opacity='0.85'/><circle cx='150' cy='340' r='1.2' opacity='0.6'/><circle cx='430' cy='400' r='1' opacity='0.45'/><circle cx='700' cy='360' r='1.6' opacity='0.75'/><circle cx='980' cy='420' r='1.1' opacity='0.55'/><circle cx='1240' cy='350' r='1.4' opacity='0.7'/><circle cx='80' cy='560' r='1.5' opacity='0.7'/><circle cx='330' cy='620' r='1' opacity='0.45'/><circle cx='590' cy='580' r='1.3' opacity='0.6'/><circle cx='860' cy='640' r='1.7' opacity='0.8'/><circle cx='1120' cy='560' r='1' opacity='0.5'/><circle cx='1360' cy='620' r='1.4' opacity='0.7'/><circle cx='200' cy='790' r='1.2' opacity='0.55'/><circle cx='500' cy='820' r='1.6' opacity='0.75'/><circle cx='820' cy='800' r='1' opacity='0.45'/><circle cx='1080' cy='840' r='1.3' opacity='0.6'/><circle cx='1300' cy='800' r='1.5' opacity='0.7'/></svg>");
		background-size: cover;
		background-position: center;
	}

	/* Twinkles — 4-point sparkles, slow staggered pulse. */
	.fof__twinkle {
		position: absolute;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-secondary);
		opacity: 0.8;
		pointer-events: none;
		animation: fof-tw 4s ease-in-out infinite;
		-webkit-mask: radial-gradient(circle, #000 0%, transparent 70%);
		mask: radial-gradient(circle, #000 0%, transparent 70%);
	}
	.fof__twinkle::before,
	.fof__twinkle::after {
		content: "";
		position: absolute;
		background: var(--color-secondary);
	}
	.fof__twinkle::before { width: 100%; height: 300%; left: 0; top: -100%; }
	.fof__twinkle::after  { width: 300%; height: 100%; top: 0; left: -100%; }
	.fof__twinkle.t1 { top: 22%; left: 18%;  animation-delay: 0.4s; }
	.fof__twinkle.t2 { top: 30%; right: 16%; animation-delay: 1.8s; }
	.fof__twinkle.t3 { bottom: 26%; left: 24%; animation-delay: 3s; }
	@keyframes fof-tw {
		0%, 100% { opacity: 0.15; transform: scale(0.7); }
		50%      { opacity: 0.9;  transform: scale(1); }
	}

	/* Sleepy 404 numeral. */
	.fof__numeral {
		position: relative;
		font-family: var(--font-heading);
		font-weight: 400;
		font-size: clamp(110px, 24vw, 230px);
		line-height: 0.9;
		letter-spacing: -0.03em;
		color: var(--color-secondary);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.02em;
		user-select: none;
	}
	.fof__drift {
		display: inline-block;
		animation: fof-drift 7s ease-in-out infinite;
		will-change: transform;
	}
	@keyframes fof-drift {
		0%, 100% { transform: translateY(0); }
		50%      { transform: translateY(-12px); }
	}

	/* The sleeping "0" — a lit moon-face. */
	.fof__zero {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 0.86em;
		height: 0.86em;
		margin: 0 0.02em;
		border-radius: 50%;
		/* #fffaf2 / #d8cdb9 = moon highlight + shadow; no token exists for these. */
		background: radial-gradient(circle at 38% 34%, #fffaf2 0%, var(--color-secondary) 42%, #d8cdb9 100%);
		box-shadow:
			0 0 50px color-mix(in srgb, var(--color-tertiary-light) 45%, transparent),
			inset -12px -10px 28px color-mix(in srgb, var(--color-main) 18%, transparent);
		color: var(--color-main);
		animation: fof-drift 7s ease-in-out infinite;
		animation-delay: 0.6s;
	}
	.fof__face { position: absolute; inset: 0; }
	.fof__eye {
		position: absolute;
		top: 42%;
		width: 0.13em;
		height: 0.07em;
		border: 0.028em solid var(--color-main);
		border-bottom: none;
		border-radius: 0.13em 0.13em 0 0;
		transform: rotate(180deg);
	}
	.fof__eye.l { left: 28%; }
	.fof__eye.r { right: 28%; }
	.fof__mouth {
		position: absolute;
		left: 50%;
		top: 58%;
		transform: translateX(-50%);
		width: 0.14em;
		height: 0.08em;
		border: 0.026em solid var(--color-main);
		border-top: none;
		border-radius: 0 0 0.14em 0.14em;
	}
	.fof__cheek {
		position: absolute;
		top: 53%;
		width: 0.075em;
		height: 0.045em;
		border-radius: 50%;
		background: color-mix(in srgb, var(--color-highlight) 35%, transparent);
	}
	.fof__cheek.l { left: 20%; }
	.fof__cheek.r { right: 20%; }

	/* Snoring Z's drifting up off the moon. */
	.fof__zzz { position: absolute; top: -0.1em; right: -0.05em; pointer-events: none; }
	.fof__zzz span {
		position: absolute;
		font-family: var(--font-heading);
		font-weight: 700;
		color: var(--color-tertiary-light);
		opacity: 0;
	}
	.fof__zzz .z1 { font-size: 0.16em; animation: fof-floatz 3.4s ease-in-out infinite; }
	.fof__zzz .z2 { font-size: 0.2em;  left: 0.18em; animation: fof-floatz 3.4s ease-in-out infinite 0.9s; }
	.fof__zzz .z3 { font-size: 0.26em; left: 0.42em; animation: fof-floatz 3.4s ease-in-out infinite 1.8s; }
	@keyframes fof-floatz {
		0%   { opacity: 0;    transform: translate(0, 0.2em) rotate(-6deg) scale(0.7); }
		25%  { opacity: 0.95; }
		100% { opacity: 0;    transform: translate(0.5em, -1.1em) rotate(8deg) scale(1.1); }
	}

	.fof__heading {
		font-family: var(--font-heading);
		font-weight: 400;
		letter-spacing: -0.02em;
		font-size: clamp(26px, 4vw, 40px);
		line-height: 1.08;
		margin-top: 14px;
		color: var(--color-secondary);
	}
	.fof__sub {
		font-family: var(--font-body);
		font-size: clamp(15px, 2vw, 18px);
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-secondary) 82%, transparent);
		max-width: 440px;
		margin: 16px auto 0;
	}

	/* Breathing orb. */
	.fof__breather {
		margin: 30px auto 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
	}
	.fof__orb-btn {
		appearance: none;
		border: none;
		background: none;
		cursor: pointer;
		padding: 0;
		position: relative;
		width: 92px;
		height: 92px;
	}
	.fof__orb {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		background: radial-gradient(circle at 40% 35%,
			color-mix(in srgb, var(--color-tertiary-light) 55%, transparent),
			color-mix(in srgb, var(--color-tertiary-light) 6%, transparent) 70%);
		border: 1.5px solid color-mix(in srgb, var(--color-tertiary-light) 50%, transparent);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.2s ease;
	}
	.fof__orb-label {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-secondary);
	}
	.fof__orb-btn:hover .fof__orb { transform: scale(1.04); }
	.fof__orb-btn:focus-visible { outline: 2px solid var(--color-tertiary-light); outline-offset: 6px; border-radius: 50%; }

	/* Running cycle — toggled by JS. */
	.fof__breather.is-breathing .fof__orb {
		animation: fof-breathe 8s ease-in-out infinite;
		border-color: color-mix(in srgb, var(--color-tertiary-light) 90%, transparent);
	}
	@keyframes fof-breathe {
		0%   { transform: scale(0.8);  box-shadow: 0 0 0 0 transparent; }
		45%  { transform: scale(1.35); box-shadow: 0 0 60px 10px color-mix(in srgb, var(--color-tertiary-light) 25%, transparent); }
		55%  { transform: scale(1.35); }
		100% { transform: scale(0.8);  box-shadow: 0 0 0 0 transparent; }
	}
	.fof__breath-caption {
		font-family: var(--font-heading);
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: color-mix(in srgb, var(--color-secondary) 55%, transparent);
		min-height: 18px;
		transition: color 0.3s ease;
	}
	.fof__breath-caption.is-inhale { color: var(--color-tertiary-light); }

	@media (prefers-reduced-motion: reduce) {
		.fof__drift,
		.fof__zero,
		.fof__zzz span,
		.fof__twinkle,
		.fof__breather.is-breathing .fof__orb {
			animation: none !important;
		}
		.fof__zzz span { opacity: 0.7; }
	}
</style>

<script>
	(function () {
		var root = document.getElementById('fof-{{ section.id }}');
		if (!root) return;
		var btn = root.querySelector('[data-orb]');
		if (!btn) return; // breather disabled in settings

		var breather = root.querySelector('[data-breather]');
		var label = root.querySelector('[data-orb-label]');
		var caption = root.querySelector('[data-orb-caption]');
		var idleLabel = label.textContent;
		var idleCaption = caption.textContent;
		var running = false;
		var timer = null, holdT = null, outT = null;
		var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		// 8s cycle: 0–3.6s inhale, 3.6–4.4 hold, 4.4–8 exhale.
		function cycle() {
			label.textContent = 'In…';
			caption.textContent = 'Breathe in through your nose';
			caption.classList.add('is-inhale');
			holdT = setTimeout(function () {
				if (!running) return;
				label.textContent = 'Hold';
				caption.textContent = 'Hold it…';
			}, 3600);
			outT = setTimeout(function () {
				if (!running) return;
				label.textContent = 'Out…';
				caption.textContent = 'Slowly let it go';
				caption.classList.remove('is-inhale');
			}, 4400);
		}

		function start() {
			running = true;
			breather.classList.add('is-breathing');
			btn.setAttribute('aria-pressed', 'true');
			if (reduce) {
				label.textContent = idleLabel;
				caption.textContent = 'Inhale 4 · hold 1 · exhale 4';
				return;
			}
			cycle();
			timer = setInterval(cycle, 8000);
		}

		function stop() {
			running = false;
			breather.classList.remove('is-breathing');
			btn.setAttribute('aria-pressed', 'false');
			clearInterval(timer);
			clearTimeout(holdT);
			clearTimeout(outT);
			label.textContent = idleLabel;
			caption.textContent = 'Nice. Feel a little less lost?';
			caption.classList.remove('is-inhale');
		}

		btn.addEventListener('click', function () {
			running ? stop() : start();
		});
	})();
</script>

{% schema %}
{
	"name": "404 page",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Error 404 · shhh"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "This page is fast asleep."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "It dozed off, wandered into a dream, or never existed at all. While it naps, why not take a breath with us?"
		},
		{
			"type": "header",
			"content": "Breathing orb"
		},
		{
			"type": "checkbox",
			"id": "breather_enabled",
			"label": "Show breathing orb",
			"default": true
		},
		{
			"type": "text",
			"id": "breather_label",
			"label": "Orb label",
			"default": "Breathe"
		},
		{
			"type": "text",
			"id": "breather_caption",
			"label": "Orb caption",
			"default": "Tap the orb & follow along"
		},
		{
			"type": "text",
			"id": "breather_aria",
			"label": "Orb accessible label",
			"info": "Read by screen readers in place of the orb icon.",
			"default": "Start a breathing exercise"
		},
		{
			"type": "header",
			"content": "Buttons"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Primary button label",
			"default": "Get my kit"
		},
		{
			"type": "url",
			"id": "button_url",
			"label": "Primary button URL",
			"info": "Defaults to the kit product page (/products/aira-kit) if left blank."
		},
		{
			"type": "text",
			"id": "secondary_button_label",
			"label": "Secondary button label",
			"default": "Back to home"
		},
		{
			"type": "url",
			"id": "secondary_button_url",
			"label": "Secondary button URL",
			"info": "Defaults to the homepage if left blank."
		}
	]
}
{% endschema %}
