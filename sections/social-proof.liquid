{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif
-%}

<section
	class="relative overflow-hidden w-full"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>

	{%- comment -%} Background image {%- endcomment -%}
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400',
					draggable: 'false'
			}}
		</div>
	{%- endif -%}

	{%- comment -%} Darken layer {%- endcomment -%}
	<div class="absolute inset-0 bg-black/35 pointer-events-none"></div>

	{%- comment -%} Vignette overlay — darkens edges {%- endcomment -%}
	<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 40%, rgba(0,0,0,0.75) 100%);"></div>

	{%- comment -%} Content {%- endcomment -%}
	<div class="relative z-10 w-full pt-12 md:pt-16 pb-16 md:pb-36">

		{%- comment -%} Centered heading {%- endcomment -%}
		<div class="container-contained text-center mb-10 md:mb-24">
			{%- if section.settings.eyebrow != blank -%}
				<p
					class="text-xs font-body font-semibold uppercase tracking-widest text-highlight mb-3 md:mb-4 transition-all duration-700 ease-out opacity-0 translate-y-6"
					data-sp-animate
				>
					{{- section.settings.eyebrow -}}
				</p>
			{%- endif -%}

			{%- if section.settings.heading != blank -%}
				<h2
					class="font-heading heading-weight text-white text-2xl md:text-4xl lg:text-5xl leading-tight transition-all duration-700 ease-out opacity-0 translate-y-6"
					style="transition-delay: 80ms"
					data-sp-animate
				>
					{{- section.settings.heading -}}
				</h2>
			{%- endif -%}

			{%- if section.settings.subheading != blank -%}
				<p
					class="font-body text-white/70 text-sm md:text-lg leading-relaxed max-w-2xl mx-auto mt-3 md:mt-5 hidden md:block transition-all duration-700 ease-out opacity-0 translate-y-6"
					style="transition-delay: 160ms"
					data-sp-animate
				>
					{{- section.settings.subheading -}}
				</p>
			{%- endif -%}
		</div>

		{%- comment -%} ═══ MOBILE layout (< lg) ═══ {%- endcomment -%}
		<div class="lg:hidden px-5">

			{%- comment -%} Column headings row {%- endcomment -%}
			<div class="grid grid-cols-2 gap-4 mb-4">
				<p class="font-heading font-bold text-highlight text-xs uppercase tracking-widest">
					{{- section.settings.left_heading | default: 'The problem' -}}
				</p>
				<p class="font-heading font-bold text-xs uppercase tracking-widest text-right" style="color: #4ADE80;">
					{{- section.settings.right_heading | default: 'With better breathing' -}}
				</p>
			</div>

			{%- comment -%} Paired rows — problems on left, benefits on right {%- endcomment -%}
			{%- assign problem_count = 0 -%}
			{%- assign benefit_count = 0 -%}
			{%- for block in section.blocks -%}
				{%- if block.type == 'problem' -%}
					{%- assign problem_count = problem_count | plus: 1 -%}
				{%- endif -%}
				{%- if block.type == 'benefit' -%}
					{%- assign benefit_count = benefit_count | plus: 1 -%}
				{%- endif -%}
			{%- endfor -%}
			{%- assign max_rows = problem_count -%}
			{%- if benefit_count > max_rows -%}
				{%- assign max_rows = benefit_count -%}
			{%- endif -%}

			{%- assign p_i = 0 -%}
			{%- assign b_i = 0 -%}
			{%- for row in (1..max_rows) -%}

				{%- comment -%} Find the nth problem and benefit {%- endcomment -%}
				{%- assign p_found = false -%}
				{%- assign b_found = false -%}
				{%- assign p_counter = 0 -%}
				{%- assign b_counter = 0 -%}

				<div class="grid grid-cols-2 gap-4 py-3 {% unless forloop.last %}border-b border-white/10{% endunless %}">

					{%- comment -%} Problem cell {%- endcomment -%}
					{%- for block in section.blocks -%}
						{%- if block.type == 'problem' -%}
							{%- if p_counter == p_i and p_found == false -%}
								{%- assign p_found = true -%}
								<div class="flex flex-col gap-0.5">
									<span class="font-heading font-bold text-highlight leading-none" style="font-size: clamp(1.5rem, 6vw, 2rem);">
										{{- block.settings.value -}}
									</span>
									{%- if block.settings.keyword != blank -%}
										<p class="font-heading font-bold text-white text-sm uppercase tracking-wide leading-tight mt-1">
											{{- block.settings.keyword -}}
										</p>
									{%- endif -%}
									<p class="font-body text-white/60 text-xs leading-snug mt-0.5">
										{{- block.settings.label -}}
									</p>
								</div>
							{%- endif -%}
							{%- assign p_counter = p_counter | plus: 1 -%}
						{%- endif -%}
					{%- endfor -%}
					{%- unless p_found -%}<div></div>{%- endunless -%}

					{%- comment -%} Benefit cell {%- endcomment -%}
					{%- for block in section.blocks -%}
						{%- if block.type == 'benefit' -%}
							{%- if b_counter == b_i and b_found == false -%}
								{%- assign b_found = true -%}
								<div class="flex flex-col gap-0.5 text-right">
									<span class="font-heading font-bold leading-none" style="color: #4ADE80; font-size: clamp(1.5rem, 6vw, 2rem);">
										{{- block.settings.value -}}
									</span>
									{%- if block.settings.keyword != blank -%}
										<p class="font-heading font-bold text-white text-sm uppercase tracking-wide leading-tight mt-1">
											{{- block.settings.keyword -}}
										</p>
									{%- endif -%}
									<p class="font-body text-white/60 text-xs leading-snug mt-0.5">
										{{- block.settings.label -}}
									</p>
								</div>
							{%- endif -%}
							{%- assign b_counter = b_counter | plus: 1 -%}
						{%- endif -%}
					{%- endfor -%}
					{%- unless b_found -%}<div></div>{%- endunless -%}

				</div>

				{%- assign p_i = p_i | plus: 1 -%}
				{%- assign b_i = b_i | plus: 1 -%}
			{%- endfor -%}

		</div>

		{%- comment -%} ═══ DESKTOP layout (lg+) ═══ {%- endcomment -%}
		<div class="hidden lg:block">

			{%- comment -%} Column headings {%- endcomment -%}
			<div class="grid grid-cols-2">
				<div class="pl-10 xl:pl-16 pr-12">
					{%- if section.settings.left_heading != blank -%}
						<h3
							class="font-heading font-bold text-highlight text-sm uppercase tracking-widest mb-0 transition-all duration-700 ease-out opacity-0 translate-y-6"
							style="transition-delay: 200ms"
							data-sp-animate
						>
							{{- section.settings.left_heading -}}
						</h3>
					{%- endif -%}
				</div>
				<div class="pr-10 xl:pr-16 pl-12 border-l border-white/10">
					{%- if section.settings.right_heading != blank -%}
						<h3
							class="font-heading font-bold text-sm uppercase tracking-widest mb-0 text-right transition-all duration-700 ease-out opacity-0 translate-y-6"
							style="color: #4ADE80; transition-delay: 200ms"
							data-sp-animate
						>
							{{- section.settings.right_heading -}}
						</h3>
					{%- endif -%}
				</div>
			</div>

			{%- comment -%} Paired rows — problem left, benefit right, same grid row {%- endcomment -%}
			{%- assign dt_p_i = 0 -%}
			{%- assign dt_b_i = 0 -%}
			{%- assign dt_p_count = 0 -%}
			{%- assign dt_b_count = 0 -%}
			{%- for block in section.blocks -%}
				{%- if block.type == 'problem' -%}{%- assign dt_p_count = dt_p_count | plus: 1 -%}{%- endif -%}
				{%- if block.type == 'benefit' -%}{%- assign dt_b_count = dt_b_count | plus: 1 -%}{%- endif -%}
			{%- endfor -%}
			{%- assign dt_max = dt_p_count -%}
			{%- if dt_b_count > dt_max -%}{%- assign dt_max = dt_b_count -%}{%- endif -%}

			{%- for row in (1..dt_max) -%}
				{%- assign delay = forloop.index | times: 100 | plus: 250 -%}
				<div
					class="grid grid-cols-2 transition-all duration-600 ease-out opacity-0 translate-y-6"
					style="transition-delay: {{ delay }}ms"
					data-sp-animate
				>
					{%- comment -%} Problem cell {%- endcomment -%}
					<div class="pl-10 xl:pl-16 pr-12 py-6 {% unless forloop.last %}border-b border-white/10{% endunless %}">
						{%- assign dt_p_counter = 0 -%}
						{%- for block in section.blocks -%}
							{%- if block.type == 'problem' -%}
								{%- if dt_p_counter == dt_p_i -%}
									<div class="flex items-start gap-5" {{ block.shopify_attributes }}>
										<span class="font-heading font-bold text-highlight leading-none shrink-0 w-24 text-right" style="font-size: clamp(2rem, 4vw, 3rem);">
											{{- block.settings.value -}}
										</span>
										<div class="flex flex-col gap-1 pt-1">
											{%- if block.settings.keyword != blank -%}
												<p class="font-heading font-bold text-white text-xl uppercase tracking-wide leading-none mb-1">
													{{- block.settings.keyword -}}
												</p>
											{%- endif -%}
											<p class="font-body text-white/75 text-sm leading-snug">
												{{- block.settings.label -}}
											</p>
											{%- if block.settings.footnote != blank -%}
												{%- if block.settings.footnote_url != blank -%}
													<a href="{{ block.settings.footnote_url }}" target="_blank" rel="noopener" class="font-body text-xs mt-0.5 hover:underline" style="color: var(--color-tertiary-light);">{{ block.settings.footnote }}</a>
												{%- else -%}
													<p class="font-body text-xs mt-0.5" style="color: var(--color-tertiary-light);">{{ block.settings.footnote }}</p>
												{%- endif -%}
											{%- endif -%}
										</div>
									</div>
								{%- endif -%}
								{%- assign dt_p_counter = dt_p_counter | plus: 1 -%}
							{%- endif -%}
						{%- endfor -%}
					</div>

					{%- comment -%} Benefit cell {%- endcomment -%}
					<div class="pr-10 xl:pr-16 pl-12 py-6 {% unless forloop.last %}border-b border-white/10{% endunless %} border-l">
						{%- assign dt_b_counter = 0 -%}
						{%- for block in section.blocks -%}
							{%- if block.type == 'benefit' -%}
								{%- if dt_b_counter == dt_b_i -%}
									<div class="flex items-start gap-5 flex-row-reverse text-right" {{ block.shopify_attributes }}>
										<span class="font-heading font-bold leading-none shrink-0 w-24 text-left" style="color: #4ADE80; font-size: clamp(2rem, 4vw, 3rem);">
											{{- block.settings.value -}}
										</span>
										<div class="flex flex-col gap-1 pt-1">
											{%- if block.settings.keyword != blank -%}
												<p class="font-heading font-bold text-white text-xl uppercase tracking-wide leading-none mb-1">
													{{- block.settings.keyword -}}
												</p>
											{%- endif -%}
											<p class="font-body text-white/75 text-sm leading-snug">
												{{- block.settings.label -}}
											</p>
											{%- if block.settings.footnote != blank -%}
												{%- if block.settings.footnote_url != blank -%}
													<a href="{{ block.settings.footnote_url }}" target="_blank" rel="noopener" class="font-body text-xs mt-0.5 hover:underline" style="color: var(--color-tertiary-light);">{{ block.settings.footnote }}</a>
												{%- else -%}
													<p class="font-body text-xs mt-0.5" style="color: var(--color-tertiary-light);">{{ block.settings.footnote }}</p>
												{%- endif -%}
											{%- endif -%}
										</div>
									</div>
								{%- endif -%}
								{%- assign dt_b_counter = dt_b_counter | plus: 1 -%}
							{%- endif -%}
						{%- endfor -%}
					</div>
				</div>

				{%- assign dt_p_i = dt_p_i | plus: 1 -%}
				{%- assign dt_b_i = dt_b_i | plus: 1 -%}
			{%- endfor -%}

		</div>

		{%- if section.settings.cta_label != blank -%}
			<div class="mt-12 md:mt-16 text-center">
				{%- render 'cta-button',
					label: section.settings.cta_label,
					url: section.settings.cta_url,
					variant: 'accent'
				-%}
			</div>
		{%- endif -%}

	</div>

</section>

<script>
	(function () {
		var els = document.querySelectorAll('[data-sp-animate]');

		if ('IntersectionObserver' in window) {
			var observer = new IntersectionObserver(function (entries) {
				entries.forEach(function (entry) {
					if (!entry.isIntersecting) return;
					var el = entry.target;
					el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
					observer.unobserve(el);
				});
			}, { threshold: 0.12 });

			els.forEach(function (el) { observer.observe(el); });
		} else {
			els.forEach(function (el) {
				el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
			});
		}
	})();
</script>

{% schema %}
{
	"name": "Social Proof",
	"settings": [
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#0A1A34"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "header",
			"content": "Heading"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "The science of sleep"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Better breathing, deeper sleep, better life."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Poor nasal breathing affects more than just snoring. Here's what the research says — and what changes when you breathe freely."
		},
		{
			"type": "header",
			"content": "CTA"
		},
		{
			"type": "text",
			"id": "cta_label",
			"label": "CTA label",
			"default": "Shop Starter Kit"
		},
		{
			"type": "url",
			"id": "cta_url",
			"label": "CTA URL"
		},
		{
			"type": "header",
			"content": "Columns"
		},
		{
			"type": "text",
			"id": "left_heading",
			"label": "Left column heading",
			"default": "The problem"
		},
		{
			"type": "text",
			"id": "right_heading",
			"label": "Right column heading",
			"default": "With better breathing"
		}
	],
	"blocks": [
		{
			"type": "problem",
			"name": "Problem stat",
			"settings": [
				{
					"type": "text",
					"id": "value",
					"label": "Stat value",
					"default": "45%"
				},
				{
					"type": "text",
					"id": "keyword",
					"label": "Keyword",
					"info": "Bold emphasis word, e.g. SNORE, EXHAUSTED"
				},
				{
					"type": "text",
					"id": "label",
					"label": "Description",
					"default": "of adults snore at least occasionally"
				},
				{
					"type": "text",
					"id": "footnote",
					"label": "Source",
					"default": "American Academy of Sleep Medicine"
				},
				{
					"type": "url",
					"id": "footnote_url",
					"label": "Source URL"
				}
			]
		},
		{
			"type": "benefit",
			"name": "Benefit stat",
			"settings": [
				{
					"type": "text",
					"id": "value",
					"label": "Stat value",
					"default": "88%"
				},
				{
					"type": "text",
					"id": "keyword",
					"label": "Keyword",
					"info": "Bold emphasis word, e.g. QUIET, RESTED"
				},
				{
					"type": "text",
					"id": "label",
					"label": "Description",
					"default": "reported a reduction in snoring"
				},
				{
					"type": "text",
					"id": "footnote",
					"label": "Source",
					"default": "Aira user survey, 2025"
				},
				{
					"type": "url",
					"id": "footnote_url",
					"label": "Source URL"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Social Proof",
			"blocks": [
				{
					"type": "problem",
					"settings": {
						"value": "44%",
						"keyword": "Snoring",
						"label": "Nearly half of all adults snore regularly",
						"footnote": "N Engl J Med, 1993"
					}
				},
				{
					"type": "benefit",
					"settings": {
						"value": "75%",
						"keyword": "Quiet nights",
						"label": "Less snoring with a nasal dilator",
						"footnote": "Rhinology, 1997"
					}
				}
			]
		}
	]
}
{% endschema %}
