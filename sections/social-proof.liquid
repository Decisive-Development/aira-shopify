{%- liquid
	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase
-%}

<section
	class="relative overflow-hidden w-full min-h-screen flex items-center"
	style="{% unless has_bg_image %}background-color: {{ section.settings.background_color }};{% endunless %}"
>

	{%- comment -%} Background image / placeholder {%- endcomment -%}
	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400',
					draggable: 'false'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}

	{%- comment -%} Subtle left-to-right gradient vignette for readability {%- endcomment -%}
	<div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(90deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.45) 100%);"></div>

	{%- comment -%} Content {%- endcomment -%}
	<div class="relative z-10 w-full {{ container_class }} py-24 md:py-36">
		<div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">

			{%- comment -%} Left: intro + trust copy {%- endcomment -%}
			<div
				class="flex flex-col gap-8 transition-all duration-700 ease-out opacity-0 translate-y-8"
				data-sp-animate
			>
				{%- if section.settings.eyebrow != blank -%}
					<p class="text-xs font-body font-semibold uppercase tracking-widest text-highlight">
						{{- section.settings.eyebrow -}}
					</p>
				{%- endif -%}

				{%- if section.settings.heading != blank -%}
					<h2 class="font-heading font-bold text-white text-4xl md:text-5xl lg:text-6xl leading-tight">
						{{- section.settings.heading -}}
					</h2>
				{%- endif -%}

				{%- if section.settings.tagline != blank -%}
					<p class="font-heading font-semibold text-white/80 text-lg md:text-xl leading-snug">
						{{- section.settings.tagline -}}
					</p>
				{%- endif -%}

				{%- if section.settings.body != blank -%}
					<p class="font-body text-white/65 text-base md:text-lg leading-relaxed max-w-md">
						{{- section.settings.body -}}
					</p>
				{%- endif -%}

				{%- if section.settings.badge != blank -%}
					<div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-5 py-3 w-fit">
						<svg class="w-5 h-5 text-highlight flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.745 3.745 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.745 3.745 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/>
						</svg>
						<span class="font-body text-sm text-white/90">{{ section.settings.badge }}</span>
					</div>
				{%- endif -%}
			</div>

			{%- comment -%} Right: stats {%- endcomment -%}
			<div class="flex flex-col gap-2">

				{%- if section.settings.stats_heading != blank -%}
					<div
						class="mb-8 transition-all duration-700 ease-out opacity-0 translate-y-8"
						style="transition-delay: 100ms"
						data-sp-animate
					>
						<h3 class="font-heading font-bold text-white text-3xl md:text-4xl">
							{{- section.settings.stats_heading -}}
						</h3>
					</div>
				{%- endif -%}

				{%- for block in section.blocks -%}
					{%- assign delay = forloop.index | times: 120 | plus: 180 -%}
					<div
						class="flex items-start gap-6 py-7 border-b border-white/15 last:border-0 first:border-t first:border-white/15 transition-all duration-600 ease-out opacity-0 translate-y-6"
						style="transition-delay: {{ delay }}ms"
						data-sp-animate
						{{ block.shopify_attributes }}
					>
						{%- comment -%} Stat value {%- endcomment -%}
						<div class="flex-shrink-0 w-32">
							<span class="font-heading font-bold text-white leading-none" style="font-size: clamp(2.5rem, 5vw, 4rem);">
								{{- block.settings.value -}}
							</span>
						</div>

						{%- comment -%} Label + footnote {%- endcomment -%}
						<div class="flex flex-col gap-1 pt-2">
							<p class="font-body text-white/85 text-base md:text-lg leading-snug">
								{{- block.settings.label -}}
							</p>
							{%- if block.settings.footnote != blank -%}
								<p class="font-body text-white/40 text-xs">{{ block.settings.footnote }}</p>
							{%- endif -%}
						</div>
					</div>
				{%- endfor -%}

			</div>

		</div>
	</div>

</section>

<script>
	(function () {
		var els = document.querySelectorAll('[data-sp-animate]');

		if ('IntersectionObserver' in window) {
			var observer = new IntersectionObserver(function (entries) {
				entries.forEach(function (entry) {
					if (!entry.isIntersecting) return;
					var el = entry.target;
					el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
					observer.unobserve(el);
				});
			}, { threshold: 0.12 });

			els.forEach(function (el) { observer.observe(el); });
		} else {
			els.forEach(function (el) {
				el.classList.remove('opacity-0', 'translate-y-8', 'translate-y-6');
			});
		}
	})();
</script>

{% schema %}
{
	"name": "Social Proof",
	"settings": [
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background color",
			"default": "#0A1A34"
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 50,
			"unit": "%"
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "header",
			"content": "Left column — intro"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Introducing Intake Breathing."
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Trusted by Millions.\nBacked by Research."
		},
		{
			"type": "text",
			"id": "tagline",
			"label": "Tagline",
			"default": "Trusted by Millions. Backed By Research."
		},
		{
			"type": "textarea",
			"id": "body",
			"label": "Body copy",
			"default": "SleepScore Labs confirms what our users experience every day — better breathing and better sleep."
		},
		{
			"type": "text",
			"id": "badge",
			"label": "Trust badge text",
			"default": "Clinically validated by SleepScore Labs"
		},
		{
			"type": "header",
			"content": "Right column — stats"
		},
		{
			"type": "text",
			"id": "stats_heading",
			"label": "Stats heading",
			"default": "Transform Your Breath"
		}
	],
	"blocks": [
		{
			"type": "stat",
			"name": "Stat",
			"settings": [
				{
					"type": "text",
					"id": "value",
					"label": "Stat value",
					"default": "88%"
				},
				{
					"type": "text",
					"id": "label",
					"label": "Label",
					"default": "Of Users Reported A Reduction In Snoring"
				},
				{
					"type": "text",
					"id": "footnote",
					"label": "Footnote (e.g. *Based on user survey)",
					"default": "*Based on a survey of verified Aira users"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Social Proof",
			"blocks": [
				{
					"type": "stat",
					"settings": {
						"value": "88%",
						"label": "Of Users Reported A Reduction In Snoring",
						"footnote": "*Based on a survey of verified Aira users"
					}
				},
				{
					"type": "stat",
					"settings": {
						"value": "92%",
						"label": "Of Users Reported Relief From Sinus Pressure",
						"footnote": "*Based on a survey of verified Aira users"
					}
				},
				{
					"type": "stat",
					"settings": {
						"value": "87%",
						"label": "Of Users Reported Deeper & More Restful Sleep",
						"footnote": "*Based on a survey of verified Aira users"
					}
				}
			]
		}
	]
}
{% endschema %}
