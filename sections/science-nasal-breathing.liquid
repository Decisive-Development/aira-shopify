{%- comment -%}
	Backed by Science — §2 The science of nasal breathing.

	Reference: design_handoff_backed_by_science/Backed by science.html §2.

	Cream background. Editorial column max-width 760px. Layout:
	  - Centered eyebrow + h2
	  - Three stat cards in a row (forced grid alignment)
	  - Editorial paragraph block(s)
	  - Single feature stat banner between editorial blocks
	  - More editorial paragraph blocks

	Blocks:
	  - stat_card    — three of these render in the top stat-row
	  - editorial    — h3 + rich body paragraph
	  - stat_banner  — full-width single big-stat callout
{%- endcomment -%}

<section class="science-nasal bg-secondary py-20 md:py-32" data-screen-label="02 The science of nasal breathing">
	<div class="container-contained">

		<div class="editorial-col text-center mb-14 md:mb-20 reveal">
			<span class="eyebrow text-main/60">{{ section.settings.eyebrow | default: 'The foundation' }}</span>
			<h2 class="font-heading heading-weight text-main text-3xl md:text-5xl mt-3 leading-tight tracking-tight">
				{{ section.settings.heading | default: 'Why nasal breathing matters more than you think.' }}
			</h2>
		</div>

		{%- comment -%} Stat cards row — first content block. {%- endcomment -%}
		{%- assign stat_cards = section.blocks | where: 'type', 'stat_card' -%}
		{%- if stat_cards.size > 0 -%}
			<div class="science-nasal__stats reveal">
				<div class="stat-row">
					{%- for block in stat_cards -%}
						<div class="stat-card" {{ block.shopify_attributes }}>
							<div class="text-[10px] tracking-[0.18em] uppercase text-main/50 font-bold">{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</div>
							<div class="stat-card__title mt-3">{{ block.settings.title }}</div>
							<div class="stat-rule"></div>
							<p class="stat-cap">
								{{- block.settings.caption -}}
								{%- if block.settings.citation_ref != blank -%}
									<a href="#cite-{{ block.settings.citation_ref }}" class="fn">[{{ block.settings.citation_ref }}]</a>
								{%- endif -%}
							</p>
						</div>
					{%- endfor -%}
				</div>
			</div>
		{%- endif -%}

		{%- comment -%} Editorial blocks (paragraphs) and stat banners interleaved in block order. {%- endcomment -%}
		{%- for block in section.blocks -%}
			{%- case block.type -%}
				{%- when 'editorial' -%}
					<div class="editorial editorial-col mt-16 reveal" {{ block.shopify_attributes }}>
						{%- if block.settings.heading != blank -%}
							<h3>{{ block.settings.heading }}</h3>
						{%- endif -%}
						<div class="editorial__body">{{ block.settings.body }}</div>
					</div>
				{%- when 'stat_banner' -%}
					<div class="editorial-col mt-10 reveal" {{ block.shopify_attributes }}>
						<div class="stat-card stat-card--banner">
							<div class="grid md:grid-cols-[auto_1fr] gap-6 items-center">
								<div>
									<div class="stat-num stat-num--italic">{{ block.settings.figure }}</div>
									<div class="stat-rule"></div>
								</div>
								<p class="stat-cap stat-cap--banner">
									{{- block.settings.caption -}}
									{%- if block.settings.citation_ref != blank -%}
										<a href="#cite-{{ block.settings.citation_ref }}" class="fn fn--banner">[{{ block.settings.citation_ref }}]</a>
									{%- endif -%}
								</p>
							</div>
						</div>
					</div>
			{%- endcase -%}
		{%- endfor -%}

	</div>
</section>

<style>
	.science-nasal .editorial-col { max-width: 760px; margin-left: auto; margin-right: auto; }
	.science-nasal__stats { max-width: 1040px; margin-left: auto; margin-right: auto; }
	.science-nasal .eyebrow {
		display: inline-block;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}
	.science-nasal .stat-row {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
	}
	@media (min-width: 768px) {
		.science-nasal .stat-row { gap: 1rem; }
	}
	.science-nasal .stat-card {
		background: var(--color-secondary, #F1EBE1);
		border-radius: 0.875rem;
		padding: 1.75rem 1.5rem 1.5rem;
		position: relative;
		display: grid;
		grid-template-rows: auto auto auto auto 1fr;
		align-items: start;
	}
	.science-nasal .stat-card--banner {
		background: #fff;
		border: 1px solid rgba(10,26,52,0.08);
		display: block;
	}
	.science-nasal .stat-card__title {
		font-family: var(--font-heading, "Satoshi", "Nunito Sans", sans-serif);
		color: #0A1A34;
		font-weight: 400;
		font-size: clamp(1.125rem, 2.4vw, 1.75rem);
		line-height: 1.15;
		letter-spacing: -0.015em;
		text-wrap: balance;
		hyphens: none;
	}
	.science-nasal .stat-num {
		font-family: var(--font-heading, "Satoshi", "Nunito Sans", sans-serif);
		font-weight: 400;
		font-size: clamp(2.75rem, 6vw, 4rem);
		color: #0A1A34;
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.science-nasal .stat-num--italic { font-style: italic; }
	.science-nasal .stat-rule {
		height: 1.5px;
		background: #9BB7D4;
		width: 56px;
		margin: 0.875rem 0 0.75rem;
		border-radius: 2px;
	}
	.science-nasal .stat-cap {
		font-size: 0.8125rem;
		line-height: 1.55;
		color: #5C6470;
	}
	.science-nasal .stat-cap--banner { font-size: 0.9375rem; }
	.science-nasal .editorial p {
		font-size: 1.0625rem;
		line-height: 1.75;
		color: #0A1A34;
	}
	@media (min-width: 768px) {
		.science-nasal .editorial p { font-size: 1.125rem; line-height: 1.78; }
	}
	.science-nasal .editorial p + p { margin-top: 1rem; }
	.science-nasal .editorial h3 {
		font-family: var(--font-heading, "Satoshi", "Nunito Sans", sans-serif);
		color: #0A1A34;
		font-weight: 500;
		font-size: 1.625rem;
		line-height: 1.2;
		margin-bottom: 1rem;
		letter-spacing: -0.01em;
	}
	@media (min-width: 768px) {
		.science-nasal .editorial h3 { font-size: 1.875rem; }
	}
	.science-nasal .editorial a[href^="#cite-"],
	.science-nasal .stat-cap a[href^="#cite-"] {
		font-size: 0.55em;
		vertical-align: super;
		line-height: 0;
		font-weight: 700;
		color: #9BB7D4;
		text-decoration: none;
		margin-left: 1px;
	}
	.science-nasal .editorial a[href^="#cite-"]:hover,
	.science-nasal .stat-cap a[href^="#cite-"]:hover { color: #0A1A34; }
</style>

{% schema %}
{
	"name": "Science — Nasal",
	"settings": [
		{ "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The foundation" },
		{ "type": "text", "id": "heading", "label": "Heading", "default": "Why nasal breathing matters more than you think." }
	],
	"blocks": [
		{
			"type": "stat_card",
			"name": "Stat card",
			"limit": 3,
			"settings": [
				{ "type": "text",     "id": "number",       "label": "Number (e.g. 01)", "default": "01" },
				{ "type": "text",     "id": "title",        "label": "Title",            "default": "Sleep quality" },
				{ "type": "textarea", "id": "caption",      "label": "Caption",          "default": "Deeper REM cycles, fewer night-time wakings." },
				{ "type": "text",     "id": "citation_ref", "label": "Citation ref id (e.g. 4)", "default": "4" }
			]
		},
		{
			"type": "editorial",
			"name": "Editorial paragraph",
			"settings": [
				{ "type": "text",     "id": "heading", "label": "Heading",         "default": "Why nasal breathing matters" },
				{ "type": "richtext", "id": "body",    "label": "Body (richtext)", "default": "<p>Body copy goes here. Use <a href=\"#cite-1\">cite anchors</a> for footnote references — paste the superscript numbers in by hand.</p>" }
			]
		},
		{
			"type": "stat_banner",
			"name": "Stat banner",
			"settings": [
				{ "type": "text",     "id": "figure",       "label": "Figure (e.g. +18%)", "default": "+18%" },
				{ "type": "textarea", "id": "caption",      "label": "Caption",            "default": "Increase in oxygen uptake from nasal-produced nitric oxide vs. mouth breathing." },
				{ "type": "text",     "id": "citation_ref", "label": "Citation ref id",    "default": "1" }
			]
		}
	],
	"presets": [
		{
			"name": "Science — Nasal",
			"blocks": [
				{ "type": "stat_card",   "settings": { "number": "01", "title": "Snoring",           "caption": "Reduced soft-palate vibration during sleep.",           "citation_ref": "6" } },
				{ "type": "stat_card",   "settings": { "number": "02", "title": "Sleep quality",     "caption": "Deeper REM cycles, fewer night-time wakings.",          "citation_ref": "4" } },
				{ "type": "stat_card",   "settings": { "number": "03", "title": "Athletic recovery", "caption": "Faster heart-rate-variability return after exercise.", "citation_ref": "5" } },
				{ "type": "editorial",   "settings": { "heading": "Why nasal breathing matters", "body": "<p>When you breathe through your nose, your body does work that mouth breathing simply can't replicate. The nasal cavity warms, humidifies, and filters incoming air. It produces nitric oxide<a href=\"#cite-1\">[1]</a> — a molecule that improves oxygen uptake in the lungs by up to 18%. And it sets the nervous system on a different course: nasal breathing is associated with deeper sleep, better focus, and more efficient recovery.</p>" } },
				{ "type": "stat_banner", "settings": { "figure": "+18%", "caption": "Increase in oxygen uptake from nasal-produced nitric oxide vs. mouth breathing.", "citation_ref": "1" } },
				{ "type": "editorial",   "settings": { "heading": "The cost of mouth breathing", "body": "<p>Chronic mouth breathing has been linked to disrupted sleep, lower daytime energy, dental issues, and reduced athletic performance. In one 2018 study published in the <em>Journal of Clinical Sleep Medicine</em>, participants who switched to nasal-only breathing reported significantly improved sleep quality after 30 days.<a href=\"#cite-2\">[2]</a></p>" } },
				{ "type": "editorial",   "settings": { "heading": "What \"nasal patency\" actually means", "body": "<p>Nasal patency is the medical term for how open your nasal airway is. People with low patency — narrow nasal valves, deviated septums, congestion from allergies — work harder to breathe through their nose. Many give up and switch to mouth breathing without realising it.</p><p>Improving nasal patency, even mechanically and externally, restores the body's preferred breathing pattern.<a href=\"#cite-3\">[3]</a></p>" } },
				{ "type": "editorial",   "settings": { "heading": "What better breathing actually changes", "body": "<p>The downstream effects of improved nasal breathing are well-documented in sleep medicine and sports science: deeper REM cycles, reduced snoring, faster heart rate variability recovery after exercise, and improved daytime focus.</p>" } }
			]
		}
	]
}
{% endschema %}
