{%- comment -%}
	Returns — Policy summary (scaffold).
	A short, scannable summary of the refund policy that links to the
	full /policies/refund-policy. Stops customers having to read the
	full legal text just to figure out if their case is in or out.
{%- endcomment -%}

<section class="bg-secondary py-16 md:py-20">
	<div class="container mx-auto px-4 max-w-3xl">

		{%- if section.settings.heading != blank -%}
			<header class="text-center mb-8">
				{%- if section.settings.eyebrow != blank -%}
					<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
				{%- endif -%}
				<h2 class="font-heading heading-weight text-2xl md:text-3xl text-title m-0">{{ section.settings.heading }}</h2>
			</header>
		{%- endif -%}

		{%- if section.blocks.size > 0 -%}
			<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 m-0 p-0 list-none">
				{%- for block in section.blocks -%}
					<li class="rounded-xl border border-main/10 bg-bg p-5" {{ block.shopify_attributes }}>
						<p class="text-xs font-bold uppercase tracking-widest text-highlight m-0 mb-1.5">{{ block.settings.label }}</p>
						<p class="text-sm text-copy m-0">{{ block.settings.body }}</p>
					</li>
				{%- endfor -%}
			</ul>
		{%- endif -%}

		<p class="text-center mt-8">
			<a href="/policies/refund-policy" class="text-sm text-highlight underline underline-offset-2">{{ section.settings.policy_link_label | default: 'Read the full refund policy →' }}</a>
		</p>

	</div>
</section>

{% schema %}
{
	"name": "Returns - Policy summary",
	"settings": [
		{ "type": "text", "id": "eyebrow",           "label": "Eyebrow",           "default": "The short version" },
		{ "type": "text", "id": "heading",           "label": "Heading",           "default": "How AIRA returns work" },
		{ "type": "text", "id": "policy_link_label", "label": "Policy link label", "default": "Read the full refund policy →" }
	],
	"blocks": [
		{
			"type": "fact",
			"name": "Fact",
			"settings": [
				{ "type": "text",     "id": "label", "label": "Label", "default": "Window" },
				{ "type": "textarea", "id": "body",  "label": "Body",  "default": "14 days from delivery" }
			]
		}
	],
	"presets": [
		{
			"name": "Returns - Policy summary",
			"blocks": [
				{ "type": "fact", "settings": { "label": "Window",     "body": "14 days from delivery." } },
				{ "type": "fact", "settings": { "label": "Condition",  "body": "Unused. Original packaging sealed." } },
				{ "type": "fact", "settings": { "label": "Refund",     "body": "Full refund to original payment method." } },
				{ "type": "fact", "settings": { "label": "Damaged?",   "body": "Skip the gate — message support directly." } }
			]
		}
	]
}
{% endschema %}
