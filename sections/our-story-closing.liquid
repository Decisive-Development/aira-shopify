{%- comment -%}
	Our Story — Closing
	Text-only closing statement with eyebrow, headline, paragraph and two CTAs.
	Styling lives in the shared 'cta-banner' snippet.
{%- endcomment -%}

{%- liquid
	assign hl_text   = section.settings.headline
	assign hl_accent = section.settings.headline_accent
	if hl_text != blank and hl_accent != blank and hl_text contains hl_accent
		assign hl_accent_wrapped = '<span class="text-highlight">' | append: hl_accent | append: '</span>'
		assign hl_html = hl_text | replace: hl_accent, hl_accent_wrapped
	else
		assign hl_html = hl_text
	endif
-%}

{%- render 'cta-banner',
	eyebrow: section.settings.eyebrow,
	heading: hl_html,
	body: section.settings.body,
	primary_label: section.settings.primary_cta_label,
	primary_url: section.settings.primary_cta_url,
	primary_variant: 'shop',
	secondary_label: section.settings.secondary_cta_label,
	secondary_url: section.settings.secondary_cta_url,
	secondary_variant: 'link'
-%}

{% schema %}
{
	"name": "Our Story Closing",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Where we go from here"
		},
		{
			"type": "text",
			"id": "headline",
			"label": "Headline",
			"default": "One product, done properly. Then the next."
		},
		{
			"type": "text",
			"id": "headline_accent",
			"label": "Headline accent phrase",
			"info": "Phrase from the headline to highlight in the brand accent color (must match exactly).",
			"default": "Then the next."
		},
		{
			"type": "textarea",
			"id": "body",
			"label": "Body",
			"default": "We're not building a vitamin aisle. We're building a small, careful collection of things that help you breathe, sleep, and recover — starting with the strip you came here for."
		},
		{
			"type": "header",
			"content": "Primary CTA"
		},
		{
			"type": "text",
			"id": "primary_cta_label",
			"label": "Label",
			"default": "Get my kit"
		},
		{
			"type": "url",
			"id": "primary_cta_url",
			"label": "Link"
		},
		{
			"type": "header",
			"content": "Secondary CTA"
		},
		{
			"type": "text",
			"id": "secondary_cta_label",
			"label": "Label",
			"info": "An arrow → is appended automatically. Don't include it in the label.",
			"default": "How to use it"
		},
		{
			"type": "url",
			"id": "secondary_cta_url",
			"label": "Link"
		}
	],
	"presets": [
		{
			"name": "Our Story Closing"
		}
	]
}
{% endschema %}
