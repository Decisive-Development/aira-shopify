{% liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'py-24 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase

	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif

	assign has_fg_image = false
	if section.settings.foreground_image != blank
		assign has_fg_image = true
	endif
%}

<section
	class="relative overflow-hidden w-full {% if section.settings.full_height %}min-h-screen flex items-center{% endif %}"
	style="{% if has_bg_image %}background-color: var(--color-primary);{% elsif section.settings.use_gradient %}background: linear-gradient(160deg, #0d2247 0%, #0A1A34 40%, #150d2a 72%, #2e0c1e 100%);{% else %}background-color: var(--color-primary);{% endif %}"
>

	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'eager',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}

	<div class="{{ container_class }} {{ py }} w-full">
		<div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

			{%- comment -%} Copy {%- endcomment -%}
			<div class="flex flex-col items-start text-left gap-6 w-full md:w-1/2">

				{%- if section.settings.eyebrow != blank -%}
					<p class="text-sm font-semibold uppercase tracking-widest text-secondary opacity-60">
						{{ section.settings.eyebrow }}
					</p>
				{%- endif -%}

				{%- if section.settings.heading != blank -%}
					<h1 class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-secondary">
						{{ section.settings.heading }}
					</h1>
				{%- endif -%}

				{%- if section.settings.subheading != blank -%}
					<p class="text-base md:text-lg leading-relaxed max-w-md text-secondary opacity-65">
						{{ section.settings.subheading }}
					</p>
				{%- endif -%}

				{%- if section.settings.button_label != blank -%}
					<div class="flex flex-wrap items-center gap-4 mt-2">
						{%- render 'cta-button',
							label: section.settings.button_label,
							url: section.settings.button_url,
							variant: 'blue',
							size: 'md'
						-%}

						{%- if section.settings.secondary_button_label != blank -%}
							<a
								href="{{ section.settings.secondary_button_url }}"
								class="inline-block text-sm font-semibold tracking-wide text-secondary opacity-80 underline-offset-4 hover:underline transition-opacity hover:opacity-70"
							>
								{{ section.settings.secondary_button_label }}
							</a>
						{%- endif -%}
					</div>
				{%- endif -%}

			</div>

			{%- comment -%} Image {%- endcomment -%}
			<div class="w-full md:w-1/2 shrink-0">
				{%- if has_fg_image -%}
					{{
						section.settings.foreground_image
						| image_url: width: 1000
						| image_tag:
							loading: 'eager',
							class: 'w-full h-auto rounded-2xl object-cover',
							widths: '400, 600, 800, 1000'
					}}
				{%- else -%}
					{% # theme-check-disable RemoteAsset %}
					<img
						src="https://images.unsplash.com/photo-1531353826977-0941b4779a1c?w=800&q=80&auto=format&fit=crop"
						alt="Hero placeholder"
						class="w-full h-auto rounded-2xl object-cover"
						width="800"
						height="600"
						loading="eager"
					>
					{% # theme-check-enable RemoteAsset %}
				{%- endif -%}
			</div>

		</div>
	</div>

</section>

{% schema %}
{
	"name": "Hero",
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow text",
			"default": "Breathe freely. Sleep better."
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Rest starts with your breath."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "Aira's magnetic nasal strip gently opens your airway for deeper, quieter sleep, no discomfort."
		},
		{
			"type": "header",
			"content": "Buttons"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Primary button label",
			"default": "Shop now"
		},
		{
			"type": "url",
			"id": "button_url",
			"label": "Primary button URL"
		},
		{
			"type": "text",
			"id": "secondary_button_label",
			"label": "Secondary button label",
			"default": "Learn more"
		},
		{
			"type": "url",
			"id": "secondary_button_url",
			"label": "Secondary button URL"
		},
		{
			"type": "header",
			"content": "Image"
		},
		{
			"type": "image_picker",
			"id": "foreground_image",
			"label": "Image",
			"info": "Upload an image to replace the placeholder."
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "checkbox",
			"id": "use_gradient",
			"label": "Use night sky gradient",
			"default": true
		},
		{
			"type": "paragraph",
			"content": "Colours are controlled in Theme settings → Brand colours."
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 30,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "checkbox",
			"id": "full_height",
			"label": "Full viewport height",
			"default": true
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"presets": [
		{
			"name": "Hero",
			"category": "Hero"
		}
	]
}
{% endschema %}
