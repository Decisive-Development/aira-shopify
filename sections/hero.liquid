{% liquid
	case section.settings.padding_vertical
		when 'none'
			assign py = ''
		when 'sm'
			assign py = 'py-8 md:py-12'
		when 'md'
			assign py = 'py-16 md:py-20'
		when 'lg'
			assign py = 'pt-24 pb-6 md:py-32'
		when 'xl'
			assign py = 'py-32 md:py-48'
	endcase

	case section.settings.container_width
		when 'contained'
			assign container_class = 'container-contained'
		when 'wide'
			assign container_class = 'container-wide'
		when 'full'
			assign container_class = 'container-full'
	endcase

	assign has_bg_image = false
	if section.settings.background_image != blank
		assign has_bg_image = true
	endif

	assign has_fg_image = false
	if section.settings.foreground_image != blank
		assign has_fg_image = true
	endif

	assign has_fg_image_mobile = false
	if section.settings.foreground_image_mobile != blank
		assign has_fg_image_mobile = true
	endif
%}

{%- liquid
	assign hl_text = section.settings.heading
	assign hl_accent = section.settings.heading_accent
	if hl_text != blank and hl_accent != blank and hl_text contains hl_accent
		assign hl_accent_wrapped = '<span class="text-tertiary-light">' | append: hl_accent | append: '</span>'
		assign hl_html = hl_text | replace: hl_accent, hl_accent_wrapped
	else
		assign hl_html = hl_text
	endif
-%}

<section
	data-hero
	class="relative overflow-hidden w-full {% if section.settings.full_height %}min-h-screen flex items-end md:items-center{% endif %}"
	style="{% if section.settings.full_height %}min-height: 100svh;{% endif %}{% if has_bg_image %}background-color: var(--color-primary);{% elsif section.settings.use_gradient %}background: linear-gradient(160deg, #0d2247 0%, #0A1A34 40%, #150d2a 72%, #2e0c1e 100%);{% else %}background-color: var(--color-primary);{% endif %}"
>

	{%- if has_bg_image -%}
		<div class="absolute inset-0 w-full h-full -z-10">
			{{
				section.settings.background_image
				| image_url: width: 2400
				| image_tag:
					loading: 'eager',
					class: 'w-full h-full object-cover',
					widths: '375, 768, 1280, 1920, 2400'
			}}
			{%- if section.settings.overlay_opacity > 0 -%}
				<div
					class="absolute inset-0"
					style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
				></div>
			{%- endif -%}
		</div>
	{%- endif -%}

	{%- comment -%} Foreground image — full-cover background with parallax {%- endcomment -%}
	<div class="absolute inset-0 w-full h-full" data-hero-parallax style="will-change: transform; height: 140%;">
		{%- if has_fg_image -%}
			<picture>
				{%- if has_fg_image_mobile -%}
					<source
						media="(max-width: 767px)"
						srcset="{{ section.settings.foreground_image_mobile | image_url: width: 750 }} 750w,
						        {{ section.settings.foreground_image_mobile | image_url: width: 1125 }} 1125w,
						        {{ section.settings.foreground_image_mobile | image_url: width: 1500 }} 1500w"
						sizes="100vw"
					>
				{%- endif -%}
				<img
					src="{{ section.settings.foreground_image | image_url: width: 2400 }}"
					srcset="{{ section.settings.foreground_image | image_url: width: 768 }} 768w,
					        {{ section.settings.foreground_image | image_url: width: 1280 }} 1280w,
					        {{ section.settings.foreground_image | image_url: width: 1920 }} 1920w,
					        {{ section.settings.foreground_image | image_url: width: 2400 }} 2400w"
					sizes="100vw"
					alt="{{ section.settings.foreground_image.alt | escape }}"
					width="{{ section.settings.foreground_image.width }}"
					height="{{ section.settings.foreground_image.height }}"
					loading="eager"
					class="w-full h-full object-cover -scale-x-100"
				>
			</picture>
		{%- else -%}
			{% # theme-check-disable RemoteAsset %}
			<img
				src="https://images.unsplash.com/photo-1531353826977-0941b4779a1c?w=1920&q=80&auto=format&fit=crop"
				alt="Hero placeholder"
				class="w-full h-full object-cover"
				width="1920"
				height="1080"
				loading="eager"
			>
			{% # theme-check-enable RemoteAsset %}
		{%- endif -%}
		<div class="absolute inset-0 bg-black/45"></div>
		<div class="absolute inset-0 bg-linear-to-t from-black/80 via-transparent to-transparent"></div>
		<div class="absolute inset-x-0 top-0 h-48 bg-linear-to-b from-black/65 to-transparent"></div>
	</div>

	<div class="{{ container_class }} {{ py }} w-full relative z-10">
		<div class="flex flex-col justify-end min-h-[40vh]">

			<div class="flex flex-col items-start text-left gap-6 max-w-2xl">

				{%- if section.settings.eyebrow != blank -%}
					<p class="text-sm font-semibold uppercase tracking-widest text-secondary">
						{{ section.settings.eyebrow }}
					</p>
				{%- endif -%}

				{%- if section.settings.heading != blank -%}
					<h1 class="font-heading heading-weight text-[36px] md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-secondary">
						{{ hl_html }}
					</h1>
				{%- endif -%}

				{%- if section.settings.subheading != blank -%}
					<p class="text-base md:text-lg leading-relaxed max-w-md text-secondary">
						{{ section.settings.subheading }}
					</p>
				{%- endif -%}

				{%- if section.settings.button_label != blank -%}
					<div class="flex flex-wrap items-center gap-4 mt-2">
						{%- render 'cta-button',
							label: section.settings.button_label,
							url: section.settings.button_url,
							variant: 'shop',
							size: 'lg'
						-%}

						{%- if section.settings.secondary_button_label != blank -%}
							{%- render 'cta-button',
								label: section.settings.secondary_button_label,
								url: section.settings.secondary_button_url,
								variant: 'link',
								surface: 'dark'
							-%}
						{%- endif -%}
					</div>
				{%- endif -%}

			</div>

		</div>
	</div>

</section>

<script>
(function () {
	var layer = document.querySelector('[data-hero-parallax]');
	if (!layer || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

	var section = layer.closest('section');
	var ticking = false;

	function update() {
		var rect = section.getBoundingClientRect();
		var visible = rect.bottom > 0 && rect.top < window.innerHeight;
		if (visible) {
			var progress = -rect.top / (rect.height + window.innerHeight);
			var offset = progress * rect.height * 0.35;
			layer.style.transform = 'translate3d(0,' + offset + 'px,0)';
		}
		ticking = false;
	}

	window.addEventListener('scroll', function () {
		if (!ticking) {
			requestAnimationFrame(update);
			ticking = true;
		}
	}, { passive: true });

	update();
})();
</script>

{% schema %}
{
	"name": "Hero",
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow text",
			"default": "Breathe freely. Sleep better."
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Rest starts with your breath."
		},
		{
			"type": "text",
			"id": "heading_accent",
			"label": "Heading accent phrase",
			"info": "Phrase from the heading to highlight in light blue (must match exactly).",
			"default": "Life changing breathing"
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading",
			"default": "The aira magnetic nasal strip gently opens your airway for deeper, quieter sleep, no discomfort."
		},
		{
			"type": "header",
			"content": "Buttons"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Primary button label",
			"default": "Get my kit"
		},
		{
			"type": "url",
			"id": "button_url",
			"label": "Primary button URL"
		},
		{
			"type": "text",
			"id": "secondary_button_label",
			"label": "Secondary button label",
			"default": "How it works"
		},
		{
			"type": "url",
			"id": "secondary_button_url",
			"label": "Secondary button URL"
		},
		{
			"type": "header",
			"content": "Image"
		},
		{
			"type": "image_picker",
			"id": "foreground_image",
			"label": "Image (desktop)",
			"info": "Shown on tablet and desktop (≥768px). Used as fallback on mobile if no mobile image is uploaded."
		},
		{
			"type": "image_picker",
			"id": "foreground_image_mobile",
			"label": "Image (mobile)",
			"info": "Optional. Shown on mobile (<768px). Recommended for portrait-cropped shots that work better on phones."
		},
		{
			"type": "header",
			"content": "Background"
		},
		{
			"type": "checkbox",
			"id": "use_gradient",
			"label": "Use night sky gradient",
			"default": true
		},
		{
			"type": "paragraph",
			"content": "Colors are controlled in Theme settings → Brand colors."
		},
		{
			"type": "image_picker",
			"id": "background_image",
			"label": "Background image"
		},
		{
			"type": "color",
			"id": "overlay_color",
			"label": "Overlay color",
			"default": "#000000"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"label": "Overlay opacity",
			"min": 0,
			"max": 100,
			"step": 5,
			"default": 30,
			"unit": "%"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "checkbox",
			"id": "full_height",
			"label": "Full viewport height",
			"default": true
		},
		{
			"type": "select",
			"id": "container_width",
			"label": "Container width",
			"options": [
				{ "value": "contained", "label": "Contained (1280px)" },
				{ "value": "wide",      "label": "Wide (1536px)" },
				{ "value": "full",      "label": "Full width" }
			],
			"default": "contained"
		},
		{
			"type": "select",
			"id": "padding_vertical",
			"label": "Vertical padding",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "sm",   "label": "Small" },
				{ "value": "md",   "label": "Medium" },
				{ "value": "lg",   "label": "Large" },
				{ "value": "xl",   "label": "Extra large" }
			],
			"default": "lg"
		}
	],
	"presets": [
		{
			"name": "Hero",
			"category": "Hero"
		}
	]
}
{% endschema %}
