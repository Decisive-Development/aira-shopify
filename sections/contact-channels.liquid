{%- comment -%}
	Contact — Channels (scaffold).
	WhatsApp + Email cards. Both targets pulled from theme settings,
	never hardcoded — see Theme settings → Support & contact.
{%- endcomment -%}

{%- liquid
	assign wa_number  = settings.support_whatsapp_number
	assign wa_prefill = settings.support_whatsapp_prefill | default: 'Hi AIRA team,'
	assign wa_link    = ''
	if wa_number != blank
		assign wa_encoded = wa_prefill | url_encode
		assign wa_link    = 'https://wa.me/' | append: wa_number | append: '?text=' | append: wa_encoded
	endif
	assign support_email = settings.support_email
-%}

<section class="bg-bg py-16 md:py-24">
	<div class="container mx-auto px-4 max-w-5xl">

		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

			{%- comment -%} WhatsApp card {%- endcomment -%}
			<a
				href="{{ wa_link | default: '#' }}"
				{% if wa_link != blank %}target="_blank" rel="noopener"{% endif %}
				class="group relative rounded-2xl bg-secondary p-8 md:p-10 transition-shadow hover:shadow-lg flex flex-col gap-4"
			>
				<div class="flex items-center gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#25D366">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
					</svg>
					<h3 class="font-heading text-2xl font-medium text-title m-0">{{ section.settings.whatsapp_heading | default: 'Message us on WhatsApp' }}</h3>
				</div>
				<p class="text-copy/80 text-base m-0">{{ section.settings.whatsapp_body | default: 'Fastest way to reach us. Order questions, sizing, returns — we usually reply within an hour during business hours.' }}</p>
				{%- if settings.business_hours_label != blank -%}
					<p class="text-xs uppercase tracking-widest text-copy/60 m-0">{{ settings.business_hours_label }}</p>
				{%- endif -%}
				{%- if wa_number != blank -%}
					<span class="text-sm font-semibold text-highlight inline-flex items-center gap-1">Open WhatsApp <span aria-hidden="true">→</span></span>
				{%- else -%}
					<span class="text-sm italic text-copy/50">Set the WhatsApp number in Theme settings → Support & contact.</span>
				{%- endif -%}
			</a>

			{%- comment -%} Email card {%- endcomment -%}
			<a
				href="{% if support_email != blank %}mailto:{{ support_email }}{% else %}#{% endif %}"
				class="group relative rounded-2xl bg-secondary p-8 md:p-10 transition-shadow hover:shadow-lg flex flex-col gap-4"
			>
				<div class="flex items-center gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#0A1A34" stroke-width="1.75">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
					</svg>
					<h3 class="font-heading text-2xl font-medium text-title m-0">{{ section.settings.email_heading | default: 'Email support' }}</h3>
				</div>
				<p class="text-copy/80 text-base m-0">{{ section.settings.email_body | default: 'Detailed questions, account issues, or anything that needs an attachment.' }}</p>
				{%- if support_email != blank -%}
					<span class="text-sm font-semibold text-highlight">{{ support_email }}</span>
				{%- else -%}
					<span class="text-sm italic text-copy/50">Set the support email in Theme settings → Support & contact.</span>
				{%- endif -%}
			</a>

		</div>
	</div>
</section>

{% schema %}
{
	"name": "Contact - Channels",
	"settings": [
		{ "type": "text",     "id": "whatsapp_heading", "label": "WhatsApp card heading", "default": "Message us on WhatsApp" },
		{ "type": "textarea", "id": "whatsapp_body",    "label": "WhatsApp card body",    "default": "Fastest way to reach us. Order questions, sizing, returns — we usually reply within an hour during business hours." },
		{ "type": "text",     "id": "email_heading",    "label": "Email card heading",    "default": "Email support" },
		{ "type": "textarea", "id": "email_body",       "label": "Email card body",       "default": "Detailed questions, account issues, or anything that needs an attachment." }
	],
	"presets": [{ "name": "Contact - Channels" }]
}
{% endschema %}
