{%- comment -%}
	Returns — Change-of-mind request form.
	Revealed by the eligibility gate (sections/returns-eligibility-gate.liquid)
	only on the "satisfaction" outcome, via the shared `.form-reveal` animation
	(wrapper id #returns-form-reveal). Inputs live in #returns-form-mount so a
	future returns-app embed can swap in cleanly.

	Routes via Shopify's built-in {% form 'contact' %} to the store contact
	email (Settings → Notifications). The damaged/faulty photo path is handled
	separately in the gate (email for now; in-form upload is still TBD —
	Shopify's contact form can't attach files without an app).
{%- endcomment -%}

<section>
	{%- comment -%} Flag JS early (before this section paints) so .form-reveal collapses without a flash. {%- endcomment -%}
	<script>document.documentElement.classList.add('js')</script>
	<div id="returns-form-reveal" class="form-reveal">
		<div class="bg-secondary py-16 md:py-24">
			<div class="container mx-auto px-4 max-w-[640px]">

				{%- if section.settings.heading != blank -%}
					<header class="text-center mb-10">
						{%- if section.settings.eyebrow != blank -%}
							<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
						{%- endif -%}
						<h2 class="font-heading heading-weight text-3xl md:text-4xl text-title m-0">{{ section.settings.heading }}</h2>
						{%- if section.settings.subheading != blank -%}
							<p class="text-copy/80 text-base mt-3">{{ section.settings.subheading }}</p>
						{%- endif -%}
					</header>
				{%- endif -%}

				{%- if settings.returns_address != blank -%}
					<div class="rounded-xl border border-main/15 bg-bg p-5 mb-8">
						<p class="text-xs font-bold uppercase tracking-widest text-copy/60 m-0 mb-2">Return address</p>
						<p class="text-sm text-copy m-0 whitespace-pre-line">{{ settings.returns_address }}</p>
						<p class="text-xs text-copy/60 m-0 mt-3">Post your return here at your own cost, then submit the form below so we can match your parcel to your order.</p>
					</div>
				{%- endif -%}

				<div id="returns-form-mount">
					{%- form 'contact', id: 'returns-request-form', class: 'flex flex-col gap-5' -%}
						{%- if form.posted_successfully? -%}
							<div class="rounded-xl bg-bg p-5 text-sm text-copy">{{ section.settings.success_message | default: "We've received your return request. We'll review and email your return instructions within two business days." }}</div>
						{%- endif -%}

						{%- if form.errors -%}
							<div class="rounded-xl bg-highlight/10 p-5 text-sm text-highlight">{{ form.errors | default_errors }}</div>
						{%- endif -%}

						{%- comment -%} Keep the form open (not collapsed) after a submit so the result is visible. {%- endcomment -%}
						{%- if form.posted_successfully? or form.errors -%}
							<script>window.airaReturnsKeepOpen = true;</script>
						{%- endif -%}

						{%- comment -%} Tag the email subject so support can filter. {%- endcomment -%}
						<input type="hidden" name="contact[subject]" value="Return request">
						<input type="hidden" name="contact[tags]"    value="returns">

						<label class="flex flex-col gap-1.5">
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Full name</span>
							<input type="text" name="contact[name]" required autocomplete="name" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
						</label>

						<label class="flex flex-col gap-1.5">
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Email</span>
							<input type="email" name="contact[email]" required autocomplete="email" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
						</label>

						<label class="flex flex-col gap-1.5">
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Order number</span>
							<input type="text" name="contact[order_number]" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
						</label>

						<label class="flex flex-col gap-1.5">
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Country</span>
							<select name="contact[country]" required class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
								<option value="">Select country</option>
								<option value="UAE">UAE</option>
								<option value="KSA">KSA</option>
								<option value="Qatar">Qatar</option>
								<option value="Kuwait">Kuwait</option>
								<option value="Bahrain">Bahrain</option>
								<option value="Oman">Oman</option>
								<option value="Other">Other</option>
							</select>
						</label>

						<label class="flex flex-col gap-1.5">
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Reason</span>
							<select name="contact[reason]" required data-reason-select class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main">
								<option value="">Select reason</option>
								<option value="Wrong size">Wrong size</option>
								<option value="No longer needed">No longer needed</option>
								<option value="Found different solution">Found different solution</option>
								<option value="Other">Other</option>
							</select>
						</label>

						<label class="flex flex-col gap-1.5" data-reason-other hidden>
							<span class="text-xs font-semibold uppercase tracking-widest text-title">Tell us more</span>
							<textarea name="contact[reason_other]" rows="4" class="rounded-xl border border-main/20 px-4 py-3 text-sm text-main bg-white focus:outline-none focus:border-main resize-y"></textarea>
						</label>

						<label class="flex items-start gap-3 cursor-pointer">
							<input type="checkbox" name="contact[sealed_confirm]" required class="mt-1">
							<span class="text-base text-copy">I confirm the product is in its original packaging and I have my receipt.</span>
						</label>

						{%- comment -%} Audit-trail hidden inputs populated by the eligibility gate JS. {%- endcomment -%}
						<input type="hidden" id="eligibility_within_window"     name="contact[eligibility_within_window]"     value="">
						<input type="hidden" id="eligibility_original_packaging" name="contact[eligibility_original_packaging]" value="">
						<input type="hidden" id="eligibility_damaged"           name="contact[eligibility_damaged]"           value="">
						<input type="hidden" id="eligibility_order_number"      name="contact[eligibility_order_number]"      value="">

						<div class="pt-2 flex justify-end">
							{%- render 'cta-button',
								label: 'Submit return request',
								element: 'button',
								button_type: 'submit',
								variant: 'solid',
								extra_classes: 'w-full md:w-auto text-center'
							-%}
						</div>
					{%- endform -%}
				</div>

			</div>
		</div>
	</div>
</section>

<script>
	(function () {
		var reveal = document.getElementById('returns-form-reveal');
		var mount  = document.getElementById('returns-form-mount');

		// Collapsed by default via CSS (.js .form-reveal). After a submit we open it
		// so the result message stays visible; otherwise the gate opens it on the
		// satisfaction outcome. Disable inputs while collapsed (out of the tab order).
		if (window.airaReturnsKeepOpen) {
			if (reveal) reveal.classList.add('is-open');
		} else if (mount) {
			mount.querySelectorAll('input, select, textarea, button').forEach(function (el) {
				if (el.type === 'hidden') return;
				el.disabled = true;
			});
		}

		if (!mount) return;

		// Reason → "tell us more" reveal.
		var reason   = mount.querySelector('[data-reason-select]');
		var otherRow = mount.querySelector('[data-reason-other]');
		if (!reason || !otherRow) return;

		var otherTextarea = otherRow.querySelector('textarea');

		function syncOther() {
			var show = reason.value === 'Other';
			otherRow.hidden = !show;
			if (otherTextarea) otherTextarea.required = show;
		}

		reason.addEventListener('change', syncOther);
		syncOther();
	})();
</script>

{% schema %}
{
	"name": "Returns - Form",
	"settings": [
		{ "type": "text",     "id": "eyebrow",         "label": "Eyebrow",        "default": "Change-of-mind return" },
		{ "type": "text",     "id": "heading",         "label": "Heading",        "default": "Tell us about the order" },
		{ "type": "textarea", "id": "subheading",      "label": "Subheading",     "default": "We'll review and email your return instructions within two business days. Return shipping is yours for change-of-mind returns." },
		{ "type": "textarea", "id": "success_message", "label": "Success message","default": "We've received your return request. We'll review and email your return instructions within two business days." }
	],
	"presets": [{ "name": "Returns - Form" }]
}
{% endschema %}
