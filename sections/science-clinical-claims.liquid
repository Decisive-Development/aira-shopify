{%- comment -%}
	Backed by Science — §5 Clinical claims (OPTIONAL — fills at launch).

	Reference: design_handoff_backed_by_science/Backed by science.html §5.

	Cream background. White rounded card with two divided rows. Each row
	is a 2-col grid: big italic figure on the left, sentence + footnote
	ref on the right. Disclaimer beneath the card.

	Section root carries data-optional="true" — flip is_published to drop
	the corner pill at launch.
{%- endcomment -%}

{%- liquid
	assign data_optional_value = 'true'
	if section.settings.is_published
		assign data_optional_value = 'false'
	endif
-%}

<section
	id="clinical-claims"
	class="science-claims bg-secondary py-20 md:py-28 relative"
	data-screen-label="06 Clinical claims"
	data-optional="{{ data_optional_value }}"
>
	<div class="container-contained">
		<div class="max-w-[860px] mx-auto reveal">

			<div class="text-center mb-10">
				<span class="eyebrow text-main/60">{{ section.settings.eyebrow | default: 'Verified results' }}</span>
				<h2 class="font-heading heading-weight text-main text-3xl md:text-5xl mt-3 leading-tight tracking-tight">
					{{ section.settings.heading | default: 'Independently tested.' }}
				</h2>
				{%- if section.settings.lede != blank -%}
					<p class="text-main/65 text-base md:text-lg mt-4 max-w-xl mx-auto">{{ section.settings.lede }}</p>
				{%- endif -%}
			</div>

			{%- if section.blocks.size > 0 -%}
				<div class="science-claims__card bg-white rounded-2xl divide-y divide-main/8 overflow-hidden">
					{%- for block in section.blocks -%}
						{%- if block.type == 'claim' -%}
							<div class="grid md:grid-cols-[auto_1fr] gap-5 md:gap-8 items-center p-6 md:p-8" {{ block.shopify_attributes }}>
								<div class="science-claims__figure font-heading italic text-main">{{ block.settings.figure }}</div>
								<div>
									<p class="text-main text-base md:text-lg leading-relaxed m-0">{{ block.settings.body }}</p>
									{%- if block.settings.citation_ref != blank -%}
										<a href="#cite-{{ block.settings.citation_ref }}" class="fn">[{{ block.settings.citation_ref }}]</a>
									{%- endif -%}
								</div>
							</div>
						{%- endif -%}
					{%- endfor -%}
				</div>
			{%- endif -%}

			{%- if section.settings.disclaimer != blank -%}
				<p class="text-main/55 text-xs mt-6 text-center">{{ section.settings.disclaimer }}</p>
			{%- endif -%}

		</div>
	</div>
</section>

<style>
	.science-claims .eyebrow {
		display: inline-block;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}
	.science-claims__card {
		border: 1px solid rgba(10,26,52,0.08);
	}
	.science-claims__figure {
		font-size: clamp(2rem, 5vw, 3rem);
		line-height: 1;
		font-weight: 400;
	}
	.science-claims .fn {
		font-size: 0.6875rem;
		font-weight: 700;
		color: #9BB7D4;
		text-decoration: none;
		vertical-align: super;
		line-height: 0;
	}
	.science-claims .fn:hover { color: #0A1A34; }
	.science-claims[data-optional="true"]::before {
		content: "OPTIONAL — fills at launch";
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.12em;
		color: #9BB7D4;
		background: rgba(155,183,212,0.10);
		padding: 4px 8px;
		border-radius: 999px;
		z-index: 5;
	}
</style>

{% schema %}
{
	"name": "Science — Claims",
	"settings": [
		{ "type": "checkbox", "id": "is_published", "label": "Published (hides the OPTIONAL pill)", "default": false },
		{ "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Verified results" },
		{ "type": "text",     "id": "heading", "label": "Heading", "default": "Independently tested." },
		{ "type": "textarea", "id": "lede",    "label": "Lede",    "default": "When we make a numerical claim about Aira, it comes from third-party testing. Every figure below is cited." },
		{ "type": "textarea", "id": "disclaimer", "label": "Disclaimer", "default": "Aira does not make claims about treating sleep apnea or any other medical condition. Every claim above refers to mechanical performance only." }
	],
	"blocks": [
		{
			"type": "claim",
			"name": "Claim row",
			"settings": [
				{ "type": "text",     "id": "figure",       "label": "Figure (left)",      "default": "+[XX]%" },
				{ "type": "textarea", "id": "body",         "label": "Description (right)", "default": "[Specific numerical result — e.g., increase in measured nasal airflow over baseline in n=[X] adult subjects]" },
				{ "type": "text",     "id": "citation_ref", "label": "Citation ref id",     "default": "7" }
			]
		}
	],
	"presets": [
		{
			"name": "Science — Claims",
			"blocks": [
				{ "type": "claim", "settings": { "figure": "+[XX]%",  "body": "[Specific numerical result — e.g., increase in measured nasal airflow over baseline in n=[X] adult subjects]",   "citation_ref": "7" } },
				{ "type": "claim", "settings": { "figure": "[XX] hrs", "body": "[Specific numerical result — e.g., average sustained adhesion through a full night of side-sleeping]",         "citation_ref": "8" } }
			]
		}
	]
}
{% endschema %}
