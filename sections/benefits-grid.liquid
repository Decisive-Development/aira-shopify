
{%- assign sc_bg = section.settings.background_color | default: '#FAFAFA' -%}

<style>
  #shopify-section-{{ section.id }} .sc-section {
    --sc-top: clamp(84px, 11vh, 120px);   /* sticky offset below the fixed header */
    --sc-peek: 16px;                       /* how much of each lower card stays visible */
    background: {{ sc_bg }};
    padding: clamp(56px, 9vw, 112px) 0;
  }

  #shopify-section-{{ section.id }} .sc-container {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* ── Section header (text styling comes from the section-heading snippet) ── */
  #shopify-section-{{ section.id }} .sc-head {
    max-width: 680px;
    margin: 0 auto clamp(36px, 5vw, 64px);
  }

  /* ── Stack ── */
  #shopify-section-{{ section.id }} .sc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 28px);
  }
  #shopify-section-{{ section.id }} .sc-card {
    position: sticky;
    top: calc(var(--sc-top) + (var(--index) - 1) * var(--sc-peek));
  }

  /* Short phone viewports: cards pin before their content is readable,
     so drop the sticky stacking and let them scroll normally. */
  @media (max-width: 768px) and (max-height: 740px) {
    #shopify-section-{{ section.id }} .sc-card {
      position: static;
    }
  }
  #shopify-section-{{ section.id }} .sc-card-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    background: #fff;
    border: 1px solid rgba(10, 26, 52, 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 28px rgba(7, 18, 38, 0.09), 0 3px 8px rgba(7, 18, 38, 0.05);
    min-height: clamp(288px, 37vh, 368px);
  }

  /* ── Card text ── */
  #shopify-section-{{ section.id }} .sc-text {
    padding: clamp(28px, 3.5vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .sc-line {
    width: 48px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-highlight, #FF4000);
    margin: 0 0 18px;
  }
  #shopify-section-{{ section.id }} .sc-card-title {
    font-family: var(--font-heading, 'Satoshi', sans-serif);
    font-weight: 700;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-main, #0A1A34);
    margin: 0 0 18px;
  }
  #shopify-section-{{ section.id }} .sc-card-body,
  #shopify-section-{{ section.id }} .sc-card-body :where(p) {
    font-family: var(--font-body, sans-serif);
    font-size: clamp(13px, 1.3vw, 14.5px);
    line-height: 1.7;
    color: var(--color-copy, #555);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .sc-cta {
    margin-top: 28px;
  }

  /* ── Stat chip (canonical stat-card pattern at card scale) ──
     Stat-first: the figure leads, the title and paragraph sit beneath it. */
  #shopify-section-{{ section.id }} .sc-chip {
    margin-bottom: 20px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(10, 26, 52, 0.10);
  }
  #shopify-section-{{ section.id }} .sc-chip-number {
    display: block;
    font-family: var(--font-heading, 'Satoshi', sans-serif);
    font-weight: 700;
    font-size: clamp(40px, 4.5vw, 56px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-highlight, #FF4000);
  }
  #shopify-section-{{ section.id }} .sc-chip-finding {
    margin: 8px 0 0;
    font-family: var(--font-body, sans-serif);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
    color: var(--color-main, #0A1A34);
  }
  #shopify-section-{{ section.id }} .sc-chip-source {
    display: inline-block;
    margin-top: 10px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-copy, #555);
    opacity: 0.75;
  }
  #shopify-section-{{ section.id }} a.sc-chip-source {
    text-decoration: none;
    transition: opacity 0.2s;
  }
  #shopify-section-{{ section.id }} a.sc-chip-source:hover,
  #shopify-section-{{ section.id }} a.sc-chip-source:focus-visible {
    opacity: 1;
    text-decoration: underline;
  }

  /* ── Closing CTA pair ── */
  #shopify-section-{{ section.id }} .sc-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: clamp(32px, 5vw, 48px);
  }

  /* ── Alternate image sides on even cards (desktop only) ── */
  @media (min-width: 769px) {
    #shopify-section-{{ section.id }} .sc-card--flip .sc-card-inner {
      grid-template-columns: 1fr 1.05fr;
    }
    #shopify-section-{{ section.id }} .sc-card--flip .sc-media {
      order: -1;
    }
  }

  /* ── Card media ── */
  #shopify-section-{{ section.id }} .sc-media {
    position: relative;
    background: var(--color-bg-soft, #F2F2F2);
    min-height: 240px;
  }
  #shopify-section-{{ section.id }} .sc-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .sc-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: #9ca3af;
    font-family: var(--font-body, sans-serif);
    font-size: 0.8125rem;
  }

  /* ── Mobile: single column, image on top ── */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .sc-section { --sc-peek: 10px; }
    #shopify-section-{{ section.id }} .sc-container {
      padding: 0 10px;
    }
    #shopify-section-{{ section.id }} .sc-card-inner {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .sc-media {
      order: -1;
      aspect-ratio: 2 / 1;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .sc-text {
      padding: 28px 12px 32px;
    }
  }
</style>

<div class="sc-section" data-stacking-cards>

  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="sc-container">
      <div class="sc-head">
        {%- render 'section-heading',
          eyebrow:    section.settings.eyebrow,
          heading:    section.settings.heading,
          subheading: section.settings.subheading,
          align:      'center',
          size:       'md'
        -%}
      </div>
    </div>
  {%- endif -%}

  <div class="sc-container">
    <ul class="sc-list" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_image = block.settings.image | default: section.settings.image
          assign card_image_mobile = block.settings.image_mobile | default: section.settings.image_mobile
          assign card_alt = block.settings.heading | default: section.settings.eyebrow | escape
          assign desktop_src = card_image | default: card_image_mobile
          assign mobile_src = card_image_mobile | default: card_image
        -%}
        <li class="sc-card{% cycle '', ' sc-card--flip' %}" style="--index: {{ forloop.index }};" {{ block.shopify_attributes }}>
          <div class="sc-card-inner">

            <div class="sc-text">
              {%- if block.settings.stat_number != blank -%}
                <div class="sc-chip">
                  <span class="sc-chip-number">{{ block.settings.stat_number }}</span>
                  {%- if block.settings.stat_finding != blank -%}
                    <p class="sc-chip-finding">{{ block.settings.stat_finding }}</p>
                  {%- endif -%}
                  {%- if block.settings.stat_source != blank -%}
                    {%- if block.settings.stat_source_url != blank -%}
                      <a class="sc-chip-source" href="{{ block.settings.stat_source_url }}" target="_blank" rel="noopener nofollow">{{ block.settings.stat_source }}</a>
                    {%- else -%}
                      <span class="sc-chip-source">{{ block.settings.stat_source }}</span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="sc-card-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <div class="sc-line"></div>
              {%- if block.settings.body != blank -%}
                <div class="sc-card-body">{{ block.settings.body }}</div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="sc-cta">
                  {%- render 'cta-button',
                    label: block.settings.button_label,
                    url: block.settings.button_url,
                    variant: 'outline',
                    surface: 'light',
                    size: 'md'
                  -%}
                </div>
              {%- endif -%}
            </div>

            <div class="sc-media">
              {%- if desktop_src != blank -%}
                <picture>
                  {%- if mobile_src != blank -%}
                    <source
                      media="(max-width: 768px)"
                      srcset="{{ mobile_src | image_url: width: 400 }} 400w, {{ mobile_src | image_url: width: 600 }} 600w, {{ mobile_src | image_url: width: 900 }} 900w"
                      sizes="100vw">
                  {%- endif -%}
                  {{
                    desktop_src
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      class: 'sc-img',
                      widths: '400, 600, 900, 1200',
                      sizes: '(max-width: 768px) 100vw, 600px',
                      alt: card_alt
                  }}
                </picture>
              {%- else -%}
                <div class="sc-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3 20.25h18A1.5 1.5 0 0 0 22.5 18.75v-15A1.5 1.5 0 0 0 21 2.25H3A1.5 1.5 0 0 0 1.5 3.75v15A1.5 1.5 0 0 0 3 20.25Z"/>
                  </svg>
                  <span>Add a card image</span>
                </div>
              {%- endif -%}
            </div>

          </div>
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
      <div class="sc-ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          {%- render 'cta-button',
            label: section.settings.cta_primary_label,
            url: section.settings.cta_primary_url,
            variant: 'shop',
            size: 'md'
          -%}
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          {%- render 'cta-button',
            label: section.settings.cta_secondary_label,
            url: section.settings.cta_secondary_url,
            variant: 'outline',
            surface: 'light',
            size: 'md'
          -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Why aira (Stacking Cards)",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Why aira"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FAFAFA"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Default card image (desktop)",
      "info": "Shared across all cards unless a card has its own image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Default card image (mobile)",
      "info": "Shown on phones. Falls back to the desktop image when blank."
    },
    {
      "type": "header",
      "content": "Closing CTA pair"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "info": "Conversion CTA, orange. Leave blank to hide the pair."
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "info": "Conviction CTA, outlined."
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Benefit heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>Describe this benefit.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image, desktop (optional)",
          "info": "Overrides the default image for this card only"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Card image, mobile (optional)",
          "info": "Shown on phones. Falls back to the card or default desktop image when blank."
        },
        {
          "type": "header",
          "content": "Stat chip"
        },
        {
          "type": "text",
          "id": "stat_number",
          "label": "Number (e.g. 22%)",
          "info": "Leave blank to hide the chip"
        },
        {
          "type": "text",
          "id": "stat_finding",
          "label": "Finding (one sentence)"
        },
        {
          "type": "text",
          "id": "stat_source",
          "label": "Source (AUTHOR ET AL., YEAR)"
        },
        {
          "type": "url",
          "id": "stat_source_url",
          "label": "Source link (optional)",
          "info": "Links the source line to the study. Leave blank for plain text."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label (optional)"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why aira (Stacking Cards)",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "heading": "Snore no more",
            "body": "<p>Snoring starts with a restricted airflow. Air can't get through, your mouth falls open, and your tongue gets in the way. The aira strip holds your nose open, so your mouth stays shut and the problem goes away. In a 14-night trial of nasal strips, partners rated the snoring quieter (Ulfberg & Fenton, 1997).</p>",
            "stat_number": "1 in 3",
            "stat_finding": "adults in the UAE snore nightly.",
            "stat_source": "AL SHAIKH ET AL., 2018",
            "stat_source_url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC6073781/"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Deepest sleep",
            "body": "<p>Deep, restorative sleep runs on nose breathing. Held open all night, you drift into deeper stages, wake less often, and get up properly rested. In a four-week randomised trial, nasal dilation significantly improved sleep quality and daytime function (Krakow et al., 2006).</p>",
            "stat_number": "2.4x",
            "stat_finding": "more likely to be tired all day when your nose is blocked at night.",
            "stat_source": "YOUNG ET AL., 1997",
            "stat_source_url": "https://www.jacionline.org/article/S0091-6749(97)70124-6/fulltext"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Stronger under load",
            "body": "<p>Built for athletes first. With your airway fully open, you hold deep, steady nose breathing while you work: smoother rhythm, more from every breath, no gasping at the peak.</p>",
            "stat_number": "22%",
            "stat_finding": "less air needed for the same pace when runners switched to nose breathing.",
            "stat_source": "DALLAM ET AL., 2018",
            "stat_source_url": "https://doi.org/10.7575/aiac.ijkss.v.6n.2p.22"
          }
        }
      ]
    }
  ]
}
{% endschema %}
