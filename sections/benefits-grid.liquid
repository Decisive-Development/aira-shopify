<section class="py-16 md:py-24 bg-bg" data-benefits-grid>
	<div class="container-contained">

		<div class="mb-10 md:mb-14">
			<p class="text-xs uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
			<h2 class="text-3xl md:text-4xl font-heading heading-weight text-title">{{ section.settings.heading }}</h2>
		</div>

		<div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">

			{%- comment -%} Left column — product image {%- endcomment -%}
			<div>
				{%- if section.settings.image != blank -%}
					{{
						section.settings.image
						| image_url: width: 800
						| image_tag:
							loading: 'lazy',
							class: 'w-full aspect-[4/3] md:aspect-[3/4] rounded-2xl object-cover',
							widths: '400, 600, 800'
					}}
				{%- else -%}
					{%- if product != blank and product.featured_image -%}
						{{
							product.featured_image
							| image_url: width: 800
							| image_tag:
								loading: 'lazy',
								class: 'w-full aspect-[4/3] md:aspect-[3/4] rounded-2xl object-cover',
								widths: '400, 600, 800'
						}}
					{%- else -%}
						<div class="w-full aspect-[4/3] md:aspect-[3/4] rounded-2xl bg-bg-muted"></div>
					{%- endif -%}
				{%- endif -%}
			</div>

			{%- comment -%} Right column — benefit blocks {%- endcomment -%}
			{%- assign benefit_blocks = section.blocks | where: "type", "benefit" -%}
			{%- if benefit_blocks.size > 0 -%}
				<div class="flex flex-col gap-6 md:gap-8">
					{%- for block in benefit_blocks -%}
						<div {{ block.shopify_attributes }}>
							<h3 class="text-lg md:text-xl font-semibold text-main">{{ block.settings.heading }}</h3>
							{%- if block.settings.description != blank -%}
								<p class="text-base text-copy leading-relaxed mt-2">{{ block.settings.description }}</p>
							{%- endif -%}
						</div>
					{%- endfor -%}
				</div>
			{%- endif -%}

		</div>

	</div>
</section>

{% schema %}
{
	"name": "Benefits grid",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Why Aira"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Why Aira works."
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Image",
			"info": "Product image for the left column. Falls back to the page product image if blank."
		}
	],
	"blocks": [
		{
			"type": "benefit",
			"name": "Benefit",
			"settings": [
				{
					"type": "text",
					"id": "heading",
					"label": "Heading",
					"default": "Opens your airway instantly"
				},
				{
					"type": "textarea",
					"id": "description",
					"label": "Description",
					"default": "The magnetic band gently lifts your nasal passages from the outside — no inserts, no discomfort, just immediate airflow."
				}
			]
		}
	],
	"presets": [
		{
			"name": "Benefits grid",
			"blocks": [
				{
					"type": "benefit",
					"settings": {
						"heading": "Opens your airway instantly",
						"description": "The magnetic band gently lifts your nasal passages from the outside — no inserts, no discomfort, just immediate airflow."
					}
				},
				{
					"type": "benefit",
					"settings": {
						"heading": "Stays put all night",
						"description": "Medical-grade adhesive holds through any sleeping position. The band weighs under 2 grams — most people forget it's there."
					}
				},
				{
					"type": "benefit",
					"settings": {
						"heading": "Reusable for months",
						"description": "The magnetic bands last for months of nightly use. Only the adhesive tabs need replacing — keeping costs low."
					}
				}
			]
		}
	],
	"disabled_on": {
		"groups": ["header", "footer"]
	}
}
{% endschema %}
