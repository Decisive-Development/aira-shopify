{% comment %}
  ══════════════════════════════════════════════════════════════
  WHY AIRA — Stacking cards
  Pure-CSS sticky stacking (no JS / no GSAP). Each card pins just
  below the header and the next card scrolls up and stacks on top,
  leaving a small "peek" of the cards beneath.
  ══════════════════════════════════════════════════════════════
{% endcomment %}

{%- assign sc_bg = section.settings.background_color | default: '#FAFAFA' -%}

<style>
  #shopify-section-{{ section.id }} .sc-section {
    --sc-top: clamp(84px, 11vh, 120px);   /* sticky offset below the fixed header */
    --sc-peek: 16px;                       /* how much of each lower card stays visible */
    background: {{ sc_bg }};
    padding: clamp(56px, 9vw, 112px) 0;
  }

  #shopify-section-{{ section.id }} .sc-container {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* ── Section header ── */
  #shopify-section-{{ section.id }} .sc-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(36px, 5vw, 64px);
  }
  #shopify-section-{{ section.id }} .sc-eyebrow {
    font-family: var(--font-heading, 'Satoshi', sans-serif);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-highlight, #FF4000);
    margin: 0 0 16px;
  }
  #shopify-section-{{ section.id }} .sc-title {
    font-family: var(--font-heading, 'Satoshi', sans-serif);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 46px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-main, #0A1A34);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .sc-sub {
    font-family: var(--font-body, sans-serif);
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.7;
    color: var(--color-copy, #555);
    margin: 16px auto 0;
    max-width: 560px;
  }

  /* ── Stack ── */
  #shopify-section-{{ section.id }} .sc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 28px);
  }
  #shopify-section-{{ section.id }} .sc-card {
    position: sticky;
    top: calc(var(--sc-top) + (var(--index) - 1) * var(--sc-peek));
  }
  #shopify-section-{{ section.id }} .sc-card-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    background: #fff;
    border: 1px solid rgba(10, 26, 52, 0.08);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 28px rgba(7, 18, 38, 0.09), 0 3px 8px rgba(7, 18, 38, 0.05);
    min-height: clamp(360px, 46vh, 460px);
  }

  /* ── Card text ── */
  #shopify-section-{{ section.id }} .sc-text {
    padding: clamp(28px, 3.5vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .sc-line {
    width: 48px;
    height: 3px;
    border-radius: 2px;
    background: var(--color-highlight, #FF4000);
    margin: 0 0 18px;
  }
  #shopify-section-{{ section.id }} .sc-card-title {
    font-family: var(--font-heading, 'Satoshi', sans-serif);
    font-weight: 700;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-main, #0A1A34);
    margin: 0 0 18px;
  }
  #shopify-section-{{ section.id }} .sc-card-body,
  #shopify-section-{{ section.id }} .sc-card-body :where(p) {
    font-family: var(--font-body, sans-serif);
    font-size: clamp(15px, 1.3vw, 16.5px);
    line-height: 1.7;
    color: var(--color-copy, #555);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .sc-cta {
    margin-top: 28px;
  }

  /* ── Card media ── */
  #shopify-section-{{ section.id }} .sc-media {
    position: relative;
    background: var(--color-bg-soft, #F2F2F2);
    min-height: 240px;
  }
  #shopify-section-{{ section.id }} .sc-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .sc-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: #9ca3af;
    font-family: var(--font-body, sans-serif);
    font-size: 0.8125rem;
  }

  /* ── Mobile: single column, image on top ── */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .sc-section { --sc-peek: 10px; }
    #shopify-section-{{ section.id }} .sc-card-inner {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .sc-media {
      order: -1;
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
    #shopify-section-{{ section.id }} .sc-text {
      padding: 28px 24px 32px;
    }
  }
</style>

<div class="sc-section" data-stacking-cards>

  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="sc-container">
      <div class="sc-head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="sc-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="sc-title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="sc-sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="sc-container">
    <ul class="sc-list" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_image = block.settings.image | default: section.settings.image
          assign card_alt = block.settings.heading | default: section.settings.eyebrow | escape
        -%}
        <li class="sc-card" style="--index: {{ forloop.index }};" {{ block.shopify_attributes }}>
          <div class="sc-card-inner">

            <div class="sc-text">
              {%- if block.settings.heading != blank -%}
                <h3 class="sc-card-title">{{ block.settings.heading }}</h3>
              {%- endif -%}
              <div class="sc-line"></div>
              {%- if block.settings.body != blank -%}
                <div class="sc-card-body">{{ block.settings.body }}</div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="sc-cta">
                  {%- render 'cta-button',
                    label: block.settings.button_label,
                    url: block.settings.button_url,
                    variant: 'outline',
                    surface: 'light',
                    size: 'md'
                  -%}
                </div>
              {%- endif -%}
            </div>

            <div class="sc-media">
              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    class: 'sc-img',
                    widths: '400, 600, 900, 1200',
                    sizes: '(max-width: 768px) 100vw, 600px',
                    alt: card_alt
                }}
              {%- else -%}
                <div class="sc-placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3 20.25h18A1.5 1.5 0 0 0 22.5 18.75v-15A1.5 1.5 0 0 0 21 2.25H3A1.5 1.5 0 0 0 1.5 3.75v15A1.5 1.5 0 0 0 3 20.25Z"/>
                  </svg>
                  <span>Add a card image</span>
                </div>
              {%- endif -%}
            </div>

          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>

</div>

{% schema %}
{
  "name": "Why aira (Stacking Cards)",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Why aira"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#FAFAFA"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Default card image",
      "info": "Shared across all cards unless a card has its own image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Benefit heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>Describe this benefit.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image (optional)",
          "info": "Overrides the default image for this card only"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label (optional)"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why aira (Stacking Cards)",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "heading": "Snore no more",
            "body": "<p>Snoring usually starts the moment you slip into mouth breathing. aira holds your nasal passages open so air flows freely through your nose — quieting the vibration at its source. Most partners hear the difference on the very first night.</p>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Rhythmic breathing",
            "body": "<p>Built for athletes first. With your airway fully open, you can breathe deep and steady through your nose under load — a smoother rhythm, more efficient oxygen, and less gasping when the effort peaks.</p>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "heading": "Deepest sleep",
            "body": "<p>Nose breathing is the foundation of deep, restorative sleep. With your airway held open all night, you drift into deeper stages, wake less often, and rise genuinely rested.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
