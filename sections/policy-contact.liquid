{%- comment -%}
	Policy — Contact
	Closing callout: short prompt + mailto button. Used on every
	/policies/* URL. Styling lives in the shared 'cta-banner' snippet.
{%- endcomment -%}

{%- liquid
	assign cta_email  = section.settings.cta_email | default: 'contact@shop-aira.com'
	assign cta_label  = section.settings.cta_label | default: 'Email our privacy team'
	assign mailto_url = 'mailto:' | append: cta_email
	assign pc_heading = section.settings.heading | default: 'Questions about how we handle your data?'
	assign pc_body    = section.settings.body | default: "Email us and we'll respond within the timeframe required by applicable law (typically 30 days)."
-%}

{%- render 'cta-banner',
	heading: pc_heading,
	body: pc_body,
	primary_label: cta_label,
	primary_url: mailto_url,
	primary_variant: 'solid'
-%}

{% schema %}
{
	"name": "Policy — Contact",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Questions about how we handle your data?"
		},
		{
			"type": "textarea",
			"id": "body",
			"label": "Body",
			"default": "Email us and we'll respond within the timeframe required by applicable law (typically 30 days)."
		},
		{
			"type": "text",
			"id": "cta_label",
			"label": "Button label",
			"default": "Email us"
		},
		{
			"type": "text",
			"id": "cta_email",
			"label": "Contact email",
			"default": "contact@shop-aira.com",
			"info": "Swap to privacy@aira-breathing.com once that alias is set up."
		}
	],
	"presets": [
		{ "name": "Policy — Contact" }
	]
}
{% endschema %}
