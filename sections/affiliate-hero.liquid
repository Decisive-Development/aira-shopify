{%- comment -%}
	Affiliate — Hero (scaffold).
	Navy bg-main + light-blue radial halo, matches /pages/our-story family.
{%- endcomment -%}

<section class="relative overflow-hidden bg-main text-secondary pt-32 md:pt-40 pb-16 md:pb-24">

	<div
		class="absolute inset-0 pointer-events-none"
		style="background:
			radial-gradient(ellipse 60% 50% at 80% 20%, rgba(155,183,212,0.10), transparent 65%),
			radial-gradient(ellipse 60% 50% at 15% 90%, rgba(80,162,167,0.12), transparent 70%);"
	></div>

	<div class="relative z-10 container mx-auto px-4 max-w-[720px] text-center">
		{%- if section.settings.eyebrow != blank -%}
			<p class="text-xs font-bold uppercase tracking-widest text-tertiary-light mb-4">{{ section.settings.eyebrow }}</p>
		{%- endif -%}
		<h1 class="text-4xl md:text-5xl font-medium mb-4 text-balance">
			{{ section.settings.heading | default: 'Partner with AIRA' }}
		</h1>
		{%- if section.settings.subheading != blank -%}
			<p class="text-lg text-secondary/80 max-w-xl mx-auto mb-8">{{ section.settings.subheading }}</p>
		{%- endif -%}
		{%- if section.settings.cta_label != blank -%}
			{%- render 'cta-button',
				label: section.settings.cta_label,
				url:   section.settings.cta_url | default: '#affiliate-form',
				variant: 'accent',
				size: 'lg'
			-%}
		{%- endif -%}
	</div>
</section>

{% schema %}
{
	"name": "Affiliate - Hero",
	"settings": [
		{ "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Partner program" },
		{ "type": "text",     "id": "heading",    "label": "Heading",    "default": "Partner with AIRA" },
		{ "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We work with creators who care about sleep, sport, and breath. Apply once, earn on every order." },
		{ "type": "text",     "id": "cta_label",  "label": "CTA label",  "default": "Apply now" },
		{ "type": "url",      "id": "cta_url",    "label": "CTA URL" }
	],
	"presets": [{ "name": "Affiliate - Hero" }]
}
{% endschema %}
