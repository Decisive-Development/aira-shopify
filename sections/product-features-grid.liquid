{%- assign feature_blocks = section.blocks | where: "type", "feature" -%}

<section class="py-16 md:py-24 bg-bg" data-features-grid>
	<div class="container-contained">

		<div class="mb-10 md:mb-12">
			{%- render 'section-heading',
				eyebrow:    section.settings.eyebrow,
				heading:    section.settings.heading,
				subheading: section.settings.subheading,
				align:      'center',
				size:       'md'
			-%}
		</div>

		{%- if feature_blocks.size > 0 -%}
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
				{%- for block in feature_blocks -%}
					<div {{ block.shopify_attributes }}>
						<div class="aspect-square rounded-2xl overflow-hidden bg-main">
							{%- if block.settings.video != blank -%}
								{%- assign feature_poster = block.settings.video.preview_image | image_url: width: 600 -%}
								{{
									block.settings.video
									| video_tag:
										autoplay: true,
										loop: true,
										muted: true,
										playsinline: true,
										preload: 'none',
										poster: feature_poster,
										class: 'w-full h-full object-cover'
								}}
							{%- elsif block.settings.image != blank -%}
								{{
									block.settings.image
									| image_url: width: 600
									| image_tag:
										loading: 'lazy',
										class: 'w-full h-full object-cover',
										widths: '300, 400, 600'
								}}
							{%- endif -%}
						</div>
						<h3 class="text-lg md:text-xl lg:text-2xl font-heading font-bold text-main mt-4">{{ block.settings.title }}</h3>
						{%- if block.settings.description != blank -%}
							<p class="text-sm md:text-base text-copy leading-relaxed mt-2">{{ block.settings.description }}</p>
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

{%- assign features_has_video = false -%}
{%- for block in feature_blocks -%}
	{%- if block.settings.video != blank -%}{%- assign features_has_video = true -%}{%- break -%}{%- endif -%}
{%- endfor -%}
{%- if features_has_video -%}
	<script>
		(function () {
			var root = document.getElementById('shopify-section-{{ section.id }}');
			if (!root) return;
			var vids = root.querySelectorAll('video');
			if (!vids.length) return;

			{%- comment -%} Lazy autoplay: only play while in view (preload: 'none' defers the fetch). {%- endcomment -%}
			if ('IntersectionObserver' in window) {
				var io = new IntersectionObserver(function (entries) {
					entries.forEach(function (entry) {
						if (!(entry.target instanceof HTMLVideoElement)) return;
						if (entry.isIntersecting) { entry.target.play().catch(function () {}); }
						else { entry.target.pause(); }
					});
				}, { threshold: 0.4 });
				vids.forEach(function (v) { io.observe(v); });
			} else {
				vids.forEach(function (v) { v.play().catch(function () {}); });
			}

			document.addEventListener('visibilitychange', function () {
				if (document.hidden) {
					vids.forEach(function (v) { v.pause(); });
				}
			});
		})();
	</script>
{%- endif -%}

{% schema %}
{
	"name": "Product Features Grid",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "Product"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Built for better breathing."
		},
		{
			"type": "textarea",
			"id": "subheading",
			"label": "Subheading"
		}
	],
	"blocks": [
		{
			"type": "feature",
			"name": "Feature",
			"limit": 4,
			"settings": [
				{
					"type": "video",
					"id": "video",
					"label": "Video (takes priority over image)"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "Image"
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "Opens on contact"
				},
				{
					"type": "textarea",
					"id": "description",
					"label": "Description",
					"default": "Pick your size, click the band on, and your nasal passages lift open. Full airflow from the first breath, no adjustment period."
				}
			]
		}
	],
	"presets": [
		{
			"name": "Product Features Grid",
			"blocks": [
				{
					"type": "feature",
					"settings": {
						"title": "Opens on contact",
						"description": "Pick your size, click the band on, and your nasal passages lift open. Full airflow from the first breath, no adjustment period."
					}
				},
				{
					"type": "feature",
					"settings": {
						"title": "Holds all night",
						"description": "Disposable strips lack the strength to hold your nostrils open. The aira strip not only opens your nose more, but it will not collapse under intense breathing."
					}
				},
				{
					"type": "feature",
					"settings": {
						"title": "Built for the Gulf",
						"description": "Engineered for sweat, humidity, and summer heat. The tabs grip through hard sessions and restless nights."
					}
				},
				{
					"type": "feature",
					"settings": {
						"title": "Kind to skin",
						"description": "Medical-grade, hypoallergenic, latex-free adhesive. A fresh pair of tabs every night, off in the morning without leaving a trace."
					}
				}
			]
		}
	],
	"disabled_on": {
		"groups": ["header", "footer"]
	}
}
{% endschema %}
