{%- assign ugc_blocks = section.blocks | where: "type", "testimonial" -%}

{%- liquid
	assign theme = section.settings.theme | default: 'dark'
	if theme == 'light'
		assign bg_class = 'bg-cream-light'
		assign bg_style = ''
		assign progress_track = 'bg-bg-muted'
		assign progress_fill = 'bg-main'
		assign border_color = 'border-bg-muted'
		assign cta_color = 'text-copy'
		assign eyebrow_color = 'text-highlight'
	else
		assign bg_class = 'bg-main'
		assign bg_style = 'background-image: radial-gradient(ellipse 60% 50% at 80% 20%, rgba(155,183,212,0.10), transparent 65%), radial-gradient(ellipse 60% 50% at 15% 90%, rgba(80,162,167,0.12), transparent 70%);'
		assign progress_track = 'bg-white/10'
		assign progress_fill = 'bg-secondary'
		assign border_color = 'border-white/10'
		assign cta_color = 'text-secondary opacity-75'
		assign eyebrow_color = 'text-tertiary-light'
	endif
	assign ig_handle = settings.social_instagram_handle | default: section.settings.handle

	# Content source: per-page blocks override the shared ugc_testimonial metaobject list
	assign ugc_entries = shop.metaobjects.ugc_testimonial.values
	assign ugc_use_blocks = false
	if ugc_blocks.size > 0
		assign ugc_use_blocks = true
	endif
	assign ugc_count = ugc_entries.size
	if ugc_use_blocks
		assign ugc_count = ugc_blocks.size
	endif
-%}

{%- if ugc_count > 0 -%}

<style>
	#shopify-section-{{ section.id }} .ugc-track::-webkit-scrollbar { display: none; }
	#shopify-section-{{ section.id }} .ugc-track {
		-ms-overflow-style: none;
		scrollbar-width: none;
		cursor: grab;
		scroll-behavior: smooth;
	}
	#shopify-section-{{ section.id }} .ugc-track.is-dragging {
		cursor: grabbing;
		scroll-behavior: auto;
	}
</style>

<section
	class="py-16 md:py-24 {{ bg_class }}"
	style="{{ bg_style }}"
	data-ugc-section="{{ section.id }}"
>
	<div class="container-contained">

		{%- render 'section-heading',
			eyebrow:    section.settings.eyebrow,
			heading:    section.settings.heading,
			subheading: section.settings.subheading,
			align:      'center',
			size:       'md',
			surface:    theme
		-%}

		{%- comment -%} Image row {%- endcomment -%}
		<div class="flex gap-3 overflow-x-auto mt-10 md:mt-12 ugc-track" data-ugc-track>
			{%- if ugc_use_blocks -%}
				{%- for block in ugc_blocks -%}
					{%- render 'ugc-card', source: 'block', block: block -%}
				{%- endfor -%}
			{%- else -%}
				{%- for entry in ugc_entries -%}
					{%- render 'ugc-card', source: 'meta', entry: entry -%}
				{%- endfor -%}
			{%- endif -%}
		</div>

		{%- comment -%} Scroll progress bar {%- endcomment -%}
		<div class="mt-6 mx-auto w-48 md:w-64 h-1 rounded-full {{ progress_track }} overflow-hidden">
			<div class="h-full rounded-full {{ progress_fill }} transition-[width] duration-100" data-ugc-progress style="width: 0%;"></div>
		</div>

		{%- comment -%} Optional shop CTA (rendered when label is set) {%- endcomment -%}
		{%- if section.settings.shop_cta_label != blank -%}
			<div class="mt-12 md:mt-16 flex justify-center">
				{%- render 'cta-button',
					label: section.settings.shop_cta_label,
					url: section.settings.shop_cta_url,
					variant: 'shop',
					size: 'lg',
					extra_classes: 'w-full md:w-auto text-center'
				-%}
			</div>
		{%- endif -%}

		{%- comment -%} Divider + CTA {%- endcomment -%}
		<div class="border-t {{ border_color }} mt-6 pt-6 text-center">
			{%- if section.settings.offer_text != blank -%}
				<p class="text-lg font-semibold {{ eyebrow_color }} mt-1">{{ section.settings.offer_text }}</p>
			{%- endif -%}
			{%- if section.settings.cta_text != blank -%}
				<p class="text-base {{ cta_color }} mt-1">{{ section.settings.cta_text | replace: section.settings.handle, '' | replace: ig_handle, '' | strip }} <strong class="font-bold">{{ ig_handle }}</strong></p>
			{%- endif -%}
		</div>

	</div>
	{%- comment -%} Video lightbox modal — one per section, populated on click {%- endcomment -%}
	<div
		data-ugc-modal
		class="fixed inset-0 z-100 hidden items-center justify-center bg-black/80 p-4"
		role="dialog"
		aria-modal="true"
		aria-hidden="true"
		aria-label="Video player"
	>
		<button
			type="button"
			data-ugc-close
			class="absolute top-4 right-4 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors"
			aria-label="Close video"
		>
			<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18"/></svg>
		</button>
		<div data-ugc-modal-holder class="relative h-[80vh] max-h-[80vh] aspect-9/16 max-w-[92vw] rounded-2xl overflow-hidden bg-black"></div>
	</div>

</section>

<script>
(function () {
	var section = document.querySelector('[data-ugc-section="{{ section.id }}"]');
	if (!section) return;
	var track = section.querySelector('[data-ugc-track]');
	var bar = section.querySelector('[data-ugc-progress]');
	if (!track) return;

	/* ── Scroll progress ── */
	function updateProgress() {
		if (!bar) return;
		var max = track.scrollWidth - track.clientWidth;
		if (max <= 0) { bar.style.width = '100%'; return; }
		var pct = (track.scrollLeft / max) * 100;
		bar.style.width = Math.max(5, Math.min(100, pct)) + '%';
	}
	track.addEventListener('scroll', updateProgress, { passive: true });
	updateProgress();

	/* ── Drag to scroll (desktop) ── */
	var isDown = false, startX = 0, scrollLeft = 0, hasDragged = false;

	track.addEventListener('mousedown', function (e) {
		isDown = true;
		hasDragged = false;
		startX = e.pageX - track.offsetLeft;
		scrollLeft = track.scrollLeft;
		track.classList.add('is-dragging');
	});

	window.addEventListener('mousemove', function (e) {
		if (!isDown) return;
		var x = e.pageX - track.offsetLeft;
		var delta = startX - x;
		if (Math.abs(delta) > 4) hasDragged = true;
		track.scrollLeft = scrollLeft + delta;
	});

	window.addEventListener('mouseup', function () {
		if (!isDown) return;
		isDown = false;
		track.classList.remove('is-dragging');
		resetAutoplay();
	});

	track.addEventListener('click', function (e) {
		if (hasDragged) e.stopPropagation();
	}, true);

	/* ── Auto-scroll every 6 seconds ── */
	var autoTimer = null;
	var userTouching = false;

	function getCardStep() {
		var card = track.firstElementChild;
		if (!card) return 200;
		return card.getBoundingClientRect().width + 12; /* 12 = gap-3 */
	}

	function autoScroll() {
		if (userTouching || isDown) return;
		var max = track.scrollWidth - track.clientWidth;
		var next = track.scrollLeft + getCardStep();
		if (next >= max - 2) {
			track.scrollTo({ left: 0, behavior: 'smooth' });
		} else {
			track.scrollTo({ left: next, behavior: 'smooth' });
		}
	}

	function resetAutoplay() {
		clearInterval(autoTimer);
		autoTimer = setInterval(autoScroll, 6000);
	}

	/* Pause on touch / hover */
	track.addEventListener('touchstart', function () { userTouching = true; clearInterval(autoTimer); }, { passive: true });
	track.addEventListener('touchend', function () { userTouching = false; resetAutoplay(); }, { passive: true });
	track.addEventListener('mouseenter', function () { clearInterval(autoTimer); });
	track.addEventListener('mouseleave', function () { if (!isDown) resetAutoplay(); });

	/* ── Video lightbox ── */
	var modal = section.querySelector('[data-ugc-modal]');
	var modalHolder = modal && modal.querySelector('[data-ugc-modal-holder]');
	var closeBtn = modal && modal.querySelector('[data-ugc-close]');

	function openModal(card) {
		var tpl = card.querySelector('[data-ugc-modal-content]');
		if (!tpl || !modalHolder || !modal) return;
		modalHolder.innerHTML = '';
		modalHolder.appendChild(tpl.content.cloneNode(true));
		modal.classList.remove('hidden');
		modal.classList.add('flex');
		modal.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';
		var v = modalHolder.querySelector('video');
		if (v) { v.play().catch(function () {}); }
	}

	function closeModal() {
		if (!modal || !modalHolder) return;
		var v = modalHolder.querySelector('video');
		if (v) { try { v.pause(); } catch (e) {} }
		modalHolder.innerHTML = '';
		modal.classList.add('hidden');
		modal.classList.remove('flex');
		modal.setAttribute('aria-hidden', 'true');
		document.body.style.overflow = '';
	}

	section.querySelectorAll('[data-ugc-card]').forEach(function (card) {
		card.addEventListener('click', function () {
			if (hasDragged) return;
			openModal(card);
		});
		card.addEventListener('keydown', function (e) {
			if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') {
				e.preventDefault();
				openModal(card);
			}
		});
	});

	if (closeBtn) closeBtn.addEventListener('click', closeModal);
	if (modal) {
		modal.addEventListener('click', function (e) {
			if (e.target === modal) closeModal();
		});
	}
	document.addEventListener('keydown', function (e) {
		if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
	});

	/* Start autoplay */
	resetAutoplay();
})();
</script>

{%- endif -%}

{% schema %}
{
	"name": "UGC Gallery",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "See it in action"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "The aira community"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"info": "Honest framing line. No fabricated counts until real numbers exist. Leave blank to hide."
		},
		{
			"type": "text",
			"id": "handle",
			"label": "Handle",
			"default": "@airabreathing"
		},
		{
			"type": "text",
			"id": "cta_text",
			"label": "Bottom text",
			"default": "Tag us and share your experience. @airabreathing"
		},
		{
			"type": "text",
			"id": "offer_text",
			"label": "Offer line",
			"info": "Shown above the handle in the bottom call-to-action. Leave blank to hide.",
			"default": "Claim a discount or free gift!"
		},
		{
			"type": "select",
			"id": "theme",
			"label": "Theme",
			"options": [
				{ "value": "dark",  "label": "Dark (navy)" },
				{ "value": "light", "label": "Light (cream)" }
			],
			"default": "dark"
		},
		{
			"type": "header",
			"content": "Shop CTA (optional)"
		},
		{
			"type": "text",
			"id": "shop_cta_label",
			"label": "Button label",
			"info": "Leave blank to hide the shop button."
		},
		{
			"type": "url",
			"id": "shop_cta_url",
			"label": "Button link"
		}
	],
	"blocks": [
		{
			"type": "testimonial",
			"name": "Testimonial",
			"limit": 8,
			"settings": [
				{
					"type": "video",
					"id": "video",
					"label": "Video",
					"info": "Optional. Shopify-hosted video. Plays muted on loop. Takes priority over the image."
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "Image"
				},
				{
					"type": "text",
					"id": "quote",
					"label": "Quote"
				},
				{
					"type": "text",
					"id": "name",
					"label": "Name"
				}
			]
		}
	],
	"presets": [
		{
			"name": "UGC Gallery",
			"blocks": [
				{
					"type": "testimonial",
					"settings": {
						"quote": "I sleep so much better now",
						"name": "Sarah M."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "My partner noticed the difference immediately",
						"name": "James K."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "Game changer for my workouts",
						"name": "Aisha R."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "Finally stopped mouth breathing at night",
						"name": "Omar D."
					}
				}
			]
		}
	],
	"disabled_on": {
		"groups": ["header", "footer"]
	}
}
{% endschema %}
