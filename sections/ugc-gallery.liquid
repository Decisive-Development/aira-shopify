{%- assign ugc_blocks = section.blocks | where: "type", "testimonial" -%}

{%- liquid
	assign theme = section.settings.theme | default: 'dark'
	if theme == 'light'
		assign bg_class = 'bg-cream-light'
		assign bg_style = ''
		assign heading_color = 'text-title'
		assign progress_track = 'bg-bg-muted'
		assign progress_fill = 'bg-main'
		assign border_color = 'border-bg-muted'
		assign handle_color = 'text-main'
		assign cta_color = 'text-copy'
	else
		assign bg_class = 'bg-main'
		assign bg_style = 'background-image: radial-gradient(ellipse 60% 50% at 80% 20%, rgba(155,183,212,0.10), transparent 65%), radial-gradient(ellipse 60% 50% at 15% 90%, rgba(80,162,167,0.12), transparent 70%);'
		assign heading_color = 'text-secondary'
		assign progress_track = 'bg-white/10'
		assign progress_fill = 'bg-secondary'
		assign border_color = 'border-white/10'
		assign handle_color = 'text-secondary'
		assign cta_color = 'text-secondary opacity-75'
	endif
-%}

{%- if ugc_blocks.size > 0 -%}

<style>
	#shopify-section-{{ section.id }} .ugc-track::-webkit-scrollbar { display: none; }
	#shopify-section-{{ section.id }} .ugc-track {
		-ms-overflow-style: none;
		scrollbar-width: none;
		cursor: grab;
		scroll-behavior: smooth;
	}
	#shopify-section-{{ section.id }} .ugc-track.is-dragging {
		cursor: grabbing;
		scroll-behavior: auto;
	}
</style>

<section
	class="py-16 md:py-24 {{ bg_class }}"
	style="{{ bg_style }}"
	data-ugc-section="{{ section.id }}"
>
	<div class="container-contained">

		{%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
			<div class="flex flex-col gap-2 md:gap-3 text-center">
				{%- if section.settings.eyebrow != blank -%}
					<p class="text-xs font-bold uppercase tracking-widest text-highlight">{{ section.settings.eyebrow }}</p>
				{%- endif -%}
				{%- if section.settings.heading != blank -%}
					<h2 class="font-heading heading-weight text-4xl md:text-5xl leading-none tracking-tight {{ heading_color }}">{{ section.settings.heading }}</h2>
				{%- endif -%}
			</div>
		{%- endif -%}

		{%- comment -%} Image row {%- endcomment -%}
		<div class="flex gap-3 overflow-x-auto mt-10 md:mt-12 snap-x snap-mandatory ugc-track" data-ugc-track>
			{%- for block in ugc_blocks -%}
				<div class="relative shrink-0 w-[65%] md:w-[22%] rounded-2xl overflow-hidden snap-start" style="aspect-ratio: 9 / 16;" {{ block.shopify_attributes }}>
					{%- if block.settings.image != blank -%}
						{{
							block.settings.image
							| image_url: width: 600
							| image_tag:
								loading: 'lazy',
								class: 'absolute inset-0 w-full h-full object-cover',
								widths: '300, 400, 600',
								draggable: 'false'
						}}
					{%- else -%}
						<div class="absolute inset-0 bg-bg-muted"></div>
					{%- endif -%}
					<div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/30 to-transparent"></div>
					{%- if block.settings.quote != blank or block.settings.name != blank -%}
						<div class="absolute bottom-0 left-0 right-0 p-4 md:p-5">
							{%- if block.settings.quote != blank -%}
								<p class="text-white text-sm md:text-base font-medium leading-snug">"{{ block.settings.quote }}"</p>
							{%- endif -%}
							{%- if block.settings.name != blank -%}
								<p class="text-white/70 text-xs mt-1">— {{ block.settings.name }}</p>
							{%- endif -%}
						</div>
					{%- endif -%}
				</div>
			{%- endfor -%}
		</div>

		{%- comment -%} Scroll progress bar {%- endcomment -%}
		<div class="mt-6 mx-auto w-48 md:w-64 h-1 rounded-full {{ progress_track }} overflow-hidden">
			<div class="h-full rounded-full {{ progress_fill }} transition-[width] duration-100" data-ugc-progress style="width: 0%;"></div>
		</div>

		{%- comment -%} Optional shop CTA (rendered when label is set) {%- endcomment -%}
		{%- if section.settings.shop_cta_label != blank -%}
			<div class="mt-12 md:mt-16 flex justify-center">
				<a
					href="{{ section.settings.shop_cta_url | default: '#' }}"
					class="inline-block rounded-xl text-sm font-semibold tracking-wide transition-opacity hover:opacity-90 bg-highlight text-white px-10 py-4 w-full md:w-auto text-center"
				>
					{{ section.settings.shop_cta_label }}
				</a>
			</div>
		{%- endif -%}

		{%- comment -%} Divider + CTA {%- endcomment -%}
		<div class="border-t {{ border_color }} mt-6 pt-6 text-center">
			{%- if section.settings.handle != blank -%}
				<p class="text-lg font-semibold {{ handle_color }}">{{ section.settings.handle }}</p>
			{%- endif -%}
			{%- if section.settings.cta_text != blank -%}
				<p class="text-base {{ cta_color }} mt-1">{{ section.settings.cta_text }}</p>
			{%- endif -%}
		</div>

	</div>
</section>

<script>
(function () {
	var section = document.querySelector('[data-ugc-section="{{ section.id }}"]');
	if (!section) return;
	var track = section.querySelector('[data-ugc-track]');
	var bar = section.querySelector('[data-ugc-progress]');
	if (!track) return;

	/* ── Scroll progress ── */
	function updateProgress() {
		if (!bar) return;
		var max = track.scrollWidth - track.clientWidth;
		if (max <= 0) { bar.style.width = '100%'; return; }
		var pct = (track.scrollLeft / max) * 100;
		bar.style.width = Math.max(5, Math.min(100, pct)) + '%';
	}
	track.addEventListener('scroll', updateProgress, { passive: true });
	updateProgress();

	/* ── Drag to scroll (desktop) ── */
	var isDown = false, startX = 0, scrollLeft = 0, hasDragged = false;

	track.addEventListener('mousedown', function (e) {
		isDown = true;
		hasDragged = false;
		startX = e.pageX - track.offsetLeft;
		scrollLeft = track.scrollLeft;
		track.classList.add('is-dragging');
	});

	window.addEventListener('mousemove', function (e) {
		if (!isDown) return;
		var x = e.pageX - track.offsetLeft;
		var delta = startX - x;
		if (Math.abs(delta) > 4) hasDragged = true;
		track.scrollLeft = scrollLeft + delta;
	});

	window.addEventListener('mouseup', function () {
		if (!isDown) return;
		isDown = false;
		track.classList.remove('is-dragging');
		resetAutoplay();
	});

	track.addEventListener('click', function (e) {
		if (hasDragged) e.stopPropagation();
	}, true);

	/* ── Auto-scroll every 3 seconds ── */
	var autoTimer = null;
	var userTouching = false;

	function getCardStep() {
		var card = track.firstElementChild;
		if (!card) return 200;
		return card.getBoundingClientRect().width + 12; /* 12 = gap-3 */
	}

	function autoScroll() {
		if (userTouching || isDown) return;
		var max = track.scrollWidth - track.clientWidth;
		var next = track.scrollLeft + getCardStep();
		if (next >= max - 2) {
			track.scrollTo({ left: 0, behavior: 'smooth' });
		} else {
			track.scrollTo({ left: next, behavior: 'smooth' });
		}
	}

	function resetAutoplay() {
		clearInterval(autoTimer);
		autoTimer = setInterval(autoScroll, 3000);
	}

	/* Pause on touch / hover */
	track.addEventListener('touchstart', function () { userTouching = true; clearInterval(autoTimer); }, { passive: true });
	track.addEventListener('touchend', function () { userTouching = false; resetAutoplay(); }, { passive: true });
	track.addEventListener('mouseenter', function () { clearInterval(autoTimer); });
	track.addEventListener('mouseleave', function () { if (!isDown) resetAutoplay(); });

	/* Start autoplay */
	resetAutoplay();
})();
</script>

{%- endif -%}

{% schema %}
{
	"name": "UGC Gallery",
	"settings": [
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow",
			"default": "See it in action"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "The Aira community"
		},
		{
			"type": "text",
			"id": "handle",
			"label": "Handle",
			"default": "@aira.breathing"
		},
		{
			"type": "text",
			"id": "cta_text",
			"label": "Bottom text",
			"default": "Share your experience — tag @aira.breathing"
		},
		{
			"type": "select",
			"id": "theme",
			"label": "Theme",
			"options": [
				{ "value": "dark",  "label": "Dark (navy)" },
				{ "value": "light", "label": "Light (cream)" }
			],
			"default": "dark"
		},
		{
			"type": "header",
			"content": "Shop CTA (optional)"
		},
		{
			"type": "text",
			"id": "shop_cta_label",
			"label": "Button label",
			"info": "Leave blank to hide the shop button."
		},
		{
			"type": "url",
			"id": "shop_cta_url",
			"label": "Button link"
		}
	],
	"blocks": [
		{
			"type": "testimonial",
			"name": "Testimonial",
			"limit": 8,
			"settings": [
				{
					"type": "image_picker",
					"id": "image",
					"label": "Image"
				},
				{
					"type": "text",
					"id": "quote",
					"label": "Quote"
				},
				{
					"type": "text",
					"id": "name",
					"label": "Name"
				}
			]
		}
	],
	"presets": [
		{
			"name": "UGC Gallery",
			"blocks": [
				{
					"type": "testimonial",
					"settings": {
						"quote": "I sleep so much better now",
						"name": "Sarah M."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "My partner noticed the difference immediately",
						"name": "James K."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "Game changer for my workouts",
						"name": "Aisha R."
					}
				},
				{
					"type": "testimonial",
					"settings": {
						"quote": "Finally stopped mouth breathing at night",
						"name": "Omar D."
					}
				}
			]
		}
	],
	"disabled_on": {
		"groups": ["header", "footer"]
	}
}
{% endschema %}
