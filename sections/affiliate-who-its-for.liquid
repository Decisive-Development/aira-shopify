{%- comment -%} Affiliate — Who it's for (scaffold). {%- endcomment -%}

<section class="bg-bg py-16 md:py-24">
	<div class="container mx-auto px-4 max-w-5xl">

		<header class="text-center mb-12">
			{%- if section.settings.eyebrow != blank -%}
				<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">{{ section.settings.eyebrow }}</p>
			{%- endif -%}
			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight text-3xl md:text-4xl text-title m-0">{{ section.settings.heading }}</h2>
			{%- endif -%}
			{%- if section.settings.subheading != blank -%}
				<p class="text-copy/80 text-base mt-3 max-w-2xl mx-auto">{{ section.settings.subheading }}</p>
			{%- endif -%}
		</header>

		{%- if section.blocks.size > 0 -%}
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{%- for block in section.blocks -%}
					<div class="rounded-xl bg-secondary p-6" {{ block.shopify_attributes }}>
						<h3 class="font-heading text-lg font-medium text-title m-0 mb-2">{{ block.settings.title }}</h3>
						<p class="text-sm text-copy/80 m-0">{{ block.settings.body }}</p>
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "Affiliate - Who it's for",
	"settings": [
		{ "type": "text",     "id": "eyebrow",    "label": "Eyebrow",    "default": "Who we partner with" },
		{ "type": "text",     "id": "heading",    "label": "Heading",    "default": "Built for voices, not metrics" },
		{ "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We care more about authenticity and audience fit than follower count." }
	],
	"blocks": [
		{
			"type": "fit",
			"name": "Fit card",
			"settings": [
				{ "type": "text",     "id": "title", "label": "Title", "default": "Wellness creators" },
				{ "type": "textarea", "id": "body",  "label": "Body",  "default": "Sleep, recovery, breathwork, mindfulness — anyone helping their audience live better." }
			]
		}
	],
	"presets": [
		{
			"name": "Affiliate - Who it's for",
			"blocks": [
				{ "type": "fit", "settings": { "title": "Wellness creators", "body": "Sleep, recovery, breathwork, mindfulness — anyone helping their audience live better." } },
				{ "type": "fit", "settings": { "title": "Athletes",          "body": "Endurance, combat, lifting — nasal breathing is performance, not just sleep." } },
				{ "type": "fit", "settings": { "title": "Lifestyle voices",  "body": "Honest reviews and real product use over scripted ads." } }
			]
		}
	]
}
{% endschema %}
