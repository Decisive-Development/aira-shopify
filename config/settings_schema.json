[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Brand colours",
    "settings": [
      {
        "type": "header",
        "content": "Brand colours"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary",
        "info": "Deep navy — headings, buttons, backgrounds",
        "default": "#0A1A34"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary",
        "info": "Warm cream — nav background, light surfaces",
        "default": "#F1EBE1"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "info": "Orange — CTAs, highlights",
        "default": "#FF4500"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#0A1A34"
      },
      {
        "type": "color",
        "id": "color_text_inverse",
        "label": "Inverse text",
        "info": "Text on dark backgrounds",
        "default": "#F1EBE1"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "Page background"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Support & contact",
    "settings": [
      {
        "type": "header",
        "content": "WhatsApp"
      },
      {
        "type": "text",
        "id": "support_whatsapp_number",
        "label": "WhatsApp Business number (no +, no spaces)",
        "info": "e.g., 971501234567 for +971 50 123 4567"
      },
      {
        "type": "text",
        "id": "support_whatsapp_prefill",
        "label": "Pre-filled WhatsApp message",
        "default": "Hi AIRA team,"
      },
      {
        "type": "header",
        "content": "Email"
      },
      {
        "type": "text",
        "id": "support_email",
        "label": "Customer support email",
        "default": "support@aira.com"
      },
      {
        "type": "text",
        "id": "partnerships_email",
        "label": "Partnerships / affiliate email",
        "default": "partnerships@aira.com"
      },
      {
        "type": "header",
        "content": "Business hours"
      },
      {
        "type": "text",
        "id": "business_hours_label",
        "label": "Hours label",
        "default": "Mon-Fri 9am-6pm GST"
      },
      {
        "type": "header",
        "content": "Legal entity (footer + contact page)"
      },
      {
        "type": "text",
        "id": "legal_entity_name",
        "label": "Registered business name"
      },
      {
        "type": "text",
        "id": "legal_license_number",
        "label": "Trade license / CR number"
      },
      {
        "type": "textarea",
        "id": "legal_business_address",
        "label": "Business address"
      }
    ]
  }
]
