{%- comment -%}
	Snippet: section-heading

	Parameters:
	  eyebrow    {String}  Small label above heading             (optional)
	  heading    {String}  Main heading                          (optional)
	  subheading {String}  Supporting paragraph                  (optional)
	  align      {String}  'left' | 'center' | 'right'          (default: 'center')
	  size       {String}  'sm' | 'md' | 'lg'                   (default: 'md')
	  surface    {String}  'light' | 'dark'                     (default: 'light')

	Usage:
	  {%- render 'section-heading',
	      eyebrow:    'See the difference',
	      heading:    'Breathe freely.',
	      subheading: 'Drag to compare.',
	      align:      'center',
	      size:       'md',
	      surface:    'light'
	  -%}
{%- endcomment -%}

{%- liquid
	assign align   = align   | default: 'center'
	assign size    = size    | default: 'md'
	assign surface = surface | default: 'light'

	case align
		when 'left'
			assign align_class = 'text-left'
			assign body_mx     = ''
		when 'right'
			assign align_class = 'text-right'
			assign body_mx     = 'ml-auto'
		else
			assign align_class = 'text-center'
			assign body_mx     = 'mx-auto'
	endcase

	case size
		when 'sm'
			assign h_class = 'text-3xl md:text-4xl'
		when 'lg'
			assign h_class = 'text-5xl md:text-6xl lg:text-7xl'
		else
			assign h_class = 'text-4xl md:text-5xl'
	endcase

	if surface == 'dark'
		assign eyebrow_color = 'text-tertiary-light'
		assign heading_color = 'text-secondary'
		assign sub_color     = 'text-secondary/80'
	else
		assign eyebrow_color = 'text-highlight'
		assign heading_color = 'text-title'
		assign sub_color     = 'text-copy'
	endif
-%}

{%- if eyebrow != blank or heading != blank or subheading != blank -%}
	<div class="flex flex-col gap-2 md:gap-3 {{ align_class }}">

		{%- if eyebrow != blank -%}
			<p class="text-xs font-bold uppercase tracking-widest {{ eyebrow_color }}">{{ eyebrow }}</p>
		{%- endif -%}

		{%- if heading != blank -%}
			<h2 class="font-heading font-bold {{ h_class }} leading-none tracking-tight {{ heading_color }}">{{ heading }}</h2>
		{%- endif -%}

		{%- if subheading != blank -%}
			<p class="text-base md:text-lg leading-relaxed {{ sub_color }} max-w-2xl {{ body_mx }}">{{ subheading }}</p>
		{%- endif -%}

	</div>
{%- endif -%}
