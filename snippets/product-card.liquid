{%- comment -%}
	snippets/product-card.liquid
	Params:
		product     — Shopify product object (required)
		badge       — String badge text shown on image (optional)
		description — Custom card description from CMS (optional)
{%- endcomment -%}

{%- assign first_variant = product.selected_or_first_available_variant | default: product.variants.first -%}
{%- assign has_selling_plans = false -%}
{%- if product.selling_plan_groups.size > 0 -%}
	{%- assign has_selling_plans = true -%}
	{%- assign sp_group = product.selling_plan_groups.first -%}
	{%- assign sp_first = sp_group.selling_plans.first -%}
	{%- assign sp_allocation = first_variant.selling_plan_allocations | where: "selling_plan_id", sp_first.id | first -%}
{%- endif -%}

<div class="flex flex-col bg-bg rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300" data-product-card>

	{%- comment -%} Image {%- endcomment -%}
	<a href="{{ product.url }}" class="block relative aspect-4/5 overflow-hidden bg-bg-muted group">
		{%- if product.featured_image -%}
			{{
				product.featured_image
				| image_url: width: 800
				| image_tag:
					loading: 'lazy',
					class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
					widths: '400, 600, 800',
					draggable: 'false'
			}}
		{%- endif -%}

		{%- if badge != blank -%}
			<span class="absolute top-3 left-3 px-3 py-1 rounded-lg bg-main text-secondary text-xs font-bold tracking-wide pointer-events-none">
				{{ badge }}
			</span>
		{%- endif -%}
	</a>

	{%- comment -%} Content {%- endcomment -%}
	<div class="flex flex-col flex-1 p-6 gap-4">

		{%- comment -%} Title + custom description {%- endcomment -%}
		<div>
			<h3 class="font-heading text-title font-semibold text-xl leading-snug">
				{{ product.title }}
			</h3>
			{%- if description != blank -%}
				<p class="text-copy text-sm leading-relaxed mt-2">{{ description }}</p>
			{%- elsif product.description != blank -%}
				<p class="text-copy text-sm leading-relaxed mt-2">{{ product.description | strip_html | truncate: 120 }}</p>
			{%- endif -%}
		</div>

		{%- comment -%} Purchase form {%- endcomment -%}
		<form action="{{ routes.cart_add_url }}" method="post" class="flex flex-col gap-3 mt-auto" data-product-form>
			<input type="hidden" name="id" value="{{ first_variant.id }}" data-variant-id>
			<input type="hidden" name="quantity" value="1">

			{%- if has_selling_plans -%}
				<input type="hidden" name="selling_plan" value="" data-selling-plan-input>

				<div class="flex flex-col gap-2.5" data-selling-plan-group>

					{%- comment -%} ── Subscribe option (promoted) ── {%- endcomment -%}
					<button
						type="button"
						class="flex flex-col gap-1.5 p-4 rounded-xl border-2 border-main bg-bg-soft text-left transition-colors"
						data-plan-btn="subscribe"
					>
						<div class="flex items-center justify-between w-full">
							<span class="font-heading text-sm font-bold text-title">Subscribe & save</span>
							<span class="w-5 h-5 rounded-full border-2 border-main flex items-center justify-center shrink-0" data-plan-radio="subscribe">
								<span class="w-2.5 h-2.5 rounded-full bg-main"></span>
							</span>
						</div>
						<p class="text-xs text-copy leading-snug">Hassle-free restock at a discount, delivered on your schedule</p>
						<div class="flex items-baseline gap-2 mt-0.5">
							<span class="font-heading font-bold text-lg text-title" data-subscribe-price>
								{%- if sp_allocation -%}{{ sp_allocation.per_delivery_price | money }}{%- endif -%}
							</span>
							<span class="text-xs text-copy">/ {{ sp_first.name | downcase }}</span>
							{%- if sp_allocation -%}
								{%- assign sp_price = sp_allocation.per_delivery_price -%}
								{%- assign save_amount = first_variant.price | minus: sp_price -%}
								{%- if save_amount > 0 -%}
									<span class="text-xs font-bold text-highlight-green">Save {{ save_amount | money }}</span>
								{%- endif -%}
							{%- endif -%}
						</div>
					</button>

					{%- comment -%} ── Divider ── {%- endcomment -%}
					<p class="text-xs text-copy text-center py-0.5">Or buy one time</p>

					{%- comment -%} ── One-time option ── {%- endcomment -%}
					<button
						type="button"
						class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl border-2 border-bg-muted bg-bg text-left transition-colors"
						data-plan-btn="onetime"
					>
						<span class="font-heading text-sm font-semibold text-title">One-time purchase</span>
						<span class="w-5 h-5 rounded-full border-2 border-bg-muted flex items-center justify-center shrink-0" data-plan-radio="onetime"></span>
					</button>

				</div>

				{%- comment -%} Variant options (quantity tabs etc) {%- endcomment -%}
				{%- for option in product.options_with_values -%}
					{%- assign opt_index = forloop.index0 -%}
					<div>
						<p class="text-xs font-semibold text-copy mb-1.5">{{ option.name }}</p>
						<div class="flex gap-2 flex-wrap" data-option-group="{{ opt_index }}" data-type="pill">
							{%- for value in option.values -%}
								{%- liquid
									assign is_active = false
									if first_variant.options[opt_index] == value
										assign is_active = true
									endif
								-%}
								<button
									type="button"
									class="px-3.5 py-1.5 rounded-lg text-sm font-medium border-2 transition-colors {% if is_active %}bg-main text-secondary border-main{% else %}bg-bg border-bg-muted text-copy{% endif %}"
									data-option-btn
									data-option-index="{{ opt_index }}"
									data-option-value="{{ value }}"
								>{{ value }}</button>
							{%- endfor -%}
						</div>
					</div>
				{%- endfor -%}

			{%- else -%}

				{%- comment -%} No selling plans — standard option selectors {%- endcomment -%}
				{%- for option in product.options_with_values -%}
					{%- liquid
						assign opt_index = forloop.index0
						assign is_colour = false
						if option.name == 'Colour' or option.name == 'Color'
							assign is_colour = true
						endif
					-%}

					{%- if is_colour -%}
						<div class="flex gap-2.5 items-center" data-option-group="{{ opt_index }}" data-type="colour">
							{%- for value in option.values -%}
								{%- liquid
									assign swatch_hex = '#888888'
									case value
										when 'Black'
											assign swatch_hex = '#1A1A1A'
										when 'Beige'
											assign swatch_hex = '#C8B89A'
									endcase
									assign is_active = false
									if first_variant.options[opt_index] == value
										assign is_active = true
									endif
								-%}
								<button
									type="button"
									class="w-7 h-7 rounded-full border-2 transition-all {% if is_active %}border-main ring-2 ring-main ring-offset-1{% else %}border-transparent{% endif %}"
									style="background: {{ swatch_hex }}"
									data-option-btn
									data-option-index="{{ opt_index }}"
									data-option-value="{{ value }}"
									aria-label="{{ value }}"
									title="{{ value }}"
								></button>
							{%- endfor -%}
						</div>
					{%- else -%}
						<div class="flex gap-2 flex-wrap" data-option-group="{{ opt_index }}" data-type="pill">
							{%- for value in option.values -%}
								{%- liquid
									assign is_active = false
									if first_variant.options[opt_index] == value
										assign is_active = true
									endif
								-%}
								<button
									type="button"
									class="px-3.5 py-1.5 rounded-lg text-sm font-medium border-2 transition-colors {% if is_active %}bg-main text-secondary border-main{% else %}bg-bg border-bg-muted text-copy{% endif %}"
									data-option-btn
									data-option-index="{{ opt_index }}"
									data-option-value="{{ value }}"
								>{{ value }}</button>
							{%- endfor -%}
						</div>
					{%- endif -%}
				{%- endfor -%}

			{%- endif -%}

			{%- comment -%} Price + CTA {%- endcomment -%}
			<div class="flex items-center justify-between gap-4 pt-1">
				<div>
					<span class="font-heading text-title font-bold text-2xl" data-price>{{ first_variant.price | money }}</span>
					{%- if first_variant.compare_at_price > first_variant.price -%}
						<span class="block text-copy text-sm line-through" data-compare-price>{{ first_variant.compare_at_price | money }}</span>
					{%- endif -%}
				</div>
				<button
					type="submit"
					class="shrink-0 px-6 py-3 rounded-xl bg-main text-secondary text-sm font-semibold transition-opacity hover:opacity-80 disabled:opacity-40 disabled:cursor-not-allowed"
					data-add-to-cart
					{% unless first_variant.available %}disabled{% endunless %}
				>
					{%- if first_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
				</button>
			</div>

		</form>

	</div>

	{%- comment -%} Variant data for JS {%- endcomment -%}
	<script type="application/json" data-product-variants>
		[
			{%- for variant in product.variants -%}
				{
					"id": {{ variant.id }},
					"options": {{ variant.options | json }},
					"price": {{ variant.price }},
					"price_formatted": {{ variant.price | money | json }},
					"compare_at_price": {{ variant.compare_at_price | default: 0 }},
					"compare_at_price_formatted": {% if variant.compare_at_price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
					"available": {{ variant.available | json }},
					"image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 800 | json }}{% else %}null{% endif %},
					"selling_plan_allocations": [
						{%- for alloc in variant.selling_plan_allocations -%}
							{
								"selling_plan_id": {{ alloc.selling_plan.id }},
								"per_delivery_price": {{ alloc.per_delivery_price }},
								"per_delivery_price_formatted": {{ alloc.per_delivery_price | money | json }},
								"name": {{ alloc.selling_plan.name | json }}
							}{%- unless forloop.last -%},{%- endunless -%}
						{%- endfor -%}
					]
				}{%- unless forloop.last -%},{%- endunless -%}
			{%- endfor -%}
		]
	</script>

</div>
