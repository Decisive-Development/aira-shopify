{%- comment -%}
	CTA Button — Aira 4-tier system

	Tiers (descending emphasis):
	  shop     Orange solid    — the ONE Shop CTA. Reserve orange for buying only.
	  solid    Navy/cream solid — primary secondary action (Add to Cart, Subscribe, submit).
	  outline  Outlined        — secondary action; navy on light, white on dark.
	  link     Ghost + arrow   — low-emphasis text link ("learn more", "the science").

	Parameters:
	  label         {String}  Button text (required)
	  url           {String}  href when element is 'a'                (default: '#')
	  variant       {String}  'shop' | 'solid' | 'outline' | 'link'   (default: 'solid')
	  surface       {String}  'light' | 'dark' — background it sits on (default: 'light')
	  size          {String}  'sm' | 'md' | 'lg'                      (default: 'md')
	  element       {String}  'a' | 'button'                          (default: 'a')
	  button_type   {String}  'button' | 'submit' | 'reset'           (default: 'button')
	  arrow         {Boolean} trailing arrow on 'link' variant        (default: true)
	  full_width    {Boolean} stretch to container width              (default: false)
	  disabled      {Boolean} disabled state (button element only)    (default: false)
	  attributes    {String}  raw extra attributes (id, data-*, aria-*) appended to the tag
	  extra_classes {String}  additional classes
{%- endcomment -%}

{%- liquid
	assign btn_variant = variant | default: 'solid'
	assign btn_surface = surface | default: 'light'
	assign btn_size    = size    | default: 'md'
	assign btn_element = element | default: 'a'
	assign btn_type    = button_type | default: 'button'

	# Colour + box per tier × surface.
	# Filled buttons use py-3 (no border); the outline uses py-2.5 + a 2px
	# border — both resolve to the same height so they line up side by side.
	# Hover = "press": the button sinks 1px, dims slightly and casts a soft
	# shadow tinted in its own brand colour. The outline fills on hover.
	case btn_variant
		when 'shop'
			assign btn_colors = 'bg-highlight text-white py-3 hover:brightness-95 hover:translate-y-px hover:shadow-md hover:shadow-highlight/20'
		when 'solid'
			if btn_surface == 'dark'
				assign btn_colors = 'bg-secondary text-main py-3 hover:brightness-95 hover:translate-y-px hover:shadow-md hover:shadow-secondary/30'
			else
				assign btn_colors = 'bg-main text-secondary py-3 hover:brightness-95 hover:translate-y-px hover:shadow-md hover:shadow-main/20'
			endif
		when 'outline'
			if btn_surface == 'dark'
				assign btn_colors = 'border-2 border-secondary/60 text-secondary py-2.5 hover:bg-secondary hover:text-main hover:translate-y-px hover:shadow-md hover:shadow-secondary/30'
			else
				assign btn_colors = 'border-2 border-main text-main py-2.5 hover:bg-main hover:text-secondary hover:translate-y-px hover:shadow-md hover:shadow-main/20'
			endif
		when 'link'
			if btn_surface == 'dark'
				assign btn_colors = 'text-secondary hover:opacity-70'
			else
				assign btn_colors = 'text-main hover:opacity-70'
			endif
	endcase

	# Sizing — horizontal padding + text size only. Vertical padding is set
	# per variant above so bordered/unbordered buttons match in height.
	case btn_size
		when 'sm'
			assign btn_padding = 'px-6 text-sm'
		when 'md'
			assign btn_padding = 'px-8 text-sm'
		when 'lg'
			assign btn_padding = 'px-10 text-sm'
	endcase

	# 'link' has no fill and minimal padding
	if btn_variant == 'link'
		assign btn_padding = 'px-1 py-1 text-sm'
	endif

	# Assemble classes
	assign btn_base = 'group inline-flex items-center justify-center gap-2 rounded-xl font-semibold tracking-wide transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] active:duration-75 cursor-pointer'
	assign btn_classes = btn_base | append: ' ' | append: btn_colors | append: ' ' | append: btn_padding

	if full_width
		assign btn_classes = btn_classes | append: ' w-full text-center'
	endif
	if disabled
		assign btn_classes = btn_classes | append: ' disabled:opacity-40 disabled:cursor-not-allowed'
	endif
	if extra_classes != blank
		assign btn_classes = btn_classes | append: ' ' | append: extra_classes
	endif

	assign show_arrow = arrow
	if show_arrow == nil
		assign show_arrow = true
	endif
-%}

{%- capture btn_inner -%}
	{{ label }}
	{%- if btn_variant == 'link' and show_arrow -%}
		<span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
	{%- endif -%}
{%- endcapture -%}

{%- if btn_element == 'button' -%}
	<button type="{{ btn_type }}" class="{{ btn_classes }}"{% if disabled %} disabled{% endif %} {{ attributes }}>{{ btn_inner }}</button>
{%- else -%}
	<a href="{{ url | default: '#' }}" class="{{ btn_classes }}" {{ attributes }}>{{ btn_inner }}</a>
{%- endif -%}
