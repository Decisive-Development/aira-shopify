{%- comment -%}
	snippets/cart-drawer.liquid
	Slide-out cart drawer with refill upsell.
	Included once in theme.liquid before </body>.
{%- endcomment -%}

{%- assign refill_product = all_products['aira-refill-tabs'] -%}
{%- assign refill_variant = refill_product.selected_or_first_available_variant | default: refill_product.variants.first -%}

<style>
	.cart-drawer-closed { transform: translateX(calc(100% + 0.75rem)); }
	.cart-drawer-open   { transform: translateX(0); }
</style>

{%- comment -%} Backdrop {%- endcomment -%}
<div
	data-cart-backdrop
	class="fixed inset-0 z-60 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
	aria-hidden="true"
></div>

{%- comment -%} Drawer {%- endcomment -%}
<aside
	data-cart-drawer
	style="max-width: min(32rem, calc(100vw - 1.5rem));"
	class="fixed top-3 right-3 bottom-3 z-61 w-full bg-bg shadow-2xl rounded-2xl transition-transform duration-300 ease-out flex flex-col overflow-hidden cart-drawer-closed"
	aria-label="Shopping cart"
>
	{%- comment -%} Header {%- endcomment -%}
	<div class="flex items-center justify-between px-6 py-5 border-b border-bg-muted">
		<h2 class="font-heading font-semibold text-title text-xl">Your Cart</h2>
		<button data-cart-close class="text-copy hover:text-title transition-colors cursor-pointer" aria-label="Close cart">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>
	</div>

	{%- comment -%} Scrollable body {%- endcomment -%}
	<div class="flex-1 overflow-y-auto px-6 py-5" data-cart-body>

		{%- comment -%} Empty state {%- endcomment -%}
		<div data-cart-empty class="hidden flex-col items-center justify-center text-center py-16 gap-4">
			<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" class="text-copy opacity-25">
				<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
			</svg>
			<p class="text-copy text-base">Your cart is empty</p>
			<a href="/products/aira-starter-kit" class="inline-block px-6 py-3 rounded-xl bg-main text-secondary text-base font-semibold transition-opacity hover:opacity-90 cursor-pointer">
				Shop Starter Kit
			</a>
		</div>

		{%- comment -%} Line items (rendered by JS) {%- endcomment -%}
		<div data-cart-items class="flex flex-col gap-4"></div>

		{%- comment -%} Upsell — refill tabs {%- endcomment -%}
		{%- if refill_product != blank and refill_variant != blank -%}
			<div data-cart-upsell class="hidden mt-6 p-4 rounded-2xl border-2 border-dashed border-bg-muted bg-bg-soft">
				<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-3">Complete your kit</p>
				<div class="flex items-center gap-4">
					{%- if refill_product.featured_image -%}
						<a href="{{ refill_product.url }}" class="shrink-0 w-16 h-16 rounded-xl overflow-hidden bg-bg-muted">
							{{ refill_product.featured_image | image_url: width: 128 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover' }}
						</a>
					{%- endif -%}
					<div class="flex-1 min-w-0">
						<p class="font-heading font-semibold text-title text-base leading-snug truncate">{{ refill_product.title }}</p>
						<p class="text-copy text-base mt-0.5">{{ refill_variant.price | money }}</p>
					</div>
					<button
						type="button"
						data-upsell-add
						data-upsell-variant-id="{{ refill_variant.id }}"
						class="shrink-0 px-5 py-2.5 rounded-xl bg-main text-secondary text-sm font-bold transition-opacity hover:opacity-90 cursor-pointer"
					>
						Add
					</button>
				</div>
			</div>
		{%- endif -%}

	</div>

	{%- comment -%} Footer — subtotal + checkout {%- endcomment -%}
	<div data-cart-footer class="hidden border-t border-border px-6 py-5 flex flex-col gap-4">
		<div class="flex items-center justify-between">
			<span class="font-heading font-semibold text-title text-lg">Subtotal</span>
			<span class="font-heading font-bold text-title text-xl" data-cart-subtotal></span>
		</div>
		<p class="text-copy text-sm">Shipping & taxes calculated at checkout</p>
		<p class="text-center text-highlight text-sm font-semibold">Free shipping on all orders</p>
		<a href="/checkout" data-cart-checkout class="block w-full text-center px-6 py-4 rounded-xl bg-main text-secondary text-base font-bold transition-opacity hover:opacity-90 cursor-pointer">
			Checkout
		</a>
		<button type="button" data-cart-close class="w-full text-center text-copy text-sm font-semibold hover:text-title transition-colors cursor-pointer">
			Continue shopping
		</button>
	</div>
</aside>

<script>
(function () {
	/* ── Refs ── */
	var backdrop = document.querySelector('[data-cart-backdrop]');
	var drawer   = document.querySelector('[data-cart-drawer]');
	var closeBtn = document.querySelector('[data-cart-close]');
	var body     = document.querySelector('[data-cart-body]');
	var itemsEl  = document.querySelector('[data-cart-items]');
	var emptyEl  = document.querySelector('[data-cart-empty]');
	var upsellEl = document.querySelector('[data-cart-upsell]');
	var footerEl = document.querySelector('[data-cart-footer]');
	var subtotalEl = document.querySelector('[data-cart-subtotal]');
	var upsellBtn  = document.querySelector('[data-upsell-add]');

	var REFILL_HANDLE = 'aira-refill-tabs';
	var isOpen = false;

	/* ── Open / close ── */
	function open() {
		if (isOpen) return;
		isOpen = true;
		backdrop.classList.remove('opacity-0', 'pointer-events-none');
		backdrop.classList.add('opacity-100', 'pointer-events-auto');
		drawer.classList.remove('cart-drawer-closed');
		drawer.classList.add('cart-drawer-open');
		document.body.style.overflow = 'hidden';
	}

	function close() {
		if (!isOpen) return;
		isOpen = false;
		backdrop.classList.add('opacity-0', 'pointer-events-none');
		backdrop.classList.remove('opacity-100', 'pointer-events-auto');
		drawer.classList.remove('cart-drawer-open');
		drawer.classList.add('cart-drawer-closed');
		document.body.style.overflow = '';
	}

	document.querySelectorAll('[data-cart-close]').forEach(function (b) { b.addEventListener('click', close); });
	backdrop.addEventListener('click', close);
	document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

	/* ── Cart icon clicks → open drawer ── */
	document.querySelectorAll('[data-cart-toggle]').forEach(function (el) {
		el.addEventListener('click', function (e) {
			e.preventDefault();
			open();
			fetchAndRender();
		});
	});

	/* ── Intercept all add-to-cart forms ── */
	document.addEventListener('submit', function (e) {
		var form = e.target;
		if (!form.matches('form[action*="/cart/add"]')) return;
		e.preventDefault();

		var formData = new FormData(form);
		var btn = form.querySelector('[data-add-to-cart]');
		if (btn) { btn.disabled = true; btn.textContent = 'Adding...'; }

		fetch('/cart/add.js', {
			method: 'POST',
			body: formData
		})
		.then(function (r) { return r.json(); })
		.then(function () {
			return fetchAndRender();
		})
		.then(function () {
			open();
			if (btn) { btn.disabled = false; btn.textContent = 'Add to Cart'; }
		})
		.catch(function () {
			if (btn) { btn.disabled = false; btn.textContent = 'Add to Cart'; }
		});
	});

	/* ── Upsell add ── */
	if (upsellBtn) {
		upsellBtn.addEventListener('click', function () {
			var vid = upsellBtn.getAttribute('data-upsell-variant-id');
			upsellBtn.disabled = true;
			upsellBtn.textContent = 'Adding...';

			fetch('/cart/add.js', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ items: [{ id: parseInt(vid, 10), quantity: 1 }] })
			})
			.then(function () { return fetchAndRender(); })
			.then(function () {
				upsellBtn.disabled = false;
				upsellBtn.textContent = 'Add';
			})
			.catch(function () {
				upsellBtn.disabled = false;
				upsellBtn.textContent = 'Add';
			});
		});
	}

	/* ── Fetch cart & render ── */
	function fetchAndRender() {
		return fetch('/cart.js')
			.then(function (r) { return r.json(); })
			.then(function (cart) { render(cart); });
	}

	function render(cart) {
		var hasItems = cart.item_count > 0;

		/* Toggle empty / filled states */
		emptyEl.classList.toggle('hidden', hasItems);
		emptyEl.classList.toggle('flex', !hasItems);
		itemsEl.classList.toggle('hidden', !hasItems);
		footerEl.classList.toggle('hidden', !hasItems);
		footerEl.classList.toggle('flex', hasItems);

		/* Update header cart counts */
		document.querySelectorAll('[data-cart-count]').forEach(function (el) {
			el.textContent = cart.item_count;
			el.closest('[data-cart-count-bubble]').classList.toggle('hidden', cart.item_count === 0);
		});

		/* Subtotal */
		if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price);

		/* Check if refills already in cart */
		var hasRefills = cart.items.some(function (item) {
			return item.handle === REFILL_HANDLE;
		});
		if (upsellEl) {
			upsellEl.classList.toggle('hidden', !hasItems || hasRefills);
		}

		/* Build line items */
		itemsEl.innerHTML = cart.items.map(function (item) {
			var img = item.featured_image && item.featured_image.url
				? '<img src="' + sizedImg(item.featured_image.url, '160x') + '" alt="" class="w-full h-full object-cover" loading="lazy">'
				: '';
			var props = '';
			if (item.variant_title) {
				props = '<p class="text-copy text-sm mt-0.5">' + escHtml(item.variant_title) + '</p>';
			}
			return '<div class="flex gap-4 items-start" data-line-key="' + item.key + '">'
				+ '<a href="' + item.url + '" class="shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-bg-muted">' + img + '</a>'
				+ '<div class="flex-1 min-w-0">'
					+ '<p class="font-heading font-semibold text-title text-base leading-snug">' + escHtml(item.product_title) + '</p>'
					+ props
					+ '<div class="flex items-center gap-3 mt-2">'
						+ '<div class="flex items-center border border-bg-muted rounded-lg">'
							+ '<button type="button" data-qty-change="-1" data-line-key="' + item.key + '" class="w-8 h-8 flex items-center justify-center text-copy hover:text-title transition-colors text-base cursor-pointer">\u2212</button>'
							+ '<span class="w-8 h-8 flex items-center justify-center text-base font-semibold text-title">' + item.quantity + '</span>'
							+ '<button type="button" data-qty-change="1" data-line-key="' + item.key + '" class="w-8 h-8 flex items-center justify-center text-copy hover:text-title transition-colors text-base cursor-pointer">+</button>'
						+ '</div>'
						+ '<span class="shrink-0 font-heading font-bold text-title text-base">' + formatMoney(item.final_line_price) + '</span>'
					+ '</div>'
					+ '<button type="button" data-line-remove data-line-key="' + item.key + '" class="text-copy hover:text-highlight text-sm transition-colors mt-1 cursor-pointer">Remove</button>'
				+ '</div>'
			+ '</div>';
		}).join('');
	}

	/* ── Quantity change / remove (event delegation) ── */
	itemsEl.addEventListener('click', function (e) {
		var qtyBtn = e.target.closest('[data-qty-change]');
		var removeBtn = e.target.closest('[data-line-remove]');

		if (qtyBtn) {
			var key = qtyBtn.getAttribute('data-line-key');
			var delta = parseInt(qtyBtn.getAttribute('data-qty-change'), 10);
			var qtySpan = qtyBtn.parentElement.querySelector('span');
			var currentQty = parseInt(qtySpan.textContent, 10);
			var newQty = Math.max(0, currentQty + delta);
			updateLine(key, newQty);
		}

		if (removeBtn) {
			var key = removeBtn.getAttribute('data-line-key');
			updateLine(key, 0);
		}
	});

	function updateLine(key, qty) {
		fetch('/cart/change.js', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ id: key, quantity: qty })
		})
		.then(function (r) { return r.json(); })
		.then(function (cart) { render(cart); });
	}

	/* ── Helpers ── */
	function formatMoney(cents) {
		return (cents / 100).toLocaleString(undefined, { style: 'currency', currency: {{ cart.currency.iso_code | default: shop.currency | json }} });
	}

	function sizedImg(url, size) {
		/* Shopify CDN: insert _160x before the file extension */
		return url.replace(/(\.\w+)(\?|$)/, '_' + size + '$1$2');
	}

	function escHtml(str) {
		var d = document.createElement('div');
		d.textContent = str;
		return d.innerHTML;
	}

	/* ── Init: pre-load cart state ── */
	fetchAndRender();
})();
</script>
