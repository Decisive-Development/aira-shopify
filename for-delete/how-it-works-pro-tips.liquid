{%- comment -%}
	How it works — Pro Tips
	Dark navy strip with two layered radials (orange top-right, light blue bottom-left).
	3-up grid of cards on translucent cream surfaces.
{%- endcomment -%}

{%- assign tips = section.blocks | where: 'type', 'tip' -%}

<section class="bg-main py-16 md:py-24 relative overflow-hidden">
	<div
		class="absolute inset-0 pointer-events-none"
		style="background:
			radial-gradient(ellipse 80vw 60vh at 15% 30%, rgba(160, 195, 230, 0.28) 0%, rgba(160, 195, 230, 0) 60%),
			radial-gradient(ellipse 75vw 55vh at 85% 70%, rgba(140, 180, 220, 0.24) 0%, rgba(140, 180, 220, 0) 65%);"
	></div>

	<div class="container-contained relative z-10">

		<div class="max-w-2xl reveal">
			{%- if section.settings.eyebrow != blank -%}
				<p class="text-xs font-bold uppercase tracking-widest text-secondary">{{ section.settings.eyebrow }}</p>
			{%- endif -%}
			{%- if section.settings.heading != blank -%}
				<h2 class="font-heading heading-weight text-secondary text-3xl md:text-5xl mt-3 leading-tight">{{ section.settings.heading }}</h2>
			{%- endif -%}
			{%- if section.settings.lead != blank -%}
				<p class="text-secondary text-base md:text-lg leading-relaxed mt-4">{{ section.settings.lead }}</p>
			{%- endif -%}
		</div>

		{%- if tips.size > 0 -%}
			<div class="grid md:grid-cols-3 gap-5 md:gap-6 mt-12 reveal">
				{%- for block in tips -%}
					<div class="rounded-2xl p-6 md:p-7" style="background: rgba(241, 235, 225, 0.06); border: 1px solid rgba(241, 235, 225, 0.10);" {{ block.shopify_attributes }}>
						<p class="font-heading text-secondary text-lg" style="font-weight: 600;">{{ block.settings.title }}</p>
						{%- if block.settings.body != blank -%}
							<p class="text-secondary text-lg leading-relaxed mt-2">{{ block.settings.body }}</p>
						{%- endif -%}
					</div>
				{%- endfor -%}
			</div>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "How it works — Pro Tips",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{ "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Pro tips" },
		{ "type": "text",     "id": "heading", "label": "Heading", "default": "Once you've got the basics." },
		{ "type": "textarea", "id": "lead",    "label": "Lead",    "default": "A few things experienced wearers do differently. Worth a try once you're comfortable with the routine." }
	],
	"blocks": [
		{
			"type": "tip",
			"name": "Pro tip",
			"limit": 6,
			"settings": [
				{
					"type": "select",
					"id": "icon",
					"label": "Icon",
					"options": [
						{ "value": "bolt",    "label": "Bolt" },
						{ "value": "clock",   "label": "Clock" },
						{ "value": "home",    "label": "Home" },
						{ "value": "sparkle", "label": "Sparkle" }
					],
					"default": "bolt"
				},
				{ "type": "text",     "id": "title", "label": "Title", "default": "Pair sizes for activity" },
				{ "type": "textarea", "id": "body",  "label": "Body",  "default": "Use a smaller strip for sport (less pull on the tabs) and a larger strip for sleep (wider airflow). Many wearers keep both bedside." }
			]
		}
	],
	"presets": [
		{ "name": "How it works — Pro Tips" }
	]
}
{% endschema %}
