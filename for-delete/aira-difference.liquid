{%- comment -%}
	The aira difference — editorial interlude on cream. Left-aligned: eyebrow,
	large heading, two-column body, then a short rule with a conviction line and
	a low-emphasis link. Optional image renders only when set. No JS.
{%- endcomment -%}

<section
	id="aira-difference-{{ section.id }}"
	class="bg-cream-light"
>
	<div class="container-contained py-16 md:py-32">

		{%- comment -%} Eyebrow {%- endcomment -%}
		{%- if section.settings.eyebrow != blank -%}
			<p class="text-xs font-bold uppercase tracking-widest text-highlight mb-6 md:mb-8">
				{{ section.settings.eyebrow }}
			</p>
		{%- endif -%}

		{%- comment -%} Heading {%- endcomment -%}
		{%- if section.settings.heading != blank -%}
			<h2 class="font-heading heading-weight text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight text-title max-w-3xl text-balance">
				{{ section.settings.heading }}
			</h2>
		{%- endif -%}

		{%- comment -%} Body — two columns on desktop, stacked on mobile {%- endcomment -%}
		{%- if section.settings.body != blank -%}
			<div class="text-base md:text-lg leading-relaxed text-copy mt-8 md:mt-12 md:columns-2 md:gap-x-16 [&>p]:mb-5 md:[&>p]:mb-0 [&>p]:break-inside-avoid">
				{{ section.settings.body }}
			</div>
		{%- endif -%}

		{%- comment -%} Optional image — hidden entirely when blank {%- endcomment -%}
		{%- if section.settings.image != blank -%}
			<div class="mt-12 md:mt-16">
				{{
					section.settings.image
					| image_url: width: 1600
					| image_tag:
						loading: 'lazy',
						class: 'w-full h-auto rounded-2xl',
						widths: '600, 900, 1280, 1600',
						alt: section.settings.image.alt
				}}
			</div>
		{%- endif -%}

		{%- comment -%} Conviction line — short rule, then kicker + link {%- endcomment -%}
		{%- if section.settings.kicker_line != blank or section.settings.cta_label != blank -%}
			<div class="mt-12 md:mt-16">
				<div class="h-[3px] w-12 bg-highlight"></div>
				<div class="mt-6 md:mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
					{%- if section.settings.kicker_line != blank -%}
						<p class="font-heading font-bold text-title text-xl md:text-2xl tracking-tight">
							{{ section.settings.kicker_line }}
						</p>
					{%- endif -%}

					{%- if section.settings.cta_label != blank -%}
						<div class="shrink-0">
							{%- render 'cta-button',
								label: section.settings.cta_label,
								url: section.settings.cta_url,
								variant: 'link'
							-%}
						</div>
					{%- endif -%}
				</div>
			</div>
		{%- endif -%}

	</div>
</section>

{% schema %}
{
	"name": "aira Difference",
	"tag": "section",
	"class": "shopify-section",
	"settings": [
		{ "type": "header", "content": "Content" },
		{
			"type": "text",
			"id": "eyebrow",
			"label": "Eyebrow"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Most sleep problems are breathing problems."
		},
		{
			"type": "richtext",
			"id": "body",
			"label": "Body",
			"info": "Two paragraphs render side by side as two columns on desktop.",
			"default": "<p>The snoring that sends your partner to the sofa. The dry mouth at 6am. The eight hours that somehow weren't enough. They look like different problems, but they usually share one root: your nose closes, and your mouth takes over.</p><p>Keep your airway open through the night, and the dominoes fall the other way. Quieter rooms. Deeper sleep. Easier mornings, faster recovery. Nothing to learn, nothing to remember: it works while you sleep.</p>"
		},
		{
			"type": "text",
			"id": "kicker_line",
			"label": "Kicker line",
			"default": "Fix the breathing. The rest follows."
		},
		{ "type": "header", "content": "CTA" },
		{
			"type": "text",
			"id": "cta_label",
			"label": "Conviction link label",
			"default": "How it works"
		},
		{
			"type": "url",
			"id": "cta_url",
			"label": "Conviction link URL"
		},
		{ "type": "header", "content": "Image" },
		{
			"type": "image_picker",
			"id": "image",
			"label": "Image (optional)",
			"info": "Hidden entirely when blank — reserved for later photography."
		}
	],
	"presets": [
		{
			"name": "aira Difference"
		}
	]
}
{% endschema %}
